class MT5Integration:
    """Полная интеграция с MetaTrader 5 - PRIME VERSION (без заглушек)"""
    
    _instance = None
    _instances: Dict[str, 'MT5Integration'] = {}
    _price_cache: Dict[str, List[float]] = {}
    
    def __new__(cls, connection_id: str = "default"):
        if connection_id not in cls._instances:
            instance = super().__new__(cls)
            instance._initialized = False
            cls._instances[connection_id] = instance
        return cls._instances[connection_id]
    
    def __init__(self, connection_id: str = "default"):
        if self._initialized:
            return
        self.connection_id = connection_id
        self.connected = False
        self.account_info = {}
        self.symbols_cache = {}
        self._reconnect_attempts = 0
        self._max_reconnect_attempts = 5
        self._login = None
        self._password = None
        self._server = None
        self._path = None
        self._last_prices: Dict[str, float] = {}
        self._initialized = True
        
    def connect(self, login: int = None, password: str = None, server: str = None, 
                path: str = None) -> bool:
        """Подключение к MT5 с сохранением параметров"""
        self._login = login
        self._password = password
        self._server = server
        self._path = path
        
        if not MT5_AVAILABLE:
            logger.error(f"❌ MT5 NOT AVAILABLE for {self.connection_id}")
            return False
            
        try:
            if path:
                mt5.initialize(path)
            else:
                mt5.initialize()
            
            if login and password:
                authorized = mt5.login(login, password, server)
                if not authorized:
                    error = mt5.last_error()
                    logger.error(f"MT5 login failed for {self.connection_id}: {error}")
                    return False
            
            self.connected = True
            self.account_info = self.get_account_info()
            logger.info(f"✅ MT5 connected: {self.connection_id} - {self.account_info.get('login', 'UNKNOWN')}")
            self._reconnect_attempts = 0
            return True
            
        except Exception as e:
            logger.error(f"MT5 connect error for {self.connection_id}: {e}")
            self.connected = False
            return False
    
    def disconnect(self):
        if MT5_AVAILABLE and self.connected:
            mt5.shutdown()
        self.connected = False
        logger.info(f"MT5 disconnected for {self.connection_id}")
    
    def reconnect(self) -> bool:
        if self._reconnect_attempts >= self._max_reconnect_attempts:
            logger.error(f"Max reconnection attempts reached for {self.connection_id}")
            return False
        self._reconnect_attempts += 1
        logger.info(f"Reconnection attempt {self._reconnect_attempts} for {self.connection_id}")
        return self.connect(self._login, self._password, self._server, self._path)
    
    def get_account_info(self) -> dict:
        if not MT5_AVAILABLE or not self.connected:
            return {}
        
        acc = mt5.account_info()
        if acc:
            return {
                "login": acc.login,
                "balance": acc.balance,
                "equity": acc.equity,
                "margin": acc.margin,
                "free_margin": acc.margin_free,
                "profit": acc.profit,
                "leverage": acc.leverage,
                "currency": acc.currency,
                "server": acc.server,
                "connection_id": self.connection_id,
            }
        return {}
    
    def get_positions(self) -> List[dict]:
        if not MT5_AVAILABLE or not self.connected:
            return []
        
        positions = mt5.positions_get()
        if positions is None:
            logger.warning(f"MT5 positions_get returned None: {mt5.last_error()}")
            return []
        
        result = []
        for pos in positions:
            result.append({
                "ticket": pos.ticket,
                "symbol": pos.symbol,
                "order_type": "BUY" if pos.type == 0 else "SELL",
                "volume": pos.volume,
                "open_price": pos.price_open,
                "current_price": pos.price_current,
                "sl": pos.sl,
                "tp": pos.tp,
                "profit": pos.profit,
                "open_time": datetime.fromtimestamp(pos.time).isoformat(),
                "connection_id": self.connection_id,
                "swap": pos.swap,
                "commission": pos.commission,
            })
        return result
    
    def get_position_by_ticket(self, ticket: int) -> Optional[dict]:
        if not MT5_AVAILABLE or not self.connected:
            return None
        
        pos = mt5.positions_get(ticket=ticket)
        if pos and len(pos) > 0:
            p = pos[0]
            return {
                "ticket": p.ticket,
                "symbol": p.symbol,
                "order_type": "BUY" if p.type == 0 else "SELL",
                "volume": p.volume,
                "open_price": p.price_open,
                "sl": p.sl,
                "tp": p.tp,
                "profit": p.profit,
                "connection_id": self.connection_id,
            }
        return None
    
    def open_order(self, symbol: str, order_type: str, volume: float,
                   sl: float = 0.0, tp: float = 0.0, comment: str = "AI") -> dict:
        if not MT5_AVAILABLE or not self.connected:
            return {"success": False, "error": "MT5 not available/connected", "connection_id": self.connection_id}
        
        symbol_info = mt5.symbol_info(symbol)
        if symbol_info is None:
            return {"success": False, "error": f"Symbol {symbol} not found", "connection_id": self.connection_id}
        
        point = symbol_info.point
        tick = mt5.symbol_info_tick(symbol)
        if tick is None:
            return {"success": False, "error": f"Cannot get tick for {symbol}", "connection_id": self.connection_id}
        
        if order_type.upper() == "BUY":
            order_type_mt5 = mt5.ORDER_TYPE_BUY
            price = tick.ask
            sl_price = price - sl if sl > 0 else 0
            tp_price = price + tp if tp > 0 else 0
        elif order_type.upper() == "SELL":
            order_type_mt5 = mt5.ORDER_TYPE_SELL
            price = tick.bid
            sl_price = price + sl if sl > 0 else 0
            tp_price = price - tp if tp > 0 else 0
        else:
            return {"success": False, "error": f"Invalid order type: {order_type}", "connection_id": self.connection_id}
        
        request = {
            "action": mt5.TRADE_ACTION_DEAL,
            "symbol": symbol,
            "volume": volume,
            "type": order_type_mt5,
            "price": price,
            "sl": sl_price,
            "tp": tp_price,
            "deviation": 20,
            "magic": 234000,
            "comment": comment,
            "type_time": mt5.ORDER_TIME_GTC,
            "type_filling": mt5.ORDER_FILLING_FOK,
        }
        
        result = mt5.order_send(request)
        
        if result.retcode != mt5.TRADE_RETCODE_DONE:
            error_msg = f"Order failed: {result.comment} (retcode={result.retcode})"
            logger.error(error_msg)
            return {
                "success": False, 
                "error": error_msg, 
                "retcode": result.retcode,
                "connection_id": self.connection_id,
            }
        
        return {
            "success": True,
            "ticket": result.order,
            "price": result.price,
            "volume": volume,
            "comment": comment,
            "connection_id": self.connection_id,
        }
    
    def close_position(self, ticket: int, volume: float = None) -> dict:
        if not MT5_AVAILABLE or not self.connected:
            return {"success": False, "error": "MT5 not available/connected", "connection_id": self.connection_id}
        
        position = self.get_position_by_ticket(ticket)
        if not position:
            return {"success": False, "error": f"Position {ticket} not found", "connection_id": self.connection_id}
        
        symbol = position["symbol"]
        order_type = mt5.ORDER_TYPE_BUY if position["order_type"] == "SELL" else mt5.ORDER_TYPE_SELL
        volume = volume or position["volume"]
        
        tick = mt5.symbol_info_tick(symbol)
        if not tick:
            return {"success": False, "error": f"Cannot get tick for {symbol}", "connection_id": self.connection_id}
        
        price = tick.bid if order_type == mt5.ORDER_TYPE_SELL else tick.ask
        
        request = {
            "action": mt5.TRADE_ACTION_DEAL,
            "symbol": symbol,
            "volume": volume,
            "type": order_type,
            "position": ticket,
            "price": price,
            "deviation": 20,
            "magic": 234000,
            "comment": "Close by AI",
            "type_time": mt5.ORDER_TIME_GTC,
            "type_filling": mt5.ORDER_FILLING_FOK,
        }
        
        result = mt5.order_send(request)
        
        if result.retcode != mt5.TRADE_RETCODE_DONE:
            error_msg = f"Close failed: {result.comment} (retcode={result.retcode})"
            logger.error(error_msg)
            return {"success": False, "error": error_msg, "connection_id": self.connection_id}
        
        return {
            "success": True,
            "ticket": ticket,
            "profit": position.get("profit", 0),
            "price": price,
            "connection_id": self.connection_id,
        }
    
    def modify_position(self, ticket: int, sl: float = None, tp: float = None) -> dict:
        if not MT5_AVAILABLE or not self.connected:
            return {"success": False, "error": "MT5 not available/connected", "connection_id": self.connection_id}
        
        position = self.get_position_by_ticket(ticket)
        if not position:
            return {"success": False, "error": f"Position {ticket} not found", "connection_id": self.connection_id}
        
        request = {
            "action": mt5.TRADE_ACTION_SLTP,
            "symbol": position["symbol"],
            "position": ticket,
            "sl": sl if sl is not None else position.get("sl", 0),
            "tp": tp if tp is not None else position.get("tp", 0),
        }
        
        result = mt5.order_send(request)
        
        if result.retcode != mt5.TRADE_RETCODE_DONE:
            error_msg = f"Modify failed: {result.comment} (retcode={result.retcode})"
            logger.error(error_msg)
            return {"success": False, "error": error_msg, "connection_id": self.connection_id}
        
        return {"success": True, "connection_id": self.connection_id}
    
    def get_rates(self, symbol: str, timeframe: int, count: int) -> List[dict]:
        if not MT5_AVAILABLE or not self.connected:
            logger.error(f"Cannot get rates for {symbol}: MT5 not available/connected")
            return []
        
        rates = mt5.copy_rates_from_pos(symbol, timeframe, 0, count)
        if rates is None:
            error = mt5.last_error()
            logger.error(f"Failed to get rates for {symbol}: {error}")
            return []
        
        return [
            {
                "time": r[0],
                "open": r[1],
                "high": r[2],
                "low": r[3],
                "close": r[4],
                "tick_volume": r[5],
                "spread": r[6],
                "real_volume": r[7],
            }
            for r in rates
        ]
    
    def _get_real_price(self, symbol: str) -> float:
        """Получение реальной цены из MT5 или кэша"""
        if MT5_AVAILABLE and self.connected:
            tick = mt5.symbol_info_tick(symbol)
            if tick:
                self._last_prices[symbol] = tick.bid or tick.ask
                return self._last_prices[symbol]
        
        # Возвращаем последнюю известную цену или стандартную
        if symbol in self._last_prices:
            return self._last_prices[symbol]
        
        # Дефолтные цены для разных символов (только если нет данных)
        default_prices = {
            "EURUSD": 1.0850, "GBPUSD": 1.2650, "USDJPY": 148.50,
            "XAUUSD": 2350.00, "BTCUSD": 65000.00, "ETHUSD": 3500.00,
        }
        return default_prices.get(symbol.upper(), 100.0)


# Глобальные экземпляры
mt5_instances: Dict[str, MT5Integration] = {}

def get_mt5(connection_id: str = "default") -> MT5Integration:
    if connection_id not in mt5_instances:
        mt5_instances[connection_id] = MT5Integration(connection_id)
    return mt5_instances[connection_id]


# ============================================================================
# NEURAL COMPONENTS (БЕЗ ИЗМЕНЕНИЙ - ВСЕ ФУНКЦИИ СОХРАНЕНЫ)
# ============================================================================
class SimpleNeuralNet:
    """Lightweight feed-forward neural network with online learning"""
    
    def __init__(self, input_size: int, hidden_sizes: List[int], output_size: int, lr: float = 0.001):
        self.lr = lr
        self.layers = []
        sizes = [input_size] + hidden_sizes + [output_size]
        for i in range(len(sizes) - 1):
            w = np.random.randn(sizes[i], sizes[i + 1]) * np.sqrt(2.0 / sizes[i])
            b = np.zeros((1, sizes[i + 1]))
            self.layers.append({"w": w, "b": b})
        self._activations = []

    def _relu(self, x):
        return np.maximum(0, x)

    def _relu_grad(self, x):
        return (x > 0).astype(float)

    def _sigmoid(self, x):
        return 1.0 / (1.0 + np.exp(-np.clip(x, -500, 500)))

    def _tanh(self, x):
        return np.tanh(x)

    def forward(self, x: np.ndarray) -> np.ndarray:
        self._activations = [x]
        current = x
        for i, layer in enumerate(self.layers):
            z = current @ layer["w"] + layer["b"]
            if i < len(self.layers) - 1:
                current = self._relu(z)
            else:
                current = self._tanh(z)
            self._activations.append(current)
        return current

    def predict(self, x: np.ndarray) -> np.ndarray:
        return self.forward(x)

    def train_step(self, x: np.ndarray, target: np.ndarray) -> float:
        out = self.forward(x)
        loss = np.mean((out - target) ** 2)
        delta = 2 * (out - target) / out.size
        delta = delta * (1 - out ** 2)
        for i in reversed(range(len(self.layers))):
            act = self._activations[i]
            dw = act.T @ delta
            db = np.sum(delta, axis=0, keepdims=True)
            self.layers[i]["w"] -= self.lr * dw
            self.layers[i]["b"] -= self.lr * db
            if i > 0:
                delta = delta @ self.layers[i]["w"].T
                delta = delta * self._relu_grad(self._activations[i])
        return float(loss)

    def get_weights(self) -> List[dict]:
        return [{"w": l["w"].tolist(), "b": l["b"].tolist()} for l in self.layers]

    def set_weights(self, weights: List[dict]):
        for i, w_dict in enumerate(weights):
            self.layers[i]["w"] = np.array(w_dict["w"])
            self.layers[i]["b"] = np.array(w_dict["b"])


class QLearningAgent:
    """Q-learning agent for trading decisions"""
    
    def __init__(self, state_size: int, action_size: int = 3):
        self.state_size = state_size
        self.action_size = action_size
        self.gamma = 0.95
        self.epsilon = 0.3
        self.epsilon_min = 0.01
        self.epsilon_decay = 0.995
        self.lr = 0.001
        self.replay_buffer = deque(maxlen=10000)
        self.model = SimpleNeuralNet(state_size, [128, 64, 32], action_size, lr=self.lr)
        self.target_model = SimpleNeuralNet(state_size, [128, 64, 32], action_size, lr=self.lr)
        self.update_target_counter = 0
        self.update_target_freq = 100
        self.batch_size = 32
        self.total_steps = 0

    def get_action(self, state: np.ndarray, explore: bool = True) -> int:
        if explore and random.random() < self.epsilon:
            return random.randint(0, self.action_size - 1)
        q_values = self.model.predict(state.reshape(1, -1))
        return int(np.argmax(q_values[0]))

    def store_experience(self, state, action, reward, next_state, done):
        self.replay_buffer.append((
            state.copy(),
            action,
            reward,
            next_state.copy(),
            done,
        ))

    def train(self) -> float:
        if len(self.replay_buffer) < self.batch_size:
            return 0.0
        batch = random.sample(self.replay_buffer, self.batch_size)
        total_loss = 0.0
        for state, action, reward, next_state, done in batch:
            s = state.reshape(1, -1)
            ns = next_state.reshape(1, -1)
            current_q = self.model.predict(s)[0].copy()
            if done:
                target_q = reward
            else:
                next_q = self.target_model.predict(ns)[0]
                target_q = reward + self.gamma * np.max(next_q)
            current_q[action] = target_q
            loss = self.model.train_step(s, current_q.reshape(1, -1))
            total_loss += loss
        self.update_target_counter += 1
        if self.update_target_counter >= self.update_target_freq:
            self.target_model.set_weights(self.model.get_weights())
            self.update_target_counter = 0
        if self.epsilon > self.epsilon_min:
            self.epsilon *= self.epsilon_decay
        self.total_steps += 1
        return total_loss / self.batch_size

    def get_state_quality(self, state: np.ndarray) -> float:
        q_values = self.model.predict(state.reshape(1, -1))[0]
        return float(np.max(q_values))


# ============================================================================
# MARKET INTELLIGENCE (PRIME - С РЕАЛЬНЫМИ УРОВНЯМИ)
# ============================================================================
class MarketIntelligence:
    """Analyzes market data and generates intelligence - PRIME VERSION"""
    
    def __init__(self):
        self.symbol_data: Dict[str, dict] = {}
        self.regime_history: deque = deque(maxlen=100)
        self.volatility_window = 20
        self.trend_window = 50

    def update(self, symbol: str, tick: dict, candles: dict):
        if symbol not in self.symbol_data:
            self.symbol_data[symbol] = {
                "ticks": deque(maxlen=1000),
                "volatility": 0.0,
                "trend_strength": 0.0,
                "regime": "UNKNOWN",
                "support_levels": [],
                "resistance_levels": [],
                "momentum": 0.0,
                "volume_profile": 0.0,
                "last_analysis": None,
                "swing_highs": deque(maxlen=50),
                "swing_lows": deque(maxlen=50),
            }
        sd = self.symbol_data[symbol]
        sd["ticks"].append(tick)
        
        if candles.get("m15") is not None and len(candles["m15"]) > self.volatility_window:
            sd["volatility"] = self._calc_volatility(candles["m15"])
            sd["trend_strength"] = self._calc_trend_strength(candles["m15"])
            sd["momentum"] = self._calc_momentum(candles["m15"])
            sd["regime"] = self._detect_regime(candles)
            # PRIME FIX #7: РЕАЛЬНЫЕ УРОВНИ SUPPORT/RESISTANCE
            sd["support_levels"] = self._find_real_support_levels(candles["m15"])
            sd["resistance_levels"] = self._find_real_resistance_levels(candles["m15"])
            sd["volume_profile"] = self._calc_volume_profile(candles["m15"])
            sd["last_analysis"] = datetime.utcnow().isoformat()
            
            # Определяем swing highs/lows для трейлинг стопа
            self._update_swing_points(candles["m15"], sd)

    def get_regime(self, symbol: str) -> str:
        """Возвращает текущий режим рынка для символа"""
        data = self.symbol_data.get(symbol, {})
        return data.get("regime", "RANGING")
    
    def get_support_levels(self, symbol: str) -> List[float]:
        """Получение реальных уровней поддержки"""
        data = self.symbol_data.get(symbol, {})
        return data.get("support_levels", [])
    
    def get_resistance_levels(self, symbol: str) -> List[float]:
        """Получение реальных уровней сопротивления"""
        data = self.symbol_data.get(symbol, {})
        return data.get("resistance_levels", [])
    
    def _update_swing_points(self, candles, sd):
        """Обновление swing highs/lows для более точных уровней"""
        if len(candles) < 10:
            return
        
        highs = np.array([c[2] for c in candles[-10:]])
        lows = np.array([c[3] for c in candles[-10:]])
        
        for i in range(2, len(highs) - 2):
            if highs[i] > highs[i-1] and highs[i] > highs[i+1] and highs[i] > highs[i-2] and highs[i] > highs[i+2]:
                sd["swing_highs"].append(highs[i])
            if lows[i] < lows[i-1] and lows[i] < lows[i+1] and lows[i] < lows[i-2] and lows[i] < lows[i+2]:
                sd["swing_lows"].append(lows[i])

    def _calc_volatility(self, candles) -> float:
        try:
            closes = np.array([c[4] for c in candles[-self.volatility_window:]])
            returns = np.diff(np.log(closes + 1e-10))
            return float(np.std(returns) * np.sqrt(252 * 24 * 4) * 100)
        except Exception:
            return 0.0

    def _calc_trend_strength(self, candles) -> float:
        try:
            closes = np.array([c[4] for c in candles[-self.trend_window:]])
            x = np.arange(len(closes))
            if len(closes) < 2:
                return 0.0
            slope, _ = np.polyfit(x, closes, 1)
            price_range = np.max(closes) - np.min(closes)
            if price_range == 0:
                return 0.0
            normalized = (slope * len(closes)) / price_range
            return float(np.clip(normalized, -1.0, 1.0))
        except Exception:
            return 0.0

    def _calc_momentum(self, candles, period: int = 14) -> float:
        try:
            closes = np.array([c[4] for c in candles[-period - 1:]])
            if len(closes) < period + 1:
                return 0.0
            return float((closes[-1] - closes[0]) / closes[0] * 100)
        except Exception:
            return 0.0

    def _detect_regime(self, candles: dict) -> str:
        try:
            m15 = candles.get("m15")
            if m15 is None or len(m15) < 50:
                return "RANGING"

            closes_m15 = np.array([c[4] for c in m15[-50:]])
            vol = self._calc_volatility(m15)
            trend = self._calc_trend_strength(m15)
            momentum = self._calc_momentum(m15)

            if vol > 30:
                return "VOLATILE"
            if trend > 0.5 and momentum > 0.1:
                return "TRENDING_UP"
            if trend < -0.5 and momentum < -0.1:
                return "TRENDING_DOWN"

            sma20 = np.mean(closes_m15[-20:])
            price = closes_m15[-1]
            dist_from_sma = abs(price - sma20) / sma20 * 100

            if dist_from_sma < 0.05:
                recent_high = np.max(closes_m15[-10:])
                recent_low = np.min(closes_m15[-10:])
                if (recent_high - recent_low) / recent_low * 100 > 0.3:
                    return "BREAKOUT"

            if abs(trend) < 0.2:
                return "RANGING"
            return "TRENDING_UP" if trend > 0 else "TRENDING_DOWN"
        except Exception:
            return "RANGING"

    def _find_real_support_levels(self, candles) -> List[float]:
        """PRIME FIX #7: РЕАЛЬНЫЙ поиск уровней поддержки через swing lows + кластеризацию"""
        try:
            if len(candles) < 50:
                return []
            
            # Берем все swing lows
            all_lows = []
            lows = np.array([c[3] for c in candles[-100:]])
            
            for i in range(5, len(lows) - 5):
                is_swing_low = True
                for j in range(-5, 6):
                    if j == 0:
                        continue
                    if lows[i] >= lows[i + j]:
                        is_swing_low = False
                        break
                if is_swing_low:
                    all_lows.append(float(lows[i]))
            
            if len(all_lows) < 3:
                return []
            
            # Кластеризация уровней (группировка близких значений)
            all_lows.sort()
            clusters = []
            current_cluster = [all_lows[0]]
            threshold = np.std(all_lows) * 0.3 if len(all_lows) > 1 else 0.001
            
            for low in all_lows[1:]:
                if low - current_cluster[-1] < threshold:
                    current_cluster.append(low)
                else:
                    clusters.append(np.mean(current_cluster))
                    current_cluster = [low]
            clusters.append(np.mean(current_cluster))
            
            # Возвращаем последние 5 значимых уровней
            return sorted(clusters)[-5:] if clusters else []
        except Exception as e:
            logger.error(f"Find support levels error: {e}")
            return []

    def _find_real_resistance_levels(self, candles) -> List[float]:
        """PRIME FIX #7: РЕАЛЬНЫЙ поиск уровней сопротивления через swing highs + кластеризацию"""
        try:
            if len(candles) < 50:
                return []
            
            all_highs = []
            highs = np.array([c[2] for c in candles[-100:]])
            
            for i in range(5, len(highs) - 5):
                is_swing_high = True
                for j in range(-5, 6):
                    if j == 0:
                        continue
                    if highs[i] <= highs[i + j]:
                        is_swing_high = False
                        break
                if is_swing_high:
                    all_highs.append(float(highs[i]))
            
            if len(all_highs) < 3:
                return []
            
            all_highs.sort()
            clusters = []
            current_cluster = [all_highs[0]]
            threshold = np.std(all_highs) * 0.3 if len(all_highs) > 1 else 0.001
            
            for high in all_highs[1:]:
                if high - current_cluster[-1] < threshold:
                    current_cluster.append(high)
                else:
                    clusters.append(np.mean(current_cluster))
                    current_cluster = [high]
            clusters.append(np.mean(current_cluster))
            
            return sorted(clusters)[:5] if clusters else []
        except Exception as e:
            logger.error(f"Find resistance levels error: {e}")
            return []

    def _calc_volume_profile(self, candles) -> float:
        try:
            volumes = np.array([c[5] for c in candles[-20:]])
            if len(volumes) < 2:
                return 0.0
            avg_vol = np.mean(volumes[:-1])
            if avg_vol == 0:
                return 0.0
            return float(volumes[-1] / avg_vol)
        except Exception:
            return 0.0

    def get_technical_indicators(self, symbol: str, candles: dict) -> dict:
        indicators = {}
        try:
            for tf_name, tf_candles in candles.items():
                if tf_candles is None or len(tf_candles) < 20:
                    continue
                closes = np.array([c[4] for c in tf_candles])
                highs = np.array([c[2] for c in tf_candles])
                lows = np.array([c[3] for c in tf_candles])
                volumes = np.array([c[5] for c in tf_candles])
                indicators[tf_name] = {
                    "sma_20": float(np.mean(closes[-20:])),
                    "sma_50": float(np.mean(closes[-50:])) if len(closes) >= 50 else float(np.mean(closes)),
                    "sma_200": float(np.mean(closes[-200:])) if len(closes) >= 200 else float(np.mean(closes)),
                    "ema_12": float(self._ema(closes, 12)),
                    "ema_26": float(self._ema(closes, 26)),
                    "rsi": float(self._rsi(closes)),
                    "macd": float(self._ema(closes, 12) - self._ema(closes, 26)),
                    "bollinger_upper": float(np.mean(closes[-20:]) + 2 * np.std(closes[-20:])),
                    "bollinger_lower": float(np.mean(closes[-20:]) - 2 * np.std(closes[-20:])),
                    "atr": float(self._atr(highs, lows, closes)),
                    "volume_avg": float(np.mean(volumes[-20:])),
                    "current_close": float(closes[-1]),
                    "current_high": float(highs[-1]),
                    "current_low": float(lows[-1]),
                }
        except Exception as e:
            logger.error(f"Technical indicators error: {e}")
        return indicators

    def _ema(self, data: np.ndarray, period: int) -> float:
        if len(data) < period:
            return float(np.mean(data))
        k = 2.0 / (period + 1)
        ema = float(data[0])
        for v in data[1:]:
            ema = float(v) * k + ema * (1 - k)
        return ema

    def _rsi(self, closes: np.ndarray, period: int = 14) -> float:
        if len(closes) < period + 1:
            return 50.0
        deltas = np.diff(closes[-period - 1:])
        gains = np.where(deltas > 0, deltas, 0)
        losses = np.where(deltas < 0, -deltas, 0)
        avg_gain = np.mean(gains[-period:])
        avg_loss = np.mean(losses[-period:])
        if avg_loss == 0:
            return 100.0
        rs = avg_gain / avg_loss
        return float(100 - (100 / (1 + rs)))

    def _atr(self, highs: np.ndarray, lows: np.ndarray, closes: np.ndarray, period: int = 14) -> float:
        if len(closes) < 2:
            return 0.0
        trs = []
        for i in range(1, min(period + 1, len(closes))):
            tr = max(
                highs[-i] - lows[-i],
                abs(highs[-i] - closes[-i - 1]),
                abs(lows[-i] - closes[-i - 1]),
            )
            trs.append(tr)
        return float(np.mean(trs)) if trs else 0.0

    def build_state_vector(self, symbol: str, candles: dict, account: dict) -> np.ndarray:
        features = []
        try:
            indicators = self.get_technical_indicators(symbol, candles)
            sd = self.symbol_data.get(symbol, {})
            for tf in ["m1", "m15", "h1", "h4"]:
                ind = indicators.get(tf, {})
                close = ind.get("current_close", 0)
                sma20 = ind.get("sma_20", close)
                sma50 = ind.get("sma_50", close)
                rsi = ind.get("rsi", 50)
                macd = ind.get("macd", 0)
                atr = ind.get("atr", 0)
                bb_upper = ind.get("bollinger_upper", close)
                bb_lower = ind.get("bollinger_lower", close)
                bb_width = (bb_upper - bb_lower) / (close + 1e-10)
                bb_pos = (close - bb_lower) / (bb_upper - bb_lower + 1e-10)
                features.extend([
                    (close - sma20) / (sma20 + 1e-10),
                    (sma20 - sma50) / (sma50 + 1e-10),
                    (rsi - 50) / 50,
                    macd / (close + 1e-10) * 1000,
                    atr / (close + 1e-10) * 1000,
                    bb_width,
                    bb_pos - 0.5,
                ])
            features.append(sd.get("volatility", 0) / 100)
            features.append(sd.get("trend_strength", 0))
            features.append(sd.get("momentum", 0) / 10)
            features.append(sd.get("volume_profile", 1) - 1)

            regime_encoding = [0.0] * len(REGIMES)
            regime = sd.get("regime", "RANGING")
            if regime in REGIMES:
                regime_encoding[REGIMES.index(regime)] = 1.0
            features.extend(regime_encoding)

            balance = account.get("balance", 10000)
            equity = account.get("equity", 10000)
            free_margin = account.get("free_margin", 10000)
            features.append((equity - balance) / (balance + 1e-10))
            features.append(free_margin / (balance + 1e-10))

            state = np.array(features, dtype=np.float32)
            state = np.nan_to_num(state, nan=0.0, posinf=1.0, neginf=-1.0)
            state = np.clip(state, -5.0, 5.0)
            return state
        except Exception as e:
            logger.error(f"Build state vector error: {e}")
            return np.zeros(50, dtype=np.float32)

    def get_market_summary(self, symbol: str) -> dict:
        sd = self.symbol_data.get(symbol, {})
        return {
            "symbol": symbol,
            "regime": sd.get("regime", "UNKNOWN"),
            "volatility": sd.get("volatility", 0.0),
            "trend_strength": sd.get("trend_strength", 0.0),
            "momentum": sd.get("momentum", 0.0),
            "support_levels": sd.get("support_levels", []),
            "resistance_levels": sd.get("resistance_levels", []),
            "volume_profile": sd.get("volume_profile", 0.0),
            "last_analysis": sd.get("last_analysis"),
        }


# ============================================================================
# RISK ENGINE (PRIME - БЕЗ ЗАГЛУШЕК)
# ============================================================================
class RiskEngine:
    def __init__(self):
        self.risk_per_trade: float = 0.01
        self.max_positions: int = 5
        self.max_daily_loss: float = 0.05
        self.max_drawdown: float = 0.15
        self.trailing_stop_multiplier: float = 2.0
        self.atr_sl_multiplier: float = 1.5
        self.atr_tp_multiplier: float = 3.0
        self.daily_loss_tracker: float = 0.0
        self.daily_loss_reset: datetime = datetime.utcnow()
        self.peak_equity: float = 0.0
        self.current_drawdown: float = 0.0
        self.trade_history_risk: deque = deque(maxlen=50)
        self.consecutive_losses: int = 0
        self.consecutive_wins: int = 0
        self.win_rate: float = 0.5
        self.avg_win: float = 0.0
        self.avg_loss: float = 0.0
        self.risk_multiplier: float = 1.0

    def reset_daily_if_needed(self):
        now = datetime.utcnow()
        if now.date() > self.daily_loss_reset.date():
            self.daily_loss_tracker = 0.0
            self.daily_loss_reset = now

    def update_equity(self, equity: float, balance: float):
        self.reset_daily_if_needed()
        if equity > self.peak_equity:
            self.peak_equity = equity
        if self.peak_equity > 0:
            self.current_drawdown = (self.peak_equity - equity) / self.peak_equity

    def record_trade_result(self, profit: float, balance: float):
        self.reset_daily_if_needed()
        self.daily_loss_tracker += profit
        self.trade_history_risk.append({
            "profit": profit,
            "timestamp": datetime.utcnow().isoformat(),
        })
        if profit < 0:
            self.consecutive_losses += 1
            self.consecutive_wins = 0
        else:
            self.consecutive_wins += 1
            self.consecutive_losses = 0

        profits = [t["profit"] for t in self.trade_history_risk]
        wins = [p for p in profits if p > 0]
        losses = [p for p in profits if p < 0]
        total = len(profits)
        self.win_rate = len(wins) / total if total > 0 else 0.5
        self.avg_win = float(np.mean(wins)) if wins else 0.0
        self.avg_loss = float(np.mean(losses)) if losses else 0.0
        self._update_risk_multiplier()

    def _update_risk_multiplier(self):
        base = 1.0
        if self.current_drawdown > 0.10:
            base *= 0.5
        elif self.current_drawdown > 0.07:
            base *= 0.7
        elif self.current_drawdown > 0.05:
            base *= 0.85
        if self.consecutive_losses >= 3:
            base *= max(0.3, 1.0 - (self.consecutive_losses - 2) * 0.15)
        if self.consecutive_wins >= 5 and self.win_rate > 0.6:
            base *= min(1.5, 1.0 + (self.consecutive_wins - 4) * 0.05)
        self.risk_multiplier = float(np.clip(base, 0.2, 2.0))

    def can_open_trade(self, account: dict, positions: list, symbol: str) -> Tuple[bool, str]:
        self.reset_daily_if_needed()
        balance = account.get("balance", 0)
        equity = account.get("equity", 0)
        free_margin = account.get("free_margin", 0)

        if balance <= 0:
            return False, "Zero balance"

        self.update_equity(equity, balance)

        if self.current_drawdown >= self.max_drawdown:
            return False, f"Max drawdown reached: {self.current_drawdown:.2%}"

        daily_loss_pct = abs(self.daily_loss_tracker) / balance if self.daily_loss_tracker < 0 else 0
        if daily_loss_pct >= self.max_daily_loss:
            return False, f"Daily loss limit reached: {daily_loss_pct:.2%}"

        if len(positions) >= self.max_positions:
            return False, f"Max positions ({self.max_positions}) reached"

        open_symbols = [p["symbol"] for p in positions]
        symbol_count = open_symbols.count(symbol)
        if symbol_count >= 2:
            return False, f"Already have {symbol_count} positions on {symbol}"

        if free_margin < balance * 0.1:
            return False, "Insufficient free margin"

        return True, "OK"

    def calculate_position_size(self, symbol: str, account: dict,
                                 entry_price: float, sl_price: float,
                                 atr: float = 0.0) -> float:
        try:
            balance = account.get("balance", 10000)
            risk_amount = balance * self.risk_per_trade * self.risk_multiplier
            if sl_price <= 0 or entry_price <= 0:
                risk_per_pip = atr if atr > 0 else entry_price * 0.001
            else:
                risk_per_pip = abs(entry_price - sl_price)
            if risk_per_pip == 0:
                risk_per_pip = entry_price * 0.001

            pip_value = self._get_pip_value(symbol, entry_price)
            if pip_value <= 0:
                pip_value = 10.0

            volume = risk_amount / (risk_per_pip * pip_value / self._get_pip_size(symbol))
            volume = round(float(np.clip(volume, 0.01, 10.0)), 2)
            return volume
        except Exception as e:
            logger.error(f"Position size calc error: {e}")
            return 0.01

    def _get_pip_size(self, symbol: str) -> float:
        sym = symbol.upper()
        if "JPY" in sym:
            return 0.01
        if any(x in sym for x in ["XAU", "GOLD"]):
            return 0.1
        if any(x in sym for x in ["BTC", "ETH"]):
            return 1.0
        return 0.0001

    def _get_pip_value(self, symbol: str, price: float) -> float:
        sym = symbol.upper()
        if "JPY" in sym:
            return 9.09
        if any(x in sym for x in ["XAU", "GOLD"]):
            return 1.0
        if any(x in sym for x in ["BTC"]):
            return 0.1
        return 10.0

    def calculate_dynamic_sl_tp(self, symbol: str, order_type: str,
                                  entry_price: float, atr: float,
                                  regime: str, confidence: float,
                                  support_levels: List[float],
                                  resistance_levels: List[float]) -> Tuple[float, float]:
        """PRIME FIX #6: ДИНАМИЧЕСКИЙ SL/TP БЕЗ ЗАГЛУШЕК"""
        try:
            # Базовый расчёт через ATR
            if atr <= 0:
                atr = entry_price * 0.001

            # Адаптивные множители под режим рынка
            regime_multipliers = {
                "TRENDING_UP": {"sl": 1.2, "tp": 3.5},
                "TRENDING_DOWN": {"sl": 1.2, "tp": 3.5},
                "RANGING": {"sl": 1.0, "tp": 2.0},
                "VOLATILE": {"sl": 2.0, "tp": 3.0},
                "BREAKOUT": {"sl": 1.5, "tp": 4.0},
                "REVERSAL": {"sl": 1.0, "tp": 2.5},
            }
            mult = regime_multipliers.get(regime, {"sl": 1.5, "tp": 3.0})
            sl_mult = mult["sl"] * (1.0 + max(0, 0.5 - confidence))
            tp_mult = mult["tp"] * (0.5 + confidence)

            sl_distance = atr * sl_mult
            tp_distance = atr * tp_mult

            # Корректировка через реальные уровни поддержки/сопротивления
            if order_type == "BUY":
                sl = entry_price - sl_distance
                tp = entry_price + tp_distance
                
                # Подтягиваем SL к ближайшему свингу
                if support_levels:
                    nearest_support = max([s for s in support_levels if s < entry_price], default=None)
                    if nearest_support and nearest_support > sl:
                        sl = nearest_support - atr * 0.2
                
                # Ограничиваем TP уровнем сопротивления
                if resistance_levels:
                    nearest_resistance = min([r for r in resistance_levels if r > entry_price], default=None)
                    if nearest_resistance and nearest_resistance < tp:
                        tp = nearest_resistance - atr * 0.1
            else:
                sl = entry_price + sl_distance
                tp = entry_price - tp_distance
                
                if resistance_levels:
                    nearest_resistance = min([r for r in resistance_levels if r > entry_price], default=None)
                    if nearest_resistance and nearest_resistance < sl:
                        sl = nearest_resistance + atr * 0.2
                
                if support_levels:
                    nearest_support = max([s for s in support_levels if s < entry_price], default=None)
                    if nearest_support and nearest_support > tp:
                        tp = nearest_support + atr * 0.1

            # Минимальные дистанции
            min_sl_dist = entry_price * 0.0005  # 0.05%
            min_tp_dist = entry_price * 0.001   # 0.1%
            
            if abs(sl - entry_price) < min_sl_dist:
                sl = entry_price - min_sl_dist if order_type == "BUY" else entry_price + min_sl_dist
            if abs(tp - entry_price) < min_tp_dist:
                tp = entry_price + min_tp_dist if order_type == "BUY" else entry_price - min_tp_dist

            # Риск-лимит: максимальный SL 2% от цены
            max_sl_pct = 0.02
            if abs(sl - entry_price) / entry_price > max_sl_pct:
                if order_type == "BUY":
                    sl = entry_price - entry_price * max_sl_pct
                else:
                    sl = entry_price + entry_price * max_sl_pct

            return round(float(sl), 5), round(float(tp), 5)
            
        except Exception as e:
            logger.error(f"SL/TP calculation error: {e}")
            # Аварийный SL/TP через ATR
            emergency_sl = atr * 1.5
            emergency_tp = atr * 2.5
            if order_type == "BUY":
                return round(entry_price - emergency_sl, 5), round(entry_price + emergency_tp, 5)
            return round(entry_price + emergency_sl, 5), round(entry_price - emergency_tp, 5)

    def should_trail_stop(self, position: dict, current_price: float, atr: float) -> Optional[float]:
        try:
            order_type = position.get("order_type", "BUY")
            open_price = position.get("open_price", current_price)
            current_sl = position.get("sl", 0.0)
            if atr <= 0:
                atr = current_price * 0.001

            trail_distance = atr * self.trailing_stop_multiplier

            if order_type == "BUY":
                profit_pips = current_price - open_price
                if profit_pips < atr * 0.5:
                    return None
                new_sl = current_price - trail_distance
                if new_sl > current_sl + atr * 0.1:
                    return round(new_sl, 5)
            else:
                profit_pips = open_price - current_price
                if profit_pips < atr * 0.5:
                    return None
                new_sl = current_price + trail_distance
                if new_sl < current_sl - atr * 0.1 or current_sl == 0:
                    return round(new_sl, 5)
            return None
        except Exception as e:
            logger.error(f"Trail stop error: {e}")
            return None

    def get_risk_report(self) -> dict:
        return {
            "risk_per_trade": self.risk_per_trade,
            "risk_multiplier": self.risk_multiplier,
            "max_positions": self.max_positions,
            "current_drawdown": round(self.current_drawdown, 4),
            "daily_loss": round(self.daily_loss_tracker, 2),
            "consecutive_losses": self.consecutive_losses,
            "consecutive_wins": self.consecutive_wins,
            "win_rate": round(self.win_rate, 3),
            "avg_win": round(self.avg_win, 2),
            "avg_loss": round(self.avg_loss, 2),
            "expectancy": round(
                self.win_rate * self.avg_win + (1 - self.win_rate) * self.avg_loss, 2
            ),
        }


# ============================================================================
# STRATEGY ENGINE (ПОЛНЫЙ - БЕЗ ИЗМЕНЕНИЙ)
# ============================================================================
class StrategyEngine:
    def __init__(self):
        self.strategy_performance: Dict[str, dict] = {
            s: {"wins": 0, "losses": 0, "profit": 0.0, "count": 0}
            for s in STRATEGIES
        }
        self.current_strategy: str = "TREND_FOLLOW"
        self.strategy_weights: Dict[str, float] = {s: 1.0 for s in STRATEGIES}
        self.mode_history: deque = deque(maxlen=20)

    def select_strategy(self, regime: str, volatility: float,
                        trend_strength: float, momentum: float,
                        rsi: float, win_rate: float) -> str:
        scores: Dict[str, float] = {}

        for strategy in STRATEGIES:
            base = self.strategy_weights.get(strategy, 1.0)
            perf = self.strategy_performance[strategy]
            if perf["count"] > 5:
                wr = perf["wins"] / perf["count"]
                perf_bonus = (wr - 0.5) * 2.0
            else:
                perf_bonus = 0.0

            if strategy == "TREND_FOLLOW":
                regime_score = 1.5 if regime in ["TRENDING_UP", "TRENDING_DOWN"] else 0.3
                scores[strategy] = base + regime_score + abs(trend_strength) + perf_bonus
            elif strategy == "MEAN_REVERT":
                regime_score = 1.5 if regime == "RANGING" else 0.2
                overbought = 1.0 if rsi > 70 or rsi < 30 else 0.3
                scores[strategy] = base + regime_score + overbought + perf_bonus
            elif strategy == "BREAKOUT":
                regime_score = 1.5 if regime == "BREAKOUT" else 0.3
                scores[strategy] = base + regime_score + volatility / 20 + perf_bonus
            elif strategy == "SCALP":
                regime_score = 1.2 if regime == "RANGING" else 0.5
                scores[strategy] = base + regime_score + (1.0 - volatility / 30) + perf_bonus
            elif strategy == "MOMENTUM":
                regime_score = 1.3 if regime in ["TRENDING_UP", "TRENDING_DOWN", "BREAKOUT"] else 0.2
                scores[strategy] = base + regime_score + abs(momentum) / 5 + perf_bonus
            elif strategy == "SWING":
                regime_score = 1.0 if regime in ["TRENDING_UP", "TRENDING_DOWN", "REVERSAL"] else 0.5
                scores[strategy] = base + regime_score + abs(trend_strength) * 0.5 + perf_bonus
            elif strategy == "DEFENSIVE":
                scores[strategy] = base + (1.0 if volatility > 25 else 0.1) + perf_bonus

        best = max(scores, key=lambda k: scores[k])
        self.current_strategy = best
        return best

    def select_trading_mode(self, regime: str, volatility: float) -> str:
        if volatility > 30:
            mode = "SHORT_TERM"
        elif volatility > 20:
            if regime in ["TRENDING_UP", "TRENDING_DOWN"]:
                mode = "SWING"
            else:
                mode = "SHORT_TERM"
        elif volatility > 10:
            mode = "SWING"
        else:
            mode = "LONG_TERM"

        if self.current_strategy == "SCALP":
            mode = "HFT"
        elif self.current_strategy == "SWING":
            mode = "SWING"

        self.mode_history.append(mode)
        return mode

    def get_cycle_delay_for_mode(self, mode: str) -> float:
        delays = {
            "HFT": 2.0,
            "SHORT_TERM": 15.0,
            "SWING": 60.0,
            "LONG_TERM": 300.0,
        }
        return delays.get(mode, 15.0)

    def record_result(self, strategy: str, profit: float):
        if strategy not in self.strategy_performance:
            self.strategy_performance[strategy] = {"wins": 0, "losses": 0, "profit": 0.0, "count": 0}
        perf = self.strategy_performance[strategy]
        perf["count"] += 1
        perf["profit"] += profit
        if profit > 0:
            perf["wins"] += 1
        else:
            perf["losses"] += 1
        if perf["count"] >= 5:
            wr = perf["wins"] / perf["count"]
            profit_factor = min(2.0, max(0.3, 1.0 + perf["profit"] / (abs(perf["profit"]) + 1)))
            self.strategy_weights[strategy] = wr * profit_factor

    def generate_signal(self, strategy: str, indicators: dict,
                         regime: str, order_type_hint: str = None) -> dict:
        signal = {"action": "HOLD", "confidence": 0.0, "reasons": []}

        try:
            m15 = indicators.get("m15", {})
            h1 = indicators.get("h1", {})
            if not m15 and not h1:
                return signal

            close = m15.get("current_close", 0) or h1.get("current_close", 0)
            if close <= 0:
                return signal

            rsi_m15 = m15.get("rsi", 50)
            rsi_h1 = h1.get("rsi", 50)
            macd_m15 = m15.get("macd", 0)
            macd_h1 = h1.get("macd", 0)
            sma20 = m15.get("sma_20", close)
            sma50 = m15.get("sma_50", close)
            sma200 = h1.get("sma_200", close)
            ema12 = m15.get("ema_12", close)
            ema26 = m15.get("ema_26", close)
            bb_upper = m15.get("bollinger_upper", close)
            bb_lower = m15.get("bollinger_lower", close)

            bull_score = 0.0
            bear_score = 0.0
            reasons = []

            if strategy == "TREND_FOLLOW":
                if close > sma20 > sma50:
                    bull_score += 1.5
                    reasons.append("Price above SMA20>SMA50")
                if close < sma20 < sma50:
                    bear_score += 1.5
                    reasons.append("Price below SMA20<SMA50")
                if close > sma200:
                    bull_score += 1.0
                    reasons.append("Price above SMA200")
                else:
                    bear_score += 1.0
                    reasons.append("Price below SMA200")
                if macd_m15 > 0 and macd_h1 > 0:
                    bull_score += 1.0
                    reasons.append("MACD bullish M15+H1")
                elif macd_m15 < 0 and macd_h1 < 0:
                    bear_score += 1.0
                    reasons.append("MACD bearish M15+H1")
                if 40 < rsi_m15 < 65:
                    bull_score += 0.5
                elif 35 < rsi_m15 < 60:
                    bear_score += 0.3

            elif strategy == "MEAN_REVERT":
                if rsi_m15 < 30 and rsi_h1 < 40:
                    bull_score += 2.0
                    reasons.append("RSI oversold M15+H1")
                if rsi_m15 > 70 and rsi_h1 > 60:
                    bear_score += 2.0
                    reasons.append("RSI overbought M15+H1")
                if close <= bb_lower:
                    bull_score += 1.5
                    reasons.append("Price at Bollinger lower")
                if close >= bb_upper:
                    bear_score += 1.5
                    reasons.append("Price at Bollinger upper")
                if ema12 > ema26 and rsi_m15 < 45:
                    bull_score += 0.5
                if ema12 < ema26 and rsi_m15 > 55:
                    bear_score += 0.5

            elif strategy == "BREAKOUT":
                bb_width = (bb_upper - bb_lower) / (close + 1e-10)
                if bb_width < 0.005:
                    if close > bb_upper and macd_m15 > 0:
                        bull_score += 2.5
                        reasons.append("Breakout above Bollinger + MACD")
                    elif close < bb_lower and macd_m15 < 0:
                        bear_score += 2.5
                        reasons.append("Breakout below Bollinger + MACD")
                if close > sma20 and ema12 > ema26:
                    bull_score += 1.0
                elif close < sma20 and ema12 < ema26:
                    bear_score += 1.0

            elif strategy == "SCALP":
                if rsi_m15 < 35 and close > sma20 * 0.9995:
                    bull_score += 1.5
                    reasons.append("Scalp buy: RSI dip + near SMA")
                if rsi_m15 > 65 and close < sma20 * 1.0005:
                    bear_score += 1.5
                    reasons.append("Scalp sell: RSI peak + near SMA")
                if macd_m15 > 0 and ema12 > ema26:
                    bull_score += 0.8
                if macd_m15 < 0 and ema12 < ema26:
                    bear_score += 0.8

            elif strategy == "MOMENTUM":
                momentum_m15 = (close - sma50) / (sma50 + 1e-10) * 100
                if momentum_m15 > 0.2 and macd_m15 > 0 and rsi_m15 > 50:
                    bull_score += 2.0
                    reasons.append(f"Momentum bullish {momentum_m15:.2f}%")
                if momentum_m15 < -0.2 and macd_m15 < 0 and rsi_m15 < 50:
                    bear_score += 2.0
                    reasons.append(f"Momentum bearish {momentum_m15:.2f}%")
                if close > sma20 and ema12 > ema26:
                    bull_score += 0.8
                elif close < sma20 and ema12 < ema26:
                    bear_score += 0.8

            elif strategy == "SWING":
                if close > sma200 and sma20 > sma50 and rsi_h1 > 40 and rsi_h1 < 70:
                    bull_score += 2.0
                    reasons.append("Swing buy: aligned MAs + H1 RSI")
                if close < sma200 and sma20 < sma50 and rsi_h1 < 60 and rsi_h1 > 30:
                    bear_score += 2.0
                    reasons.append("Swing sell: aligned MAs + H1 RSI")
                h4_rsi = indicators.get("h4", {}).get("rsi", 50)
                if h4_rsi < 40 and bull_score > 0:
                    bull_score += 1.0
                    reasons.append("H4 RSI supports buy")
                if h4_rsi > 60 and bear_score > 0:
                    bear_score += 1.0
                    reasons.append("H4 RSI supports sell")

            elif strategy == "DEFENSIVE":
                if rsi_m15 < 25 and rsi_h1 < 30 and close < bb_lower:
                    bull_score += 2.5
                    reasons.append("DEFENSIVE: extreme oversold")
                if rsi_m15 > 75 and rsi_h1 > 70 and close > bb_upper:
                    bear_score += 2.5
                    reasons.append("DEFENSIVE: extreme overbought")

            if regime == "TRENDING_UP":
                bull_score *= 1.2
            elif regime == "TRENDING_DOWN":
                bear_score *= 1.2
            elif regime == "VOLATILE":
                bull_score *= 0.6
                bear_score *= 0.6

            total = bull_score + bear_score
            if total == 0:
                return signal

            if bull_score > bear_score and bull_score >= 2.0:
                confidence = min(0.95, bull_score / (total + 1e-10))
                signal = {"action": "BUY", "confidence": confidence, "reasons": reasons}
            elif bear_score > bull_score and bear_score >= 2.0:
                confidence = min(0.95, bear_score / (total + 1e-10))
                signal = {"action": "SELL", "confidence": confidence, "reasons": reasons}
            else:
                signal = {"action": "HOLD", "confidence": 0.0, "reasons": reasons}

        except Exception as e:
            logger.error(f"Generate signal error: {e}")

        return signal


# ============================================================================
# MEMORY ENGINE (ПОЛНЫЙ - БЕЗ ИЗМЕНЕНИЙ)
# ============================================================================
class MemoryEngine:
    def __init__(self, db_path: str):
        self.db_path = db_path
        self.short_term: deque = deque(maxlen=1000)
        self.episode_buffer: deque = deque(maxlen=500)
        self.pattern_memory: Dict[str, list] = {}
        self.market_memory: Dict[str, deque] = {}
        self.reward_history: deque = deque(maxlen=500)
        self.total_trades: int = 0
        self.total_profit: float = 0.0
        self.best_trades: list = []
        self.worst_trades: list = []

    def store_experience(self, state: np.ndarray, action: int,
                          reward: float, next_state: np.ndarray,
                          done: bool, metadata: dict = None):
        experience = {
            "state": state,
            "action": action,
            "reward": reward,
            "next_state": next_state,
            "done": done,
            "metadata": metadata or {},
            "timestamp": datetime.utcnow().isoformat(),
        }
        self.short_term.append(experience)
        self.episode_buffer.append(experience)
        self.reward_history.append(reward)

    def record_trade(self, trade: dict):
        self.total_trades += 1
        profit = trade.get("profit", 0)
        self.total_profit += profit

        if profit > 0:
            self.best_trades.append(trade)
            self.best_trades = sorted(self.best_trades, key=lambda x: x.get("profit", 0), reverse=True)[:10]
        else:
            self.worst_trades.append(trade)
            self.worst_trades = sorted(self.worst_trades, key=lambda x: x.get("profit", 0))[:10]

        symbol = trade.get("symbol", "UNKNOWN")
        strategy = trade.get("strategy", "UNKNOWN")
        pattern_key = f"{symbol}_{strategy}"
        if pattern_key not in self.pattern_memory:
            self.pattern_memory[pattern_key] = []
        self.pattern_memory[pattern_key].append({
            "profit": profit,
            "regime": trade.get("regime", "UNKNOWN"),
            "timestamp": datetime.utcnow().isoformat(),
        })
        if len(self.pattern_memory[pattern_key]) > 100:
            self.pattern_memory[pattern_key] = self.pattern_memory[pattern_key][-100:]

    def get_pattern_quality(self, symbol: str, strategy: str, regime: str) -> float:
        key = f"{symbol}_{strategy}"
        patterns = self.pattern_memory.get(key, [])
        if not patterns:
            return 0.5
        regime_patterns = [p for p in patterns if p.get("regime") == regime]
        if not regime_patterns:
            regime_patterns = patterns[-20:]
        profits = [p["profit"] for p in regime_patterns]
        if not profits:
            return 0.5
        win_rate = len([p for p in profits if p > 0]) / len(profits)
        return float(np.clip(win_rate, 0.0, 1.0))

    def calculate_reward(self, trade_result: dict) -> float:
        profit = trade_result.get("profit", 0)
        balance = trade_result.get("balance", 10000)
        duration_hours = trade_result.get("duration_hours", 1)

        if balance <= 0:
            return -1.0

        profit_pct = profit / balance

        if profit_pct > 0:
            reward = np.log(1 + profit_pct * 100)
        else:
            reward = -np.log(1 + abs(profit_pct) * 100) * 1.5

        if duration_hours > 48 and profit <= 0:
            reward -= 0.5

        if duration_hours > 0 and profit > 0:
            reward += min(0.3, profit_pct / duration_hours * 100)

        return float(np.clip(reward, -3.0, 3.0))

    def sample_batch(self, batch_size: int) -> list:
        if len(self.episode_buffer) < batch_size:
            return list(self.episode_buffer)
        return random.sample(list(self.episode_buffer), batch_size)

    def get_recent_performance(self, n: int = 20) -> dict:
        rewards = list(self.reward_history)[-n:]
        if not rewards:
            return {"avg_reward": 0.0, "trend": "NEUTRAL"}
        avg = float(np.mean(rewards))
        trend = "IMPROVING" if len(rewards) > 5 and np.mean(rewards[-5:]) > np.mean(rewards[:5]) else \
                "DECLINING" if len(rewards) > 5 and np.mean(rewards[-5:]) < np.mean(rewards[:5]) else "NEUTRAL"
        return {"avg_reward": avg, "trend": trend, "samples": len(rewards)}

    def get_summary(self) -> dict:
        recent_perf = self.get_recent_performance()
        return {
            "total_trades": self.total_trades,
            "total_profit": round(self.total_profit, 2),
            "buffer_size": len(self.episode_buffer),
            "patterns_learned": len(self.pattern_memory),
            "recent_performance": recent_perf,
            "best_trade": self.best_trades[0] if self.best_trades else None,
            "worst_trade": self.worst_trades[0] if self.worst_trades else None,
        }


# ============================================================================
# LEARNING ENGINE (ПОЛНЫЙ - БЕЗ ИЗМЕНЕНИЙ)
# ============================================================================
class LearningEngine:
    def __init__(self, state_size: int = 50):
        self.state_size = state_size
        self.agents: Dict[str, QLearningAgent] = {}
        self.global_agent = QLearningAgent(state_size, action_size=3)
        self.learning_active = True
        self.total_training_steps = 0
        self.loss_history: deque = deque(maxlen=1000)
        self.performance_tracker: Dict[str, deque] = {}
        self.error_log: deque = deque(maxlen=100)
        self.adaptation_rate = 0.01
        self.learning_cycles = 0

    def get_agent(self, symbol: str) -> QLearningAgent:
        if symbol not in self.agents:
            self.agents[symbol] = QLearningAgent(self.state_size, action_size=3)
            logger.info(f"Created new RL agent for {symbol}")
        return self.agents[symbol]

    async def train_agents(self, memory: MemoryEngine) -> dict:
        results = {}
        try:
            batch = memory.sample_batch(64)
            if len(batch) < 8:
                return results

            for exp in batch:
                state = exp["state"]
                action = exp["action"]
                reward = exp["reward"]
                next_state = exp["next_state"]
                done = exp["done"]
                symbol = exp.get("metadata", {}).get("symbol")

                self.global_agent.store_experience(state, action, reward, next_state, done)
                if symbol:
                    agent = self.get_agent(symbol)
                    agent.store_experience(state, action, reward, next_state, done)

            global_loss = self.global_agent.train()
            self.loss_history.append(global_loss)
            results["global_loss"] = global_loss

            symbol_losses = {}
            for symbol, agent in self.agents.items():
                loss = agent.train()
                symbol_losses[symbol] = loss

            results["symbol_losses"] = symbol_losses
            self.total_training_steps += 1
            self.learning_cycles += 1

            if self.learning_cycles % 50 == 0:
                self._adapt_learning_rates()

        except Exception as e:
            logger.error(f"Train agents error: {e}")
            self.error_log.append({"error": str(e), "timestamp": datetime.utcnow().isoformat()})
        return results

    def _adapt_learning_rates(self):
        recent_losses = list(self.loss_history)[-50:]
        if not recent_losses:
            return
        avg_loss = np.mean(recent_losses)
        if avg_loss > 0.1:
            for agent in self.agents.values():
                agent.model.lr = max(0.0001, agent.model.lr * 0.95)
            self.global_agent.model.lr = max(0.0001, self.global_agent.model.lr * 0.95)
        elif avg_loss < 0.001:
            for agent in self.agents.values():
                agent.model.lr = min(0.01, agent.model.lr * 1.05)

    def get_action_recommendation(self, symbol: str, state: np.ndarray) -> Tuple[int, float]:
        agent = self.get_agent(symbol)
        action = agent.get_action(state, explore=False)
        quality = agent.get_state_quality(state)
        global_action = self.global_agent.get_action(state, explore=False)
        global_quality = self.global_agent.get_state_quality(state)

        if len(agent.replay_buffer) > 100:
            final_action = action
            final_quality = (quality * 0.6 + global_quality * 0.4)
        else:
            final_action = global_action
            final_quality = global_quality

        return final_action, float(np.clip(final_quality, 0.0, 1.0))

    def get_training_stats(self) -> dict:
        losses = list(self.loss_history)
        return {
            "total_steps": self.total_training_steps,
            "learning_cycles": self.learning_cycles,
            "current_loss": float(np.mean(losses[-10:])) if losses else 0.0,
            "trend_loss": "IMPROVING" if len(losses) > 20 and np.mean(losses[-10:]) < np.mean(losses[-20:-10]) else "STABLE",
            "agents_count": len(self.agents),
            "global_epsilon": round(self.global_agent.epsilon, 4),
            "errors": len(self.error_log),
        }


# ============================================================================
# SIGNAL AGGREGATOR (ПОЛНЫЙ - БЕЗ ИЗМЕНЕНИЙ)
# ============================================================================
class SignalAggregator:
    def __init__(self):
        self.timeframe_weights = {
            "m1": 0.10,
            "m15": 0.30,
            "h1": 0.35,
            "h4": 0.25,
        }
        self.signal_history: Dict[str, deque] = {}
        self.divergence_log: deque = deque(maxlen=100)

    def aggregate(
        self,
        symbol: str,
        indicators: Dict[str, dict],
        regime: str,
        strategy: str,
        strategy_engine: StrategyEngine,
    ) -> dict:
        if symbol not in self.signal_history:
            self.signal_history[symbol] = deque(maxlen=50)

        tf_signals = {}
        for tf, weight in self.timeframe_weights.items():
            tf_ind = {tf: indicators.get(tf, {})}
            if not tf_ind.get(tf):
                continue
            sig = strategy_engine.generate_signal(
                strategy=strategy,
                indicators=tf_ind,
                regime=regime,
            )
            tf_signals[tf] = {
                "action": sig.get("action", "HOLD"),
                "confidence": sig.get("confidence", 0.0),
                "weight": weight,
                "reasons": sig.get("reasons", []),
            }

        if not tf_signals:
            return {"action": "HOLD", "confidence": 0.0, "reasons": [], "tf_signals": {}}

        weighted_votes = {"BUY": 0.0, "SELL": 0.0, "HOLD": 0.0}
        all_reasons = []
        total_weight = 0.0

        for tf, sig_data in tf_signals.items():
            action = sig_data["action"]
            conf = sig_data["confidence"]
            weight = sig_data["weight"]
            if action in weighted_votes:
                weighted_votes[action] += conf * weight
            total_weight += weight
            all_reasons.extend(sig_data["reasons"])

        if total_weight > 0:
            for k in weighted_votes:
                weighted_votes[k] /= total_weight

        best_action = max(weighted_votes, key=lambda k: weighted_votes[k])
        best_confidence = weighted_votes[best_action]

        actions = [s["action"] for s in tf_signals.values()]
        agreement_rate = actions.count(best_action) / len(actions)

        if agreement_rate < 0.5:
            best_confidence *= 0.6
            all_reasons.append(f"Low TF agreement: {agreement_rate:.0%}")

        if agreement_rate >= 0.75 and best_action != "HOLD":
            best_confidence = min(0.95, best_confidence * 1.15)
            all_reasons.append(f"High TF agreement: {agreement_rate:.0%}")

        divergence = self._detect_divergence(tf_signals)
        if divergence:
            self.divergence_log.append({
                "symbol": symbol,
                "divergence": divergence,
                "timestamp": datetime.utcnow().isoformat(),
            })
            best_confidence *= 0.75

        aggregated = {
            "action": best_action if best_confidence >= 0.55 else "HOLD",
            "signal_confidence": round(best_confidence, 4),
            "confidence": round(best_confidence, 4),
            "agreement_rate": round(agreement_rate, 3),
            "weighted_votes": {k: round(v, 4) for k, v in weighted_votes.items()},
            "tf_signals": tf_signals,
            "reasons": list(set(all_reasons)),
            "divergence": divergence,
        }

        self.signal_history[symbol].append({
            "action": aggregated["action"],
            "confidence": aggregated["confidence"],
            "timestamp": datetime.utcnow().isoformat(),
        })

        return aggregated

    def _detect_divergence(self, tf_signals: dict) -> Optional[str]:
        actions = [s["action"] for s in tf_signals.values() if s["action"] != "HOLD"]
        if len(set(actions)) > 1 and len(actions) >= 3:
            buys = actions.count("BUY")
            sells = actions.count("SELL")
            if buys > 0 and sells > 0:
                return f"TF_DIVERGENCE: {buys}xBUY vs {sells}xSELL"
        return None

    def get_signal_consistency(self, symbol: str) -> float:
        history = list(self.signal_history.get(symbol, []))
        if len(history) < 3:
            return 0.5
        recent = history[-10:]
        actions = [h["action"] for h in recent]
        if not actions:
            return 0.5
        most_common = max(set(actions), key=actions.count)
        return actions.count(most_common) / len(actions)


# ============================================================================
# POSITION TRACKER (ПОЛНЫЙ - БЕЗ ИЗМЕНЕНИЙ)
# ============================================================================
class PositionTracker:
    def __init__(self):
        self.tracked_positions: Dict[int, dict] = {}
        self.position_events: deque = deque(maxlen=500)
        self.max_position_age_hours: float = 72.0
        self.profit_lock_threshold: float = 0.02
        self.risk_alerts: deque = deque(maxlen=100)

    def update_position(self, position: dict, current_price: float, atr: float):
        ticket = position.get("ticket")
        if ticket is None:
            return

        if ticket not in self.tracked_positions:
            self.tracked_positions[ticket] = {
                "ticket": ticket,
                "symbol": position.get("symbol"),
                "order_type": position.get("order_type"),
                "open_price": position.get("open_price"),
                "volume": position.get("volume"),
                "open_time": position.get("open_time", datetime.utcnow().isoformat()),
                "peak_profit": 0.0,
                "min_profit": 0.0,
                "max_adverse_excursion": 0.0,
                "max_favorable_excursion": 0.0,
                "profit_locked": False,
                "age_hours": 0.0,
                "atr_at_open": atr,
                "updates": 0,
            }

        tp = self.tracked_positions[ticket]
        profit = position.get("profit", 0.0)
        open_price = tp.get("open_price", current_price)
        order_type = tp.get("order_type", "BUY")

        if profit > tp["peak_profit"]:
            tp["peak_profit"] = profit
        if profit < tp["min_profit"]:
            tp["min_profit"] = profit

        if order_type == "BUY":
            adverse = open_price - current_price
            favorable = current_price - open_price
        else:
            adverse = current_price - open_price
            favorable = open_price - current_price

        if adverse > tp["max_adverse_excursion"]:
            tp["max_adverse_excursion"] = adverse
        if favorable > tp["max_favorable_excursion"]:
            tp["max_favorable_excursion"] = favorable

        try:
            open_dt = datetime.fromisoformat(tp["open_time"])
            tp["age_hours"] = (datetime.utcnow() - open_dt).total_seconds() / 3600
        except Exception:
            tp["age_hours"] = 0.0

        balance_proxy = 10000
        if profit > balance_proxy * self.profit_lock_threshold and not tp["profit_locked"]:
            tp["profit_locked"] = True
            self.position_events.append({
                "ticket": ticket,
                "event": "PROFIT_LOCKED",
                "profit": profit,
                "timestamp": datetime.utcnow().isoformat(),
            })

        tp["current_profit"] = profit
        tp["current_price"] = current_price
        tp["updates"] += 1

        self._check_alerts(tp, atr)

    def _check_alerts(self, tp: dict, atr: float):
        ticket = tp.get("ticket")
        age_hours = tp.get("age_hours", 0.0)
        profit = tp.get("current_profit", 0.0)
        peak = tp.get("peak_profit", 0.0)

        if age_hours > self.max_position_age_hours and profit <= 0:
            self.risk_alerts.append({
                "ticket": ticket,
                "type": "AGE_WARNING",
                "message": f"Position {ticket} is {age_hours:.1f}h old with profit={profit:.2f}",
                "timestamp": datetime.utcnow().isoformat(),
            })

        if peak > 0 and profit < peak * 0.5 and peak > atr:
            self.risk_alerts.append({
                "ticket": ticket,
                "type": "PROFIT_PULLBACK",
                "message": f"Profit pulled back from {peak:.2f} to {profit:.2f}",
                "timestamp": datetime.utcnow().isoformat(),
            })

    def remove_position(self, ticket: int) -> Optional[dict]:
        return self.tracked_positions.pop(ticket, None)

    def get_portfolio_heat(self) -> float:
        if not self.tracked_positions:
            return 0.0
        total_adverse = sum(
            tp.get("max_adverse_excursion", 0)
            for tp in self.tracked_positions.values()
        )
        atr_sum = sum(
            tp.get("atr_at_open", 0.001)
            for tp in self.tracked_positions.values()
        )
        if atr_sum <= 0:
            return 0.0
        heat = total_adverse / atr_sum / len(self.tracked_positions)
        return float(np.clip(heat, 0.0, 1.0))

    def get_positions_summary(self) -> dict:
        positions = list(self.tracked_positions.values())
        if not positions:
            return {"count": 0, "total_profit": 0.0, "portfolio_heat": 0.0}
        total_profit = sum(p.get("current_profit", 0) for p in positions)
        return {
            "count": len(positions),
            "total_profit": round(total_profit, 2),
            "portfolio_heat": round(self.get_portfolio_heat(), 3),
            "oldest_hours": round(max(p.get("age_hours", 0) for p in positions), 1),
            "profit_locked_count": sum(1 for p in positions if p.get("profit_locked")),
            "risk_alerts_count": len(self.risk_alerts),
            "positions": [
                {
                    "ticket": p["ticket"],
                    "symbol": p["symbol"],
                    "order_type": p["order_type"],
                    "profit": round(p.get("current_profit", 0), 2),
                    "peak_profit": round(p["peak_profit"], 2),
                    "age_hours": round(p["age_hours"], 2),
                    "mae": round(p["max_adverse_excursion"], 5),
                    "mfe": round(p["max_favorable_excursion"], 5),
                }
                for p in positions
            ],
        }


# ============================================================================
# PERFORMANCE ANALYTICS ENGINE (ПОЛНЫЙ - БЕЗ ИЗМЕНЕНИЙ)
# ============================================================================
class PerformanceAnalyticsEngine:
    def __init__(self):
        self.equity_curve: deque = deque(maxlen=10000)
        self.daily_returns: deque = deque(maxlen=365)
        self.trade_metrics: deque = deque(maxlen=1000)
        self.symbol_performance: Dict[str, dict] = {}
        self.regime_performance: Dict[str, dict] = {}
        self.hourly_performance: Dict[int, dict] = {}
        self.weekly_performance: Dict[int, dict] = {}
        self.max_consecutive_wins: int = 0
        self.max_consecutive_losses: int = 0
        self._current_consecutive_wins: int = 0
        self._current_consecutive_losses: int = 0
        self.peak_equity: float = 0.0
        self.max_drawdown_ever: float = 0.0
        self.sharpe_ratio: float = 0.0
        self.sortino_ratio: float = 0.0
        self.profit_factor: float = 0.0
        self.calmar_ratio: float = 0.0
        self.last_analytics_update: Optional[datetime] = None

    def record_equity_point(self, equity: float, balance: float, timestamp: datetime):
        self.equity_curve.append({
            "equity": equity,
            "balance": balance,
            "timestamp": timestamp.isoformat(),
            "drawdown": (self.peak_equity - equity) / (self.peak_equity + 1e-10) if self.peak_equity > 0 else 0.0,
        })
        if equity > self.peak_equity:
            self.peak_equity = equity
        current_dd = (self.peak_equity - equity) / (self.peak_equity + 1e-10)
        if current_dd > self.max_drawdown_ever:
            self.max_drawdown_ever = current_dd

    def record_trade_result(self, trade: dict):
        try:
            profit = trade.get("profit", 0.0)
            symbol = trade.get("symbol", "UNKNOWN")
            strategy = trade.get("strategy", "UNKNOWN")
            regime = trade.get("regime", "UNKNOWN")
            open_time_str = trade.get("open_time", datetime.utcnow().isoformat())
            close_time_str = trade.get("close_time", datetime.utcnow().isoformat())

            try:
                open_dt = datetime.fromisoformat(open_time_str)
                close_dt = datetime.fromisoformat(close_time_str)
                duration_minutes = (close_dt - open_dt).total_seconds() / 60
            except Exception:
                duration_minutes = 60.0
                open_dt = datetime.utcnow()

            hour = open_dt.hour
            weekday = open_dt.weekday()

            metric = {
                "profit": profit,
                "symbol": symbol,
                "strategy": strategy,
                "regime": regime,
                "duration_minutes": duration_minutes,
                "hour": hour,
                "weekday": weekday,
                "timestamp": datetime.utcnow().isoformat(),
                "is_win": profit > 0,
            }
            self.trade_metrics.append(metric)

            if profit > 0:
                self._current_consecutive_wins += 1
                self._current_consecutive_losses = 0
                if self._current_consecutive_wins > self.max_consecutive_wins:
                    self.max_consecutive_wins = self._current_consecutive_wins
            else:
                self._current_consecutive_losses += 1
                self._current_consecutive_wins = 0
                if self._current_consecutive_losses > self.max_consecutive_losses:
                    self.max_consecutive_losses = self._current_consecutive_losses

            if symbol not in self.symbol_performance:
                self.symbol_performance[symbol] = {
                    "trades": 0, "wins": 0, "losses": 0,
                    "total_profit": 0.0, "avg_duration": 0.0,
                    "best_trade": 0.0, "worst_trade": 0.0,
                }
            sp = self.symbol_performance[symbol]
            sp["trades"] += 1
            sp["total_profit"] += profit
            if profit > 0:
                sp["wins"] += 1
                sp["best_trade"] = max(sp["best_trade"], profit)
            else:
                sp["losses"] += 1
                sp["worst_trade"] = min(sp["worst_trade"], profit)
            sp["avg_duration"] = (
                (sp["avg_duration"] * (sp["trades"] - 1) + duration_minutes) / sp["trades"]
            )

            if regime not in self.regime_performance:
                self.regime_performance[regime] = {
                    "trades": 0, "wins": 0, "total_profit": 0.0,
                }
            rp = self.regime_performance[regime]
            rp["trades"] += 1
            rp["total_profit"] += profit
            if profit > 0:
                rp["wins"] += 1

            if hour not in self.hourly_performance:
                self.hourly_performance[hour] = {
                    "trades": 0, "wins": 0, "total_profit": 0.0,
                }
            hp = self.hourly_performance[hour]
            hp["trades"] += 1
            hp["total_profit"] += profit
            if profit > 0:
                hp["wins"] += 1

            if weekday not in self.weekly_performance:
                self.weekly_performance[weekday] = {
                    "trades": 0, "wins": 0, "total_profit": 0.0,
                }
            wp = self.weekly_performance[weekday]
            wp["trades"] += 1
            wp["total_profit"] += profit
            if profit > 0:
                wp["wins"] += 1

            self._update_ratios()

        except Exception as e:
            logger.error(f"Record trade result analytics error: {e}")

    def _update_ratios(self):
        try:
            trades = list(self.trade_metrics)
            if len(trades) < 5:
                return

            profits = [t["profit"] for t in trades]
            wins = [p for p in profits if p > 0]
            losses = [p for p in profits if p < 0]

            gross_profit = sum(wins)
            gross_loss = abs(sum(losses))
            self.profit_factor = gross_profit / gross_loss if gross_loss > 0 else float(gross_profit > 0) * 99.0

            if len(profits) > 1:
                mean_r = float(np.mean(profits))
                std_r = float(np.std(profits))
                self.sharpe_ratio = (mean_r / (std_r + 1e-10)) * np.sqrt(252)

                downside = [p for p in profits if p < 0]
                if downside:
                    downside_std = float(np.std(downside))
                    self.sortino_ratio = (mean_r / (downside_std + 1e-10)) * np.sqrt(252)

            ann_return = float(np.sum(profits)) / max(1, len(profits)) * 252
            if self.max_drawdown_ever > 0:
                self.calmar_ratio = ann_return / self.max_drawdown_ever
            else:
                self.calmar_ratio = 0.0

            self.last_analytics_update = datetime.utcnow()

        except Exception as e:
            logger.error(f"Update ratios error: {e}")

    def get_best_trading_hours(self) -> List[int]:
        hour_scores = {}
        for hour, data in self.hourly_performance.items():
            if data["trades"] >= 3:
                wr = data["wins"] / data["trades"]
                score = wr * data["total_profit"]
                hour_scores[hour] = score
        if not hour_scores:
            return list(range(6, 22))
        sorted_hours = sorted(hour_scores, key=lambda h: hour_scores[h], reverse=True)
        return sorted_hours[:12]

    def get_best_regimes(self) -> List[str]:
        regime_scores = {}
        for regime, data in self.regime_performance.items():
            if data["trades"] >= 3:
                wr = data["wins"] / data["trades"]
                regime_scores[regime] = wr * (data["total_profit"] + 1)
        if not regime_scores:
            return REGIMES
        return sorted(regime_scores, key=lambda r: regime_scores[r], reverse=True)

    def get_full_report(self) -> dict:
        trades = list(self.trade_metrics)
        total = len(trades)
        if total == 0:
            return {"status": "no_data", "total_trades": 0}

        profits = [t["profit"] for t in trades]
        wins = [p for p in profits if p > 0]
        losses = [p for p in profits if p < 0]

        return {
            "total_trades": total,
            "win_rate": round(len(wins) / total, 4) if total > 0 else 0.0,
            "total_profit": round(sum(profits), 2),
            "avg_profit": round(float(np.mean(profits)), 2),
            "avg_win": round(float(np.mean(wins)), 2) if wins else 0.0,
            "avg_loss": round(float(np.mean(losses)), 2) if losses else 0.0,
            "best_trade": round(max(profits), 2) if profits else 0.0,
            "worst_trade": round(min(profits), 2) if profits else 0.0,
            "profit_factor": round(self.profit_factor, 3),
            "sharpe_ratio": round(self.sharpe_ratio, 3),
            "sortino_ratio": round(self.sortino_ratio, 3),
            "calmar_ratio": round(self.calmar_ratio, 3),
            "max_drawdown_ever": round(self.max_drawdown_ever, 4),
            "max_consecutive_wins": self.max_consecutive_wins,
            "max_consecutive_losses": self.max_consecutive_losses,
            "symbol_performance": {
                sym: {
                    "trades": d["trades"],
                    "win_rate": round(d["wins"] / d["trades"], 3) if d["trades"] > 0 else 0.0,
                    "total_profit": round(d["total_profit"], 2),
                    "avg_duration_min": round(d["avg_duration"], 1),
                    "best_trade": round(d["best_trade"], 2),
                    "worst_trade": round(d["worst_trade"], 2),
                }
                for sym, d in self.symbol_performance.items()
            },
            "regime_performance": {
                reg: {
                    "trades": d["trades"],
                    "win_rate": round(d["wins"] / d["trades"], 3) if d["trades"] > 0 else 0.0,
                    "total_profit": round(d["total_profit"], 2),
                }
                for reg, d in self.regime_performance.items()
            },
            "best_hours": self.get_best_trading_hours(),
            "best_regimes": self.get_best_regimes(),
            "equity_curve_points": len(self.equity_curve),
            "last_update": self.last_analytics_update.isoformat() if self.last_analytics_update else None,
        }

    def get_equity_curve(self, last_n: int = 200) -> list:
        curve = list(self.equity_curve)
        return curve[-last_n:] if len(curve) > last_n else curve


# ============================================================================
# ADVANCED RISK ENGINE (PRIME - С РЕАЛЬНЫМИ АЛЕРТАМИ)
# ============================================================================
class AdvancedRiskEngine:
    def __init__(self, event_bus: Optional["EventBus"] = None):
        self.event_bus = event_bus
        self.portfolio_returns: deque = deque(maxlen=500)
        self.symbol_returns: Dict[str, deque] = {}
        self.correlation_matrix: Dict[str, Dict[str, float]] = {}
        self.correlation_last_update: Optional[datetime] = None
        self.correlation_update_interval = 300

        self.var_confidence = 0.95
        self.var_horizon_days = 1
        self.cvar_window = 252

        self.gross_exposure: float = 0.0
        self.net_exposure: float = 0.0
        self.symbol_exposure: Dict[str, float] = {}
        self.sector_exposure: Dict[str, float] = {}
        self.max_gross_exposure_pct: float = 0.30
        self.max_symbol_exposure_pct: float = 0.10
        self.max_sector_exposure_pct: float = 0.20

        self.current_leverage: float = 1.0
        self.max_leverage: float = 5.0
        self.target_volatility: float = 0.15
        self.leverage_history: deque = deque(maxlen=100)

        self.portfolio_risk_score: float = 0.0
        self.last_var: float = 0.0
        self.last_cvar: float = 0.0
        self.last_score_update: Optional[datetime] = None

        self.stress_scenarios: Dict[str, float] = {
            "flash_crash_10pct": -0.10,
            "flash_crash_5pct": -0.05,
            "gap_up_5pct": 0.05,
            "volatility_spike": -0.07,
        }

        self.symbol_sectors: Dict[str, str] = {
            "EURUSD": "FX_MAJOR", "GBPUSD": "FX_MAJOR",
            "USDJPY": "FX_MAJOR", "USDCHF": "FX_MAJOR",
            "AUDUSD": "FX_COMMODITY", "NZDUSD": "FX_COMMODITY",
            "USDCAD": "FX_COMMODITY", "XAUUSD": "METALS",
            "XAGUSD": "METALS", "BTCUSD": "CRYPTO",
            "ETHUSD": "CRYPTO", "US30": "INDICES",
            "SPX500": "INDICES", "NAS100": "INDICES",
        }
        logger.info("AdvancedRiskEngine initialized")

    def record_symbol_return(self, symbol: str, ret: float):
        if symbol not in self.symbol_returns:
            self.symbol_returns[symbol] = deque(maxlen=252)
        self.symbol_returns[symbol].append(ret)
        if self.symbol_returns:
            avg_ret = float(np.mean([
                list(rets)[-1]
                for rets in self.symbol_returns.values()
                if rets
            ]))
            self.portfolio_returns.append(avg_ret)

    def compute_var(self, confidence: float = 0.95, horizon: int = 1) -> Tuple[float, float]:
        try:
            returns = list(self.portfolio_returns)
            if len(returns) < 20:
                logger.warning("Insufficient data for VaR calculation, using default")
                return 0.02, 0.03
            arr = np.array(returns)
            scaled = arr * np.sqrt(horizon)
            var_pct = float(np.percentile(scaled, (1 - confidence) * 100))
            tail = scaled[scaled <= var_pct]
            cvar_pct = float(np.mean(tail)) if len(tail) > 0 else var_pct
            self.last_var = abs(var_pct)
            self.last_cvar = abs(cvar_pct)
            return self.last_var, self.last_cvar
        except Exception as e:
            logger.error(f"VaR computation error: {e}")
            return 0.02, 0.03

    def compute_portfolio_volatility(self) -> float:
        try:
            returns = list(self.portfolio_returns)
            if len(returns) < 5:
                return 0.15
            arr = np.array(returns)
            daily_vol = float(np.std(arr))
            ann_vol = daily_vol * np.sqrt(252)
            return float(np.clip(ann_vol, 0.01, 5.0))
        except Exception as e:
            logger.error(f"Portfolio volatility error: {e}")
            return 0.15

    def compute_correlation_matrix(self) -> Dict[str, Dict[str, float]]:
        try:
            now = datetime.utcnow()
            if (
                self.correlation_last_update
                and (now - self.correlation_last_update).total_seconds() < self.correlation_update_interval
            ):
                return self.correlation_matrix

            symbols = [s for s, r in self.symbol_returns.items() if len(r) >= 20]
            if len(symbols) < 2:
                return {}

            matrix: Dict[str, Dict[str, float]] = {}
            for s1 in symbols:
                matrix[s1] = {}
                r1 = np.array(list(self.symbol_returns[s1]))
                for s2 in symbols:
                    r2 = np.array(list(self.symbol_returns[s2]))
                    min_len = min(len(r1), len(r2))
                    if min_len < 10:
                        matrix[s1][s2] = 0.0
                        continue
                    corr = float(np.corrcoef(r1[-min_len:], r2[-min_len:])[0, 1])
                    matrix[s1][s2] = round(float(np.nan_to_num(corr, nan=0.0)), 3)

            self.correlation_matrix = matrix
            self.correlation_last_update = now
            return matrix
        except Exception as e:
            logger.error(f"Correlation matrix error: {e}")
            return {}

    def get_correlation_risk(self, symbol: str, existing_positions: list) -> float:
        try:
            if not existing_positions:
                return 0.0
            matrix = self.compute_correlation_matrix()
            if not matrix or symbol not in matrix:
                return 0.0
            open_symbols = list(set(p.get("symbol") for p in existing_positions))
            correlations = []
            for s in open_symbols:
                if s in matrix.get(symbol, {}):
                    correlations.append(abs(matrix[symbol][s]))
            if not correlations:
                return 0.0
            max_corr = float(np.max(correlations))
            avg_corr = float(np.mean(correlations))
            return float(np.clip(max_corr * 0.7 + avg_corr * 0.3, 0.0, 1.0))
        except Exception as e:
            logger.error(f"Correlation risk error: {e}")
            return 0.0

    def compute_dynamic_leverage(self) -> float:
        try:
            port_vol = self.compute_portfolio_volatility()
            if port_vol <= 0:
                return 1.0
            target_lev = self.target_volatility / port_vol
            var, cvar = self.compute_var()
            if cvar > 0.05:
                target_lev *= 0.5
            elif cvar > 0.03:
                target_lev *= 0.75
            alpha = 0.2
            self.current_leverage = (
                alpha * float(np.clip(target_lev, 0.1, self.max_leverage))
                + (1 - alpha) * self.current_leverage
            )
            self.leverage_history.append({
                "leverage": self.current_leverage,
                "port_vol": port_vol,
                "timestamp": datetime.utcnow().isoformat(),
            })
            return round(self.current_leverage, 3)
        except Exception as e:
            logger.error(f"Dynamic leverage error: {e}")
            return 1.0

    def update_exposure(self, positions: list, account: dict):
        try:
            balance = account.get("balance", 10000)
            if balance <= 0:
                return
            self.symbol_exposure.clear()
            self.sector_exposure.clear()
            gross = 0.0
            net = 0.0
            for p in positions:
                symbol = p.get("symbol", "UNKNOWN")
                volume = p.get("volume", 0.0)
                open_price = p.get("open_price", 1.0)
                order_type = p.get("order_type", "BUY")
                notional = volume * open_price * 100000
                exposure_pct = notional / balance
                self.symbol_exposure[symbol] = (
                    self.symbol_exposure.get(symbol, 0.0) + exposure_pct
                )
                sector = self.symbol_sectors.get(symbol, "OTHER")
                self.sector_exposure[sector] = (
                    self.sector_exposure.get(sector, 0.0) + exposure_pct
                )
                gross += exposure_pct
                net += exposure_pct if order_type == "BUY" else -exposure_pct
            self.gross_exposure = gross
            self.net_exposure = net
        except Exception as e:
            logger.error(f"Update exposure error: {e}")

    async def emit_risk_alerts(self, event_bus, positions: list, account: dict):
        """PRIME FIX #4: ПОЛНОЦЕННЫЙ emit_risk_alerts (была заглушка)"""
        try:
            balance = account.get("balance", 0)
            equity = account.get("equity", balance)
            
            if balance > 0:
                drawdown = (balance - equity) / balance
                if drawdown > 0.12:
                    await event_bus.publish(TradingEvent(
                        event_type=EventBus.DRAWDOWN_BREACH,
                        source="AdvancedRiskEngine",
                        payload={"drawdown": drawdown, "balance": balance, "equity": equity}
                    ))
                
                # Доп. проверка: стресс-тест при просадке > 8%
                if drawdown > 0.08:
                    stress = self.run_stress_test(positions, account)
                    worst_stress = min(stress.values()) if stress else 0
                    if worst_stress < -0.15:
                        await event_bus.publish(TradingEvent(
                            event_type=EventBus.RISK_ALERT,
                            source="AdvancedRiskEngine",
                            payload={
                                "message": f"Stress test shows {worst_stress:.1%} loss potential",
                                "drawdown": drawdown,
                                "stress_result": worst_stress
                            }
                        ))
            
            if len(positions) > 8:
                await event_bus.publish(TradingEvent(
                    event_type=EventBus.RISK_ALERT,
                    source="AdvancedRiskEngine",
                    payload={"message": f"High position count: {len(positions)}", "positions": len(positions)}
                ))
            
            # Проверка на концентрацию по символу
            symbol_counts = {}
            symbol_values = {}
            for p in positions:
                sym = p.get("symbol", "UNKNOWN")
                symbol_counts[sym] = symbol_counts.get(sym, 0) + 1
                volume = p.get("volume", 0)
                open_price = p.get("open_price", 1.0)
                symbol_values[sym] = symbol_values.get(sym, 0) + volume * open_price * 100000
            
            for sym, count in symbol_counts.items():
                if count >= 3:
                    await event_bus.publish(TradingEvent(
                        event_type=EventBus.RISK_ALERT,
                        source="AdvancedRiskEngine",
                        payload={"message": f"High concentration on {sym}: {count} positions", "symbol": sym, "count": count}
                    ))
            
            # Проверка на корреляционный риск
            if len(positions) >= 2:
                symbols = list(set(p.get("symbol") for p in positions))
                if len(symbols) >= 2:
                    matrix = self.compute_correlation_matrix()
                    max_corr = 0
                    for i, s1 in enumerate(symbols):
                        for s2 in symbols[i+1:]:
                            corr = abs(matrix.get(s1, {}).get(s2, 0))
                            max_corr = max(max_corr, corr)
                    if max_corr > 0.8:
                        await event_bus.publish(TradingEvent(
                            event_type=EventBus.RISK_ALERT,
                            source="AdvancedRiskEngine",
                            payload={"message": f"High correlation ({max_corr:.2f}) between positions", "max_correlation": max_corr}
                        ))
                        
        except Exception as e:
            logger.error(f"emit_risk_alerts error: {e}")

    def run_stress_test(self, positions: list, account: dict) -> Dict[str, float]:
        try:
            balance = account.get("balance", 10000)
            if balance <= 0:
                return {}
            results = {}
            for scenario_name, shock in self.stress_scenarios.items():
                total_pnl = 0.0
                for p in positions:
                    volume = p.get("volume", 0.0)
                    open_price = p.get("open_price", 1.0)
                    order_type = p.get("order_type", "BUY")
                    notional = volume * open_price * 100000
                    if order_type == "BUY":
                        pnl = notional * shock
                    else:
                        pnl = notional * (-shock)
                    total_pnl += pnl
                results[scenario_name] = round(total_pnl / balance, 4)
            return results
        except Exception as e:
            logger.error(f"Stress test error: {e}")
            return {}

    def compute_portfolio_risk_score(
        self,
        positions: list,
        account: dict,
    ) -> float:
        try:
            balance = account.get("balance", 10000)
            equity = account.get("equity", balance)
            if balance <= 0:
                return 0.0

            self.update_exposure(positions, account)
            var, cvar = self.compute_var()
            port_vol = self.compute_portfolio_volatility()
            drawdown = (balance - equity) / balance if balance > 0 else 0.0

            var_score = float(np.clip(var / 0.05, 0.0, 1.0))
            cvar_score = float(np.clip(cvar / 0.08, 0.0, 1.0))
            exposure_score = float(np.clip(self.gross_exposure / self.max_gross_exposure_pct, 0.0, 1.0))
            vol_score = float(np.clip(port_vol / 0.50, 0.0, 1.0))
            dd_score = float(np.clip(drawdown / 0.15, 0.0, 1.0))

            if len(positions) >= 2:
                sym_list = list(set(p.get("symbol") for p in positions))
                max_corr = 0.0
                matrix = self.compute_correlation_matrix()
                for i, s1 in enumerate(sym_list):
                    for s2 in sym_list[i+1:]:
                        c = abs(matrix.get(s1, {}).get(s2, 0.0))
                        max_corr = max(max_corr, c)
                corr_score = float(np.clip(max_corr, 0.0, 1.0))
            else:
                corr_score = 0.0

            weights = {
                "var": 0.20,
                "cvar": 0.25,
                "exposure": 0.20,
                "vol": 0.15,
                "dd": 0.15,
                "corr": 0.05,
            }
            score = (
                weights["var"] * var_score
                + weights["cvar"] * cvar_score
                + weights["exposure"] * exposure_score
                + weights["vol"] * vol_score
                + weights["dd"] * dd_score
                + weights["corr"] * corr_score
            )
            self.portfolio_risk_score = float(np.clip(score, 0.0, 1.0))
            self.last_score_update = datetime.utcnow()
            return self.portfolio_risk_score
        except Exception as e:
            logger.error(f"Portfolio risk score error: {e}")
            return 0.5

    def suggest_position_size(
        self,
        symbol: str,
        account: dict,
        positions: list,
        entry_price: float,
        sl_price: float,
        base_volume: float,
    ) -> Tuple[float, str]:
        try:
            risk_score = self.compute_portfolio_risk_score(positions, account)
            corr_risk = self.get_correlation_risk(symbol, positions)
            leverage = self.compute_dynamic_leverage()

            multiplier = 1.0
            reasons = []

            if risk_score > 0.80:
                multiplier *= 0.25
                reasons.append(f"CRITICAL risk_score={risk_score:.2f}")
            elif risk_score > 0.65:
                multiplier *= 0.50
                reasons.append(f"HIGH risk_score={risk_score:.2f}")
            elif risk_score > 0.50:
                multiplier *= 0.75
                reasons.append(f"ELEVATED risk_score={risk_score:.2f}")

            if corr_risk > 0.80:
                multiplier *= 0.50
                reasons.append(f"HIGH correlation={corr_risk:.2f}")
            elif corr_risk > 0.60:
                multiplier *= 0.75
                reasons.append(f"MODERATE correlation={corr_risk:.2f}")

            symbol_exp = self.symbol_exposure.get(symbol, 0.0)
            if symbol_exp > self.max_symbol_exposure_pct:
                multiplier *= 0.30
                reasons.append(f"Symbol exposure cap ({symbol_exp:.1%})")

            sector = self.symbol_sectors.get(symbol, "OTHER")
            sector_exp = self.sector_exposure.get(sector, 0.0)
            if sector_exp > self.max_sector_exposure_pct:
                multiplier *= 0.50
                reasons.append(f"Sector exposure cap ({sector_exp:.1%})")

            multiplier *= float(np.clip(leverage / self.max_leverage, 0.2, 1.5))

            adjusted = round(float(np.clip(base_volume * multiplier, 0.01, 10.0)), 2)
            reason_str = " | ".join(reasons) if reasons else "OK"
            return adjusted, reason_str

        except Exception as e:
            logger.error(f"Suggest position size error: {e}")
            return base_volume, "error"

    def get_full_risk_report(self) -> dict:
        var, cvar = self.compute_var()
        port_vol = self.compute_portfolio_volatility()
        leverage = self.current_leverage
        return {
            "portfolio_risk_score": round(self.portfolio_risk_score, 4),
            "var_95_1d": round(var, 4),
            "cvar_95_1d": round(cvar, 4),
            "portfolio_volatility_ann": round(port_vol, 4),
            "current_leverage": round(leverage, 3),
            "gross_exposure": round(self.gross_exposure, 4),
            "net_exposure": round(self.net_exposure, 4),
            "symbol_exposure": {k: round(v, 4) for k, v in self.symbol_exposure.items()},
            "sector_exposure": {k: round(v, 4) for k, v in self.sector_exposure.items()},
            "last_score_update": self.last_score_update.isoformat() if self.last_score_update else None,
            "correlation_matrix": {
                s1: {s2: v for s2, v in row.items()}
                for s1, row in self.correlation_matrix.items()
            },
        }


# ============================================================================
# ONLINE LEARNING ENGINE (PRIME - С РЕАЛЬНОЙ ДЕГРАДАЦИЕЙ)
# ============================================================================
@dataclass
class FeatureRecord:
    timestamp: str
    symbol: str
    regime: str
    strategy: str
    features: List[float]
    label: int
    confidence: float
    profit: float = 0.0

class OnlineLearningEngine:
    def __init__(self, feature_dim: int = 50, event_bus: Optional["EventBus"] = None):
        self.feature_dim = feature_dim
        self.event_bus = event_bus

        self.feature_store: deque = deque(maxlen=5000)
        self.regime_feature_store: Dict[str, deque] = {
            r: deque(maxlen=500) for r in REGIMES
        }
        self.strategy_feature_store: Dict[str, deque] = {
            s: deque(maxlen=500) for s in STRATEGIES
        }

        self.regime_classifiers: Dict[str, SimpleNeuralNet] = {
            r: SimpleNeuralNet(feature_dim, [64, 32], 2, lr=0.002) for r in REGIMES
        }
        self.strategy_classifiers: Dict[str, SimpleNeuralNet] = {
            s: SimpleNeuralNet(feature_dim, [64, 32], 2, lr=0.002) for s in STRATEGIES
        }
        self.global_classifier = SimpleNeuralNet(feature_dim, [128, 64, 32], 2, lr=0.001)

        self.baseline_accuracy: Dict[str, float] = {}
        self.rolling_accuracy: Dict[str, deque] = {}
        self.drift_threshold = 0.15
        self.drift_window = 50
        self.drift_events: deque = deque(maxlen=100)
        self.degradation_alerts: deque = deque(maxlen=50)

        self.accuracy_window: deque = deque(maxlen=200)
        self.regime_accuracy: Dict[str, deque] = {r: deque(maxlen=100) for r in REGIMES}
        self.strategy_accuracy: Dict[str, deque] = {s: deque(maxlen=100) for s in STRATEGIES}

        self.pending_train: deque = deque(maxlen=1000)
        self.total_online_updates = 0
        self.last_drift_check: Optional[datetime] = None

        logger.info("OnlineLearningEngine initialized")

    def store_feature(self, record: FeatureRecord):
        self.feature_store.append(record)
        self.regime_feature_store[record.regime].append(record)
        self.strategy_feature_store.get(record.strategy, deque()).append(record)
        self.pending_train.append(record)

    def online_update(self, record: FeatureRecord) -> float:
        try:
            features = np.array(record.features[:self.feature_dim], dtype=np.float32)
            if len(features) < self.feature_dim:
                features = np.pad(features, (0, self.feature_dim - len(features)))
            features = np.nan_to_num(np.clip(features, -5.0, 5.0))

            target = np.array([[float(record.label), float(1 - record.label)]], dtype=np.float32)

            loss = self.global_classifier.train_step(features.reshape(1, -1), target)

            if record.regime in self.regime_classifiers:
                loss += self.regime_classifiers[record.regime].train_step(
                    features.reshape(1, -1), target
                )

            if record.strategy in self.strategy_classifiers:
                loss += self.strategy_classifiers[record.strategy].train_step(
                    features.reshape(1, -1), target
                )

            pred = self.global_classifier.predict(features.reshape(1, -1))[0]
            predicted_label = int(np.argmax(pred))
            correct = int(predicted_label == record.label)

            self.accuracy_window.append(correct)
            self.regime_accuracy[record.regime].append(correct)
            if record.strategy in self.strategy_accuracy:
                self.strategy_accuracy[record.strategy].append(correct)

            self.total_online_updates += 1
            return float(loss)

        except Exception as e:
            logger.error(f"Online update error: {e}")
            return 0.0

    def batch_train(self, n: int = 64) -> Dict[str, float]:
        results = {}
        try:
            records = list(self.pending_train)
            if len(records) < 8:
                return results

            batch = random.sample(records, min(n, len(records)))
            total_loss = 0.0
            for rec in batch:
                loss = self.online_update(rec)
                total_loss += loss

            self.pending_train.clear()
            results["batch_loss"] = round(total_loss / len(batch), 6)
            results["batch_size"] = len(batch)
        except Exception as e:
            logger.error(f"Batch train error: {e}")
        return results

    async def check_performance_degradation(self, memory_engine) -> dict:
        """PRIME FIX #5: РЕАЛЬНАЯ проверка деградации (была заглушка)"""
        try:
            summary = memory_engine.get_summary()
            recent_perf = summary.get("recent_performance", {})
            avg_reward = recent_perf.get("avg_reward", 0)
            
            # Проверка по разным метрикам
            degradation_detected = False
            reasons = []
            
            if avg_reward < -0.5:
                degradation_detected = True
                reasons.append(f"Negative avg_reward: {avg_reward:.2f}")
            
            # Проверка win rate за последние 20 сделок
            trades = list(memory_engine.trade_history_risk)
            if len(trades) >= 20:
                recent_trades = trades[-20:]
                wins = sum(1 for t in recent_trades if t.get("profit", 0) > 0)
                win_rate = wins / len(recent_trades)
                if win_rate < 0.35:
                    degradation_detected = True
                    reasons.append(f"Low win_rate: {win_rate:.1%}")
            
            # Проверка на увеличение просадки
            if hasattr(memory_engine, 'max_drawdown'):
                dd = memory_engine.max_drawdown
                if dd > 0.12:
                    degradation_detected = True
                    reasons.append(f"High drawdown: {dd:.1%}")
            
            if degradation_detected:
                alert = {
                    "degraded": True,
                    "avg_reward": avg_reward,
                    "threshold": -0.5,
                    "reasons": reasons,
                    "timestamp": datetime.utcnow().isoformat()
                }
                self.degradation_alerts.append(alert)
                
                if self.event_bus:
                    await self.event_bus.publish(TradingEvent(
                        event_type=EventBus.PERFORMANCE_ALERT,
                        source="OnlineLearningEngine",
                        payload=alert,
                        priority=2
                    ))
                
                return alert
            
            return {"degraded": False, "avg_reward": avg_reward}
            
        except Exception as e:
            logger.error(f"check_performance_degradation error: {e}")
            return {"degraded": False, "error": str(e)}

    def predict_trade_quality(
        self,
        features: np.ndarray,
        regime: str,
        strategy: str,
    ) -> Tuple[float, float]:
        try:
            f = np.array(features[:self.feature_dim], dtype=np.float32)
            if len(f) < self.feature_dim:
                f = np.pad(f, (0, self.feature_dim - len(f)))
            f = np.nan_to_num(np.clip(f, -5.0, 5.0)).reshape(1, -1)

            global_pred = self.global_classifier.predict(f)[0]
            global_win_prob = float(global_pred[0])

            regime_win_prob = 0.5
            if regime in self.regime_classifiers:
                regime_pred = self.regime_classifiers[regime].predict(f)[0]
                regime_win_prob = float(regime_pred[0])

            strategy_win_prob = 0.5
            if strategy in self.strategy_classifiers:
                strat_pred = self.strategy_classifiers[strategy].predict(f)[0]
                strategy_win_prob = float(strat_pred[0])

            acc_global = self._get_accuracy("global")
            acc_regime = self._get_accuracy(f"regime_{regime}")
            acc_strategy = self._get_accuracy(f"strategy_{strategy}")
            total_acc = acc_global + acc_regime + acc_strategy + 1e-10

            win_prob = (
                acc_global * global_win_prob
                + acc_regime * regime_win_prob
                + acc_strategy * strategy_win_prob
            ) / total_acc

            confidence = abs(win_prob - 0.5) * 2.0
            return float(np.clip(win_prob, 0.0, 1.0)), float(np.clip(confidence, 0.0, 1.0))

        except Exception as e:
            logger.error(f"Predict trade quality error: {e}")
            return 0.5, 0.0

    def _get_accuracy(self, key: str) -> float:
        if key == "global":
            window = list(self.accuracy_window)
        elif key.startswith("regime_"):
            regime = key[7:]
            window = list(self.regime_accuracy.get(regime, []))
        elif key.startswith("strategy_"):
            strategy = key[9:]
            window = list(self.strategy_accuracy.get(strategy, []))
        else:
            return 0.5
        if not window:
            return 0.5
        return float(np.mean(window[-self.drift_window:]))

    async def check_model_drift(self) -> Optional[dict]:
        try:
            now = datetime.utcnow()
            if (
                self.last_drift_check
                and (now - self.last_drift_check).total_seconds() < 300
            ):
                return None
            self.last_drift_check = now

            drift_detected = False
            drift_details = {}

            window = list(self.accuracy_window)
            if len(window) >= self.drift_window * 2:
                old_acc = float(np.mean(window[: self.drift_window]))
                new_acc = float(np.mean(window[-self.drift_window:]))
                key = "global"
                if key not in self.baseline_accuracy:
                    self.baseline_accuracy[key] = old_acc
                baseline = self.baseline_accuracy[key]
                drop = baseline - new_acc
                if drop > self.drift_threshold:
                    drift_detected = True
                    drift_details["global"] = {
                        "baseline": round(baseline, 3),
                        "current": round(new_acc, 3),
                        "drop": round(drop, 3),
                    }

            for regime, acc_deque in self.regime_accuracy.items():
                w = list(acc_deque)
                if len(w) >= 20:
                    key = f"regime_{regime}"
                    curr_acc = float(np.mean(w[-20:]))
                    if key not in self.baseline_accuracy:
                        self.baseline_accuracy[key] = curr_acc
                    baseline = self.baseline_accuracy[key]
                    drop = baseline - curr_acc
                    if drop > self.drift_threshold * 1.2:
                        drift_detected = True
                        drift_details[key] = {
                            "baseline": round(baseline, 3),
                            "current": round(curr_acc, 3),
                            "drop": round(drop, 3),
                        }

            if drift_detected:
                report = {
                    "drift_detected": True,
                    "details": drift_details,
                    "timestamp": now.isoformat(),
                    "total_updates": self.total_online_updates,
                }
                self.drift_events.append(report)

                if self.event_bus:
                    await self.event_bus.publish(TradingEvent(
                        event_type=EventBus.MODEL_DRIFT,
                        source="OnlineLearningEngine",
                        payload=report,
                        priority=2,
                    ))

                for key in drift_details:
                    if key.startswith("regime_"):
                        regime = key[7:]
                        w = list(self.regime_accuracy.get(regime, []))
                        if w:
                            self.baseline_accuracy[key] = float(np.mean(w[-10:]))
                    else:
                        w = list(self.accuracy_window)
                        if w:
                            self.baseline_accuracy["global"] = float(np.mean(w[-20:]))

                return report

            return None

        except Exception as e:
            logger.error(f"Check model drift error: {e}")
            return None

    def get_feature_store_stats(self) -> dict:
        return {
            "total_records": len(self.feature_store),
            "pending_train": len(self.pending_train),
            "global_accuracy": round(self._get_accuracy("global"), 3),
            "regime_accuracy": {
                r: round(self._get_accuracy(f"regime_{r}"), 3) for r in REGIMES
            },
            "strategy_accuracy": {
                s: round(self._get_accuracy(f"strategy_{s}"), 3) for s in STRATEGIES
            },
            "total_online_updates": self.total_online_updates,
            "drift_events": len(self.drift_events),
            "degradation_alerts": len(self.degradation_alerts),
            "recent_drift": list(self.drift_events)[-3:],
        }


# ============================================================================
# MARKET REGIME CLASSIFIER (PRIME - С ЗАЩИТОЙ ОТ None)
# ============================================================================
class MarketRegimeClassifier:
    def __init__(self):
        self.regime_history: Dict[str, deque] = {}
        self.transition_matrix: Dict[str, Dict[str, float]] = {
            r: {r2: 0.0 for r2 in REGIMES} for r in REGIMES
        }
        self.transition_counts: Dict[str, Dict[str, int]] = {
            r: {r2: 0 for r2 in REGIMES} for r in REGIMES
        }
        self.regime_durations: Dict[str, deque] = {r: deque(maxlen=50) for r in REGIMES}
        self.classifier_nn = SimpleNeuralNet(input_size=20, hidden_sizes=[32, 16], output_size=len(REGIMES), lr=0.005)
        self.label_history: deque = deque(maxlen=200)

    def classify(self, symbol: str, candles: dict, indicators: dict) -> Tuple[str, float]:
        try:
            if symbol not in self.regime_history:
                self.regime_history[symbol] = deque(maxlen=100)

            features = self._build_classifier_features(candles, indicators)
            if features is None:
                logger.warning(f"Could not build features for {symbol}, using RANGING")
                return "RANGING", 0.5

            nn_output = self.classifier_nn.predict(features.reshape(1, -1))[0]
            nn_probs = self._softmax(nn_output)
            nn_regime_idx = int(np.argmax(nn_probs))
            nn_regime = REGIMES[nn_regime_idx]
            nn_confidence = float(nn_probs[nn_regime_idx])

            stat_regime, stat_confidence = self._statistical_classify(candles, indicators)

            if nn_confidence > 0.7:
                final_regime = nn_regime
                final_confidence = nn_confidence * 0.6 + stat_confidence * 0.4
            else:
                final_regime = stat_regime
                final_confidence = stat_confidence * 0.7 + nn_confidence * 0.3

            history = list(self.regime_history.get(symbol, []))
            if history:
                prev_regime = history[-1]
                trans_prob = self.transition_matrix.get(prev_regime, {}).get(final_regime, 0.1)
                if trans_prob > 0.3:
                    final_confidence = min(0.95, final_confidence * 1.1)
                elif trans_prob < 0.05:
                    final_confidence *= 0.85

            prev = self.regime_history[symbol][-1] if self.regime_history[symbol] else final_regime
            self.regime_history[symbol].append(final_regime)
            self._update_transition_matrix(prev, final_regime)

            return final_regime, round(float(np.clip(final_confidence, 0.3, 0.99)), 3)

        except Exception as e:
            logger.error(f"Regime classification error ({symbol}): {e}")
            return "RANGING", 0.5

    def _build_classifier_features(self, candles: dict, indicators: dict) -> Optional[np.ndarray]:
        """PRIME FIX #11: ЗАЩИТА ОТ None ВО ВСЕХ ПОЛЯХ"""
        try:
            features = []
            m15_ind = indicators.get("m15", {})
            h1_ind = indicators.get("h1", {})
            h4_ind = indicators.get("h4", {})

            # Безопасное получение значений с дефолтами
            close = m15_ind.get("current_close", 0)
            if close is None or close <= 0:
                # Пытаемся получить из h1
                close = h1_ind.get("current_close", 0)
                if close is None or close <= 0:
                    return None

            sma20 = m15_ind.get("sma_20", close)
            if sma20 is None:
                sma20 = close
            sma50 = m15_ind.get("sma_50", close)
            if sma50 is None:
                sma50 = close
            sma200 = h1_ind.get("sma_200", close)
            if sma200 is None:
                sma200 = close
            
            rsi_m15 = m15_ind.get("rsi", 50)
            if rsi_m15 is None:
                rsi_m15 = 50
            rsi_h1 = h1_ind.get("rsi", 50)
            if rsi_h1 is None:
                rsi_h1 = 50
            
            macd_m15 = m15_ind.get("macd", 0)
            if macd_m15 is None:
                macd_m15 = 0
            
            atr_m15 = m15_ind.get("atr", close * 0.001)
            if atr_m15 is None:
                atr_m15 = close * 0.001
            
            bb_upper = m15_ind.get("bollinger_upper", close)
            if bb_upper is None:
                bb_upper = close
            bb_lower = m15_ind.get("bollinger_lower", close)
            if bb_lower is None:
                bb_lower = close
            
            bb_width = (bb_upper - bb_lower) / (close + 1e-10)
            bb_pos = (close - bb_lower) / (bb_upper - bb_lower + 1e-10)

            features.extend([
                (close - sma20) / (sma20 + 1e-10),
                (sma20 - sma50) / (sma50 + 1e-10),
                (close - sma200) / (sma200 + 1e-10),
                (rsi_m15 - 50) / 50,
                (rsi_h1 - 50) / 50,
                macd_m15 / (close + 1e-10) * 1000,
                atr_m15 / (close + 1e-10) * 1000,
                bb_width,
                bb_pos - 0.5,
            ])

            m15_candles = candles.get("m15")
            if m15_candles is not None and len(m15_candles) >= 20:
                closes = np.array([c[4] for c in m15_candles[-20:]])
                returns = np.diff(np.log(closes + 1e-10))
                features.append(float(np.std(returns) * 100))
                features.append(float(np.mean(returns) * 100))
                features.append(float(np.max(closes) - np.min(closes)) / (close + 1e-10))
                features.append(float(closes[-1] - closes[-5]) / (closes[-5] + 1e-10))
                features.append(float(closes[-1] - closes[-10]) / (closes[-10] + 1e-10))
                volumes = np.array([c[5] for c in m15_candles[-20:]])
                avg_vol = float(np.mean(volumes[:-1]))
                features.append(float(volumes[-1]) / (avg_vol + 1e-10) - 1.0)
                body_sizes = np.abs(
                    np.array([c[4] for c in m15_candles[-10:]]) -
                    np.array([c[1] for c in m15_candles[-10:]])
                )
                features.append(float(np.mean(body_sizes)) / (close + 1e-10))
            else:
                features.extend([0.0] * 7)

            h4_ind_data = h4_ind if h4_ind else {}
            rsi_h4 = h4_ind_data.get("rsi", 50)
            if rsi_h4 is None:
                rsi_h4 = 50
            macd_h4 = h4_ind_data.get("macd", 0)
            if macd_h4 is None:
                macd_h4 = 0
            features.append((rsi_h4 - 50) / 50)
            features.append(macd_h4 / (close + 1e-10) * 1000)

            arr = np.array(features[:20], dtype=np.float32)
            if len(arr) < 20:
                arr = np.pad(arr, (0, 20 - len(arr)))
            return np.nan_to_num(np.clip(arr, -5.0, 5.0), nan=0.0)

        except Exception as e:
            logger.error(f"Build classifier features error: {e}")
            return None

    def _statistical_classify(self, candles: dict, indicators: dict) -> Tuple[str, float]:
        try:
            m15 = indicators.get("m15", {})
            close = m15.get("current_close", 0)
            if close <= 0:
                return "RANGING", 0.5

            atr = m15.get("atr", close * 0.001)
            rsi = m15.get("rsi", 50)
            macd = m15.get("macd", 0)
            sma20 = m15.get("sma_20", close)
            sma50 = m15.get("sma_50", close)
            bb_upper = m15.get("bollinger_upper", close)
            bb_lower = m15.get("bollinger_lower", close)
            bb_width = (bb_upper - bb_lower) / (close + 1e-10)

            volatility_score = atr / (close + 1e-10) * 1000
            trend_score = abs(sma20 - sma50) / (sma50 + 1e-10) * 100
            momentum_score = abs(rsi - 50) / 50

            if volatility_score > 3.0:
                return "VOLATILE", min(0.9, 0.5 + volatility_score / 10)

            if close > sma20 > sma50 and macd > 0 and rsi > 52:
                conf = 0.5 + trend_score * 2 + momentum_score * 0.2
                return "TRENDING_UP", min(0.92, conf)

            if close < sma20 < sma50 and macd < 0 and rsi < 48:
                conf = 0.5 + trend_score * 2 + momentum_score * 0.2
                return "TRENDING_DOWN", min(0.92, conf)

            if bb_width < 0.003:
                if close > bb_upper:
                    return "BREAKOUT", 0.75
                if close < bb_lower:
                    return "BREAKOUT", 0.75

            if rsi > 68 and macd < 0:
                return "REVERSAL", 0.70
            if rsi < 32 and macd > 0:
                return "REVERSAL", 0.70

            ranging_conf = 0.5 + (1.0 - trend_score) * 0.3
            return "RANGING", min(0.85, ranging_conf)

        except Exception as e:
            logger.error(f"Statistical classify error: {e}")
            return "RANGING", 0.5

    def _softmax(self, x: np.ndarray) -> np.ndarray:
        e = np.exp(x - np.max(x))
        return e / (e.sum() + 1e-10)

    def _update_transition_matrix(self, prev: str, current: str):
        if prev not in self.transition_counts:
            return
        self.transition_counts[prev][current] = self.transition_counts[prev].get(current, 0) + 1
        total = sum(self.transition_counts[prev].values())
        if total > 0:
            for regime in REGIMES:
                count = self.transition_counts[prev].get(regime, 0)
                self.transition_matrix[prev][regime] = count / total

    def train_on_labeled(self, features: np.ndarray, regime: str):
        if regime not in REGIMES:
            return
        target = np.zeros(len(REGIMES))
        target[REGIMES.index(regime)] = 1.0
        self.classifier_nn.train_step(features.reshape(1, -1), target.reshape(1, -1))
        self.label_history.append({"features": features.tolist(), "regime": regime})

    def get_regime_probabilities(self, symbol: str) -> Dict[str, float]:
        history = list(self.regime_history.get(symbol, []))
        if not history:
            return {r: 1.0 / len(REGIMES) for r in REGIMES}
        counts = {r: history.count(r) for r in REGIMES}
        total = len(history)
        return {r: round(counts[r] / total, 3) for r in REGIMES}

    def get_transition_stats(self) -> dict:
        return {
            "transition_matrix": {
                r: {r2: round(v, 3) for r2, v in row.items()}
                for r, row in self.transition_matrix.items()
            },
            "transition_counts": self.transition_counts,
        }


# ============================================================================
# SELF DEVELOPMENT ENGINE (PRIME - С 3 ИСТОЧНИКАМИ ДАННЫХ)
# ============================================================================
class SelfDevelopmentEngine:
    def __init__(self):
        self.knowledge_base: dict = {
            "market_patterns": {},
            "news_sentiment": {},
            "economic_events": [],
            "strategy_insights": {},
            "last_update": None,
        }
        self.update_interval = 3600
        self.last_update: Optional[datetime] = None
        self.development_log: deque = deque(maxlen=200)
        self.sentiment_scores: Dict[str, float] = {}
        self.economic_calendar: list = []
        self.insight_buffer: deque = deque(maxlen=50)
        self.improvement_suggestions: list = []

    async def run_development_cycle(self, market_intelligence: MarketIntelligence,
                                     strategy_engine: StrategyEngine,
                                     memory_engine: MemoryEngine):
        try:
            now = datetime.utcnow()
            if self.last_update and (now - self.last_update).seconds < 300:
                return

            await self._analyze_own_performance(memory_engine, strategy_engine)
            await self._update_market_knowledge(market_intelligence)
            await self._fetch_external_signals()
            await self._generate_insights(memory_engine, strategy_engine)
            await self._improve_strategy_weights(strategy_engine, memory_engine)

            self.last_update = now
            self.knowledge_base["last_update"] = now.isoformat()
            self.development_log.append({
                "timestamp": now.isoformat(),
                "event": "Development cycle completed",
            })
            logger.info("Self-development cycle completed")
        except Exception as e:
            logger.error(f"Self development cycle error: {e}")

    async def _analyze_own_performance(self, memory: MemoryEngine, strategy: StrategyEngine):
        try:
            summary = memory.get_summary()
            recent_perf = summary.get("recent_performance", {})
            avg_reward = recent_perf.get("avg_reward", 0.0)
            trend = recent_perf.get("trend", "NEUTRAL")

            for strat_name, perf in strategy.strategy_performance.items():
                if perf["count"] >= 10:
                    wr = perf["wins"] / perf["count"]
                    profit = perf["profit"]
                    key = strat_name
                    if key not in self.knowledge_base["strategy_insights"]:
                        self.knowledge_base["strategy_insights"][key] = {}
                    self.knowledge_base["strategy_insights"][key] = {
                        "win_rate": wr,
                        "total_profit": profit,
                        "count": perf["count"],
                        "quality": wr * (1 + max(0, profit / 1000)),
                    }

            if trend == "DECLINING":
                self.improvement_suggestions.append({
                    "type": "RISK_REDUCTION",
                    "reason": "Performance declining",
                    "timestamp": datetime.utcnow().isoformat(),
                })
            elif trend == "IMPROVING" and avg_reward > 0.5:
                self.improvement_suggestions.append({
                    "type": "RISK_INCREASE",
                    "reason": "Strong performance detected",
                    "timestamp": datetime.utcnow().isoformat(),
                })

            if len(self.improvement_suggestions) > 20:
                self.improvement_suggestions = self.improvement_suggestions[-20:]
        except Exception as e:
            logger.error(f"Analyze own performance error: {e}")

    async def _update_market_knowledge(self, market_intelligence: MarketIntelligence):
        try:
            for symbol, sd in market_intelligence.symbol_data.items():
                regime = sd.get("regime", "UNKNOWN")
                volatility = sd.get("volatility", 0)
                trend_str = sd.get("trend_strength", 0)

                if symbol not in self.knowledge_base["market_patterns"]:
                    self.knowledge_base["market_patterns"][symbol] = {
                        "regime_history": deque(maxlen=100),
                        "avg_volatility": volatility,
                        "dominant_regime": regime,
                    }
                pat = self.knowledge_base["market_patterns"][symbol]
                pat["regime_history"].append(regime)
                if pat["regime_history"]:
                    regime_counts = {}
                    for r in pat["regime_history"]:
                        regime_counts[r] = regime_counts.get(r, 0) + 1
                    pat["dominant_regime"] = max(regime_counts, key=regime_counts.get)
                    vol_list = [volatility]
                    pat["avg_volatility"] = float(np.mean(vol_list[-20:]))
        except Exception as e:
            logger.error(f"Update market knowledge error: {e}")

    async def _fetch_external_signals(self):
        """PRIME FIX #12: 3 ИСТОЧНИКА ДАННЫХ (был pass)"""
        # Источник 1: Crypto Fear & Greed Index
        try:
            import aiohttp
            async with aiohttp.ClientSession(timeout=aiohttp.ClientTimeout(total=5)) as session:
                async with session.get("https://api.alternative.me/fng/?limit=1") as resp:
                    if resp.status == 200:
                        data = await resp.json()
                        if data.get("data"):
                            fng = data["data"][0]
                            self.sentiment_scores["crypto_fear_greed"] = float(fng.get("value", 50)) / 100
                            self.knowledge_base["news_sentiment"]["crypto_fear_greed"] = {
                                "value": self.sentiment_scores["crypto_fear_greed"],
                                "classification": fng.get("value_classification", "Neutral"),
                                "source": "alternative.me",
                                "timestamp": datetime.utcnow().isoformat(),
                            }
                            logger.debug(f"FNG updated: {self.sentiment_scores['crypto_fear_greed']}")
        except ImportError:
            logger.warning("aiohttp not installed, skipping external API calls")
        except Exception as e:
            logger.warning(f"FNG API error (non-critical): {e}")

        # Источник 2: CoinGecko (для крипто-символов)
        try:
            import aiohttp
            async with aiohttp.ClientSession(timeout=aiohttp.ClientTimeout(total=5)) as session:
                async with session.get("https://api.coingecko.com/api/v3/global") as resp:
                    if resp.status == 200:
                        data = await resp.json()
                        if data.get("data"):
                            market_cap_change = data["data"].get("market_cap_change_percentage_24h_usd", 0)
                            self.sentiment_scores["crypto_market_cap_change"] = market_cap_change / 100
                            self.knowledge_base["news_sentiment"]["coingecko"] = {
                                "value": market_cap_change,
                                "source": "coingecko",
                                "timestamp": datetime.utcnow().isoformat(),
                            }
        except Exception as e:
            logger.debug(f"CoinGecko API error: {e}")

        # Источник 3: Альфа-Ванtage (если есть API ключ)
        alpha_vantage_key = os.getenv("ALPHA_VANTAGE_KEY", "")
        if alpha_vantage_key:
            try:
                import aiohttp
                async with aiohttp.ClientSession(timeout=aiohttp.ClientTimeout(total=5)) as session:
                    async with session.get(f"https://www.alphavantage.co/query?function=GLOBAL_QUOTE&symbol=SPY&apikey={alpha_vantage_key}") as resp:
                        if resp.status == 200:
                            data = await resp.json()
                            if "Global Quote" in data:
                                change_pct = data["Global Quote"].get("10. change percent", "0%")
                                change_pct = float(change_pct.replace("%", ""))
                                self.sentiment_scores["sp500_change"] = change_pct / 100
            except Exception as e:
                logger.debug(f"Alpha Vantage error: {e}")

    async def _generate_insights(self, memory: MemoryEngine, strategy: StrategyEngine):
        try:
            for symbol, patterns in memory.pattern_memory.items():
                if len(patterns) < 10:
                    continue
                recent = patterns[-20:]
                profits = [p["profit"] for p in recent]
                if not profits:
                    continue
                avg_profit = float(np.mean(profits))
                win_rate = len([p for p in profits if p > 0]) / len(profits)
                insight = {
                    "symbol_strategy": symbol,
                    "avg_profit": avg_profit,
                    "win_rate": win_rate,
                    "sample_size": len(recent),
                    "assessment": "POSITIVE" if avg_profit > 0 and win_rate > 0.5 else "NEGATIVE",
                    "timestamp": datetime.utcnow().isoformat(),
                }
                self.insight_buffer.append(insight)
        except Exception as e:
            logger.error(f"Generate insights error: {e}")

    async def _improve_strategy_weights(self, strategy_engine: StrategyEngine,
                                         memory_engine: MemoryEngine):
        try:
            insights_map = {}
            for insight in self.insight_buffer:
                key = insight["symbol_strategy"]
                if key not in insights_map:
                    insights_map[key] = []
                insights_map[key].append(insight)

            for strat_name in STRATEGIES:
                relevant_insights = [
                    ins for key, ins_list in insights_map.items()
                    for ins in ins_list if strat_name in key
                ]
                if not relevant_insights:
                    continue
                avg_wr = float(np.mean([i["win_rate"] for i in relevant_insights]))
                current_weight = strategy_engine.strategy_weights.get(strat_name, 1.0)
                target_weight = avg_wr * 2.0
                new_weight = current_weight * 0.9 + target_weight * 0.1
                strategy_engine.strategy_weights[strat_name] = float(np.clip(new_weight, 0.1, 3.0))
        except Exception as e:
            logger.error(f"Improve strategy weights error: {e}")

    def get_market_sentiment(self, symbol: str) -> float:
        if "BTC" in symbol.upper() or "ETH" in symbol.upper():
            fng = self.sentiment_scores.get("crypto_fear_greed", 0.5)
            return (fng - 0.5) * 2.0
        return 0.0

    def get_development_report(self) -> dict:
        return {
            "last_update": self.last_update.isoformat() if self.last_update else None,
            "knowledge_symbols": len(self.knowledge_base["market_patterns"]),
            "insights_count": len(self.insight_buffer),
            "improvements_pending": len(self.improvement_suggestions),
            "sentiment_signals": len(self.sentiment_scores),
            "recent_developments": list(self.development_log)[-5:],
        }


