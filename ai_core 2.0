# MASTER AI — ГЛАВНЫЙ КЛАСС (PRIME - ПОЛНОСТЬЮ ФУНКЦИОНАЛЬНЫЙ)
# ============================================================================
class MasterAI:
    def __init__(
        self,
        symbols: List[str],
        db_path: str,
        broadcast_callback: Optional[Callable[..., Coroutine]] = None,
        connection_id: str = "default",
    ):
        self.symbols = symbols
        self.db_path = db_path
        self.broadcast_callback = broadcast_callback
        self.connection_id = connection_id
        self.mt5 = get_mt5(connection_id)

        self.market_intelligence = MarketIntelligence()
        self.risk_engine = RiskEngine()
        self.strategy_engine = StrategyEngine()
        self.memory_engine = MemoryEngine(db_path)
        self.learning_engine = LearningEngine(state_size=50)
        self.self_development = SelfDevelopmentEngine()
        self.chat_engine = ChatEngine()
        self.decision_engine = DecisionEngine()

        self.is_initialized = False
        self.autotrade_running = False
        self.decision_cycles = 0
        self.current_trading_mode = "SHORT_TERM"
        self.current_strategy = "TREND_FOLLOW"
        self.current_regime = "RANGING"
        self.avg_confidence = 0.0
        self.total_training_steps = 0
        self.open_trades: Dict[int, dict] = {}

        self._candles_cache: Dict[str, dict] = {}
        self._last_states: Dict[str, np.ndarray] = {}
        self._last_actions: Dict[str, int] = {}
        self._cycle_delay = 5.0
        self._volatility_cache: Dict[str, float] = {}
        self._trend_cache: Dict[str, float] = {}
        self._training_task: Optional[asyncio.Task] = None

        self.event_bus = EventBus()
        self.advanced_risk_engine = AdvancedRiskEngine(event_bus=self.event_bus)
        self.online_learning_engine = OnlineLearningEngine(feature_dim=50, event_bus=self.event_bus)
        self.persistence_layer = PersistenceLayer(base_dir=".", db_path=db_path)
        self.execution_safety = ExecutionSafetyLayer(event_bus=self.event_bus)
        self.analytics_engine = PerformanceAnalyticsEngine()
        self.signal_aggregator = SignalAggregator()
        self.position_tracker = PositionTracker()
        self.regime_classifier = MarketRegimeClassifier()
        self._regime_confidence: Dict[str, float] = {}

        self.execution_ledger = ExecutionLedger(db_path)
        self.idempotency_manager = IdempotencyManager(self.execution_ledger)
        self.atomic_pipeline = AtomicExecutionPipeline(
            ledger=self.execution_ledger,
            idempotency_manager=self.idempotency_manager,
            event_bus=self.event_bus,
        )
        self.reconciliation_engine = ReconciliationEngine(
            ledger=self.execution_ledger,
            get_broker_positions_fn=self.mt5.get_positions,
            event_bus=self.event_bus,
        )
        self.circuit_breaker = CircuitBreakerSystem(db_path, self.event_bus)
        self.execution_observability = ExecutionObservability(db_path)
        self.confirmation_loop = ExecutionConfirmationLoop(
            ledger=self.execution_ledger,
            get_position_fn=self.mt5.get_position_by_ticket,
            event_bus=self.event_bus,
        )
        self.failure_resilience = FailureResilienceLayer(
            db_path=db_path,
            mt5_connect_fn=self.mt5.connect,
            mt5_is_connected_fn=lambda: self.mt5.connected,
            event_bus=self.event_bus,
        )
        self.startup_recovery = StartupRecoverySequence(
            ledger=self.execution_ledger,
            reconciliation_engine=self.reconciliation_engine,
            circuit_breaker=self.circuit_breaker,
            execution_safety=self.execution_safety,
            event_bus=self.event_bus,
        )

        self._last_autosave: datetime = datetime.utcnow()
        self._autosave_interval_seconds: float = 600.0

        self.event_bus.subscribe(EventBus.KILL_SWITCH, self._on_kill_switch_event)
        self.event_bus.subscribe(EventBus.DRAWDOWN_BREACH, self._on_drawdown_breach_event)
        self.event_bus.subscribe(EventBus.RISK_ALERT, self._on_risk_alert_event)
        self.event_bus.subscribe(EventBus.MODEL_DRIFT, self._on_model_drift_event)
        self.event_bus.subscribe(EventBus.PERFORMANCE_ALERT, self._on_performance_alert_event)
        self.event_bus.subscribe(EventBus.OVERTRADING_ALERT, self._on_overtrading_alert_event)

        logger.info(f"MasterAI instance created for connection {connection_id}")

    async def initialize(self):
        if not self.mt5.connected and MT5_AVAILABLE:
            logger.info(f"Connecting to MT5 for {self.connection_id}...")
            if not self.mt5.connect(MT5_LOGIN, MT5_PASSWORD, MT5_SERVER):
                logger.error(f"Failed to connect MT5 for {self.connection_id}")
                return False
        elif not MT5_AVAILABLE:
            logger.warning(f"MT5 not available for {self.connection_id}, running in simulation mode")
        
        self._load_state_from_db()
        self._training_task = asyncio.create_task(self._continuous_training_loop())
        await self.event_bus.start()

        load_results = await self.persistence_layer.load_all(self)
        logger.info(f"Persistence load results: {load_results}")

        await self.reconciliation_engine.start()
        await self.confirmation_loop.start()
        await self.failure_resilience.start()

        asyncio.create_task(self._autosave_loop())
        asyncio.create_task(self._risk_monitoring_loop())
        asyncio.create_task(self._drift_monitor_loop())
        asyncio.create_task(self._self_development_loop())

        success, message = await self.startup_recovery.execute()

        if not success:
            logger.critical(f"STARTUP RECOVERY FAILED: {message}")
            logger.critical("TRADING WILL NOT BE ENABLED")
            await self.execution_safety.activate_kill_switch(f"Startup recovery failed: {message}")
            return False
        else:
            logger.info(f"Startup recovery successful: {message}")
            logger.info("TRADING ENABLED - System ready for live execution")

        await self.event_bus.publish(TradingEvent(
            event_type=EventBus.SYSTEM_READY,
            source="MasterAI",
            payload={"symbols": self.symbols, "load_results": load_results, "recovery_message": message},
            priority=1,
        ))

        self.is_initialized = True
        logger.info(f"MasterAI fully initialized for {self.connection_id}")
        return True

    async def _self_development_loop(self):
        logger.info("Self-development loop started")
        while True:
            try:
                await self.self_development.run_development_cycle(
                    market_intelligence=self.market_intelligence,
                    strategy_engine=self.strategy_engine,
                    memory_engine=self.memory_engine,
                )
                await asyncio.sleep(300)
            except asyncio.CancelledError:
                break
            except Exception as e:
                logger.error(f"Self-development loop error: {e}")
                await asyncio.sleep(60)

    async def _continuous_training_loop(self):
        logger.info("Continuous training loop started")
        while True:
            try:
                if len(self.memory_engine.episode_buffer) >= 32:
                    await self.learning_engine.train_agents(self.memory_engine)
                    self.total_training_steps += 1
                await asyncio.sleep(30)
            except asyncio.CancelledError:
                break
            except Exception as e:
                logger.error(f"Training loop error: {e}")
                await asyncio.sleep(60)

    async def _autosave_loop(self):
        while True:
            try:
                await asyncio.sleep(self._autosave_interval_seconds)
                now = datetime.utcnow()
                if (now - self._last_autosave).total_seconds() >= self._autosave_interval_seconds:
                    results = await self.persistence_layer.save_all(self)
                    self._last_autosave = now
                    self.persistence_layer.cleanup_old_states(keep_last=10)
                    logger.info(f"Auto-save completed: {results}")
            except asyncio.CancelledError:
                break
            except Exception as e:
                logger.error(f"Auto-save error: {e}")
                await asyncio.sleep(60)

    async def _risk_monitoring_loop(self):
        logger.info("Risk monitoring loop started")
        while True:
            try:
                await asyncio.sleep(30)
                positions = self.mt5.get_positions()
                account = self.mt5.get_account_info()

                if account:
                    for symbol in self.symbols:
                        candles = self._candles_cache.get(symbol, {})
                        m15 = candles.get("m15")
                        if m15 and len(m15) >= 2:
                            try:
                                closes = [c[4] for c in m15[-5:]]
                                if len(closes) >= 2 and closes[-2] > 0:
                                    ret = (closes[-1] - closes[-2]) / closes[-2]
                                    self.advanced_risk_engine.record_symbol_return(symbol, ret)
                            except Exception:
                                pass

                    await self.advanced_risk_engine.emit_risk_alerts(self.event_bus, positions, account)

                    balance = account.get("balance", 0)
                    equity = account.get("equity", balance)
                    if balance > 0:
                        dd = (balance - equity) / balance
                        if dd > 0.20 and not self.execution_safety.kill_switch_active:
                            await self.execution_safety.activate_kill_switch(f"Drawdown {dd:.2%} > 20%")
            except asyncio.CancelledError:
                break
            except Exception as e:
                logger.error(f"Risk monitoring error: {e}")
                await asyncio.sleep(30)

    async def _drift_monitor_loop(self):
        logger.info("Drift monitor loop started")
        while True:
            try:
                await asyncio.sleep(120)
                drift = await self.online_learning_engine.check_model_drift()
                if drift:
                    logger.warning(f"Model drift detected: {drift}")
                degradation = await self.online_learning_engine.check_performance_degradation(self.memory_engine)
                if degradation and degradation.get("degraded"):
                    logger.warning(f"Performance degradation: {degradation}")
                await self.online_learning_engine.batch_train(n=64)
            except asyncio.CancelledError:
                break
            except Exception as e:
                logger.error(f"Drift monitor error: {e}")
                await asyncio.sleep(60)

    def _load_state_from_db(self):
        try:
            conn = sqlite3.connect(self.db_path, timeout=10)
            c = conn.cursor()
            c.execute("CREATE TABLE IF NOT EXISTS trades (ticket INTEGER PRIMARY KEY, symbol TEXT, order_type TEXT, volume REAL, open_price REAL, sl REAL, tp REAL, strategy TEXT, ai_reasoning TEXT, status TEXT, open_time TEXT)")
            c.execute("SELECT ticket, symbol, order_type, volume, open_price, sl, tp, strategy, ai_reasoning FROM trades WHERE status='OPEN'")
            for row in c.fetchall():
                self.open_trades[row[0]] = {
                    "ticket": row[0], "symbol": row[1], "order_type": row[2],
                    "volume": row[3], "open_price": row[4], "sl": row[5],
                    "tp": row[6], "strategy": row[7], "ai_reasoning": row[8],
                    "open_time": datetime.utcnow().isoformat(),
                }
            conn.close()
            logger.info(f"Loaded {len(self.open_trades)} open trades from DB")
        except Exception as e:
            logger.error(f"Load state error: {e}")

    async def update_market_data(self, symbol: str, tick: dict, candles: dict):
        self.market_intelligence.update(symbol, tick, candles)
        clean_candles = {tf: c for tf, c in candles.items() if c is not None and len(c) > 0}
        if clean_candles:
            self._candles_cache[symbol] = clean_candles
        sd = self.market_intelligence.symbol_data.get(symbol, {})
        self._volatility_cache[symbol] = sd.get("volatility", 0.0)
        self._trend_cache[symbol] = sd.get("trend_strength", 0.0)

        try:
            if candles and any(v is not None for v in candles.values()):
                indicators = self.market_intelligence.get_technical_indicators(symbol, candles)
                regime, conf = self.regime_classifier.classify(symbol, candles, indicators)
                self._regime_confidence[symbol] = conf
                features = self.regime_classifier._build_classifier_features(candles, indicators)
                if features is not None:
                    self.regime_classifier.train_on_labeled(features, regime)

            new_regime = self.market_intelligence.symbol_data.get(symbol, {}).get("regime", "RANGING")
            if new_regime != self.current_regime and new_regime != "UNKNOWN":
                old_regime = self.current_regime
                self.current_regime = new_regime
                await self.event_bus.publish(TradingEvent(
                    event_type=EventBus.REGIME_CHANGED,
                    source="MasterAI",
                    payload={"symbol": symbol, "prev_regime": old_regime, "new_regime": new_regime},
                    priority=1,
                ))
        except Exception as e:
            logger.error(f"Update market data error: {e}")

    async def think_and_decide(self, positions: list, account: dict, market_data: dict) -> List[dict]:
        self.decision_cycles += 1
        raw_decisions = []

        try:
            if not account:
                return raw_decisions

            can_trade, reason = self.circuit_breaker.can_trade()
            if not can_trade:
                logger.warning(f"Circuit breaker blocks trading: {reason}")
                return []

            balance = account.get("balance", 10000)
            equity = account.get("equity", balance)
            self.risk_engine.update_equity(equity, balance)
            self.circuit_breaker.update_metrics(equity)

            confidences = []

            for symbol in self.symbols:
                try:
                    candles = self._candles_cache.get(symbol)
                    if not candles:
                        continue

                    indicators = self.market_intelligence.get_technical_indicators(symbol, candles)
                    if not indicators:
                        continue

                    state = self.market_intelligence.build_state_vector(symbol, candles, account)
                    if state is None or len(state) == 0:
                        continue

                    market_summary = self.market_intelligence.get_market_summary(symbol)
                    regime = market_summary.get("regime", "RANGING")
                    volatility = market_summary.get("volatility", 0.0)
                    trend_strength = market_summary.get("trend_strength", 0.0)
                    momentum = market_summary.get("momentum", 0.0)
                    rsi_m15 = indicators.get("m15", {}).get("rsi", 50)

                    strategy = self.strategy_engine.select_strategy(
                        regime=regime, volatility=volatility,
                        trend_strength=trend_strength, momentum=momentum,
                        rsi=rsi_m15, win_rate=self.risk_engine.win_rate,
                    )

                    trading_mode = self.strategy_engine.select_trading_mode(regime, volatility)
                    self.current_trading_mode = trading_mode
                    self._cycle_delay = self.strategy_engine.get_cycle_delay_for_mode(trading_mode)

                    signal = self.strategy_engine.generate_signal(strategy, indicators, regime)

                    rl_action, rl_quality = self.learning_engine.get_action_recommendation(symbol, state)

                    pattern_quality = self.memory_engine.get_pattern_quality(symbol, strategy, regime)

                    sentiment = self.self_development.get_market_sentiment(symbol)

                    # Передаём market_intelligence в market_data для доступа к уровням
                    market_data_with_intel = market_data.copy()
                    market_data_with_intel["market_intelligence"] = self.market_intelligence

                    decision = self.decision_engine.make_decision(
                        symbol=symbol, state=state, signal=signal,
                        rl_action=rl_action, rl_quality=rl_quality,
                        market_data=market_data_with_intel, positions=positions, account=account,
                        risk_engine=self.risk_engine, strategy=strategy, regime=regime,
                        indicators=indicators, pattern_quality=pattern_quality, sentiment=sentiment,
                    )

                    self._last_states[symbol] = state
                    self._last_actions[symbol] = rl_action

                    if decision:
                        raw_decisions.append(decision)
                    confidences.append(signal.get("confidence", 0.0))
                    self.current_strategy = strategy
                    self.current_regime = regime

                except Exception as e:
                    logger.error(f"Think error for {symbol}: {e}")
                    continue

            if confidences:
                self.avg_confidence = float(np.mean(confidences))

            if self.decision_cycles % 10 == 0:
                await self.learning_engine.train_agents(self.memory_engine)

            for position in positions:
                symbol = position.get("symbol", "")
                ticket = position.get("ticket")
                if not ticket:
                    continue
                candles = self._candles_cache.get(symbol, {})
                m15_ind = self.market_intelligence.get_technical_indicators(symbol, candles).get("m15", {}) if candles else {}
                current_price = m15_ind.get("current_close", 0)
                if current_price <= 0:
                    md = market_data.get(symbol, {})
                    tick = md.get("tick", md)
                    current_price = tick.get("bid", 0)
                atr = m15_ind.get("atr", current_price * 0.001 if current_price > 0 else 0.001)
                if current_price > 0:
                    self.position_tracker.update_position(position, current_price, atr)

            if balance > 0:
                self.analytics_engine.record_equity_point(equity, balance, datetime.utcnow())

            safe_decisions = []
            for decision in raw_decisions:
                try:
                    symbol = decision.get("symbol", "")
                    action = decision.get("action", "")

                    allowed, reason = await self.execution_safety.is_execution_allowed(decision, positions, account)
                    if not allowed:
                        logger.debug(f"Decision blocked: {symbol}/{action} — {reason}")
                        continue

                    candles = self._candles_cache.get(symbol, {})
                    m15_ind = self.market_intelligence.get_technical_indicators(symbol, candles).get("m15", {}) if candles else {}
                    entry_price = m15_ind.get("current_close", decision.get("entry_price", 0))
                    sl_price = decision.get("sl", 0.0)
                    base_volume = decision.get("volume", 0.01)

                    if entry_price > 0:
                        adj_volume, size_reason = self.advanced_risk_engine.suggest_position_size(
                            symbol, account, positions, entry_price, sl_price, base_volume
                        )
                        decision["volume"] = adj_volume
                        decision["volume_adjusted_reason"] = size_reason

                    state = self._last_states.get(symbol)
                    if state is not None:
                        regime = decision.get("market_regime", self.current_regime)
                        strategy_val = decision.get("strategy", self.current_strategy)
                        win_prob, ml_confidence = self.online_learning_engine.predict_trade_quality(
                            state, regime, strategy_val
                        )
                        decision["ml_win_probability"] = win_prob
                        if win_prob < 0.35 and ml_confidence > 0.6:
                            logger.debug(f"Decision blocked by ML: {symbol} win_prob={win_prob:.2f}")
                            continue

                    safe_decisions.append(decision)

                except Exception as e:
                    logger.error(f"Decision filter error: {e}")
                    continue

            for decision in safe_decisions:
                if decision.get("action") in ["OPEN_BUY", "OPEN_SELL"]:
                    async def mt5_wrapper(d):
                        action_type = d["action"].replace("OPEN_", "")
                        return self.mt5.open_order(
                            d["symbol"], action_type, d["volume"],
                            d.get("sl", 0.0), d.get("tp", 0.0)
                        )
                    success, result = await self.atomic_pipeline.execute(decision, mt5_wrapper)
                    if success:
                        await self.on_trade_opened(result.get("ticket"), decision)
                        self.execution_observability.record_latency(result.get("trace_id", "unknown"), 0, decision["symbol"])
                        self.circuit_breaker.update_metrics(equity, execution_success=True)
                    else:
                        self.circuit_breaker.update_metrics(equity, execution_success=False)

            return safe_decisions

        except Exception as e:
            logger.error(f"Think and decide critical error: {e}")
            return []

    async def manage_open_positions(self, positions: list, account: dict, market_data: dict,
                                      modify_fn: Callable, close_fn: Callable):
        for position in positions:
            try:
                symbol = position.get("symbol")
                if not symbol:
                    continue

                candles = self._candles_cache.get(symbol)
                if not candles:
                    continue

                indicators = self.market_intelligence.get_technical_indicators(symbol, candles)
                market_summary = self.market_intelligence.get_market_summary(symbol)
                regime = market_summary.get("regime", "RANGING")

                m15 = indicators.get("m15", {})
                current_price = m15.get("current_close", 0)
                if current_price <= 0:
                    md = market_data.get(symbol, {})
                    tick = md.get("tick", md)
                    current_price = tick.get("bid", 0) or tick.get("ask", 0)
                if current_price <= 0:
                    continue

                mgmt_decision = self.decision_engine.make_position_management_decision(
                    position, current_price, indicators, regime, self.risk_engine, account
                )

                if mgmt_decision is None:
                    continue

                ticket = mgmt_decision.get("ticket")
                action = mgmt_decision.get("action")

                if action == "MODIFY_SLTP" and ticket:
                    result = modify_fn(ticket=ticket, sl=mgmt_decision.get("new_sl", 0.0), tp=mgmt_decision.get("new_tp", 0.0))
                    if result.get("success"):
                        logger.info(f"Position {ticket} modified: {mgmt_decision.get('reasoning')}")

                elif action == "CLOSE" and ticket:
                    result = close_fn(ticket=ticket)
                    if result.get("success"):
                        profit = result.get("profit", 0.0)
                        await self.on_trade_closed(ticket, profit)

            except Exception as e:
                logger.error(f"Position management error: {e}")

    async def on_trade_opened(self, ticket: int, trade: dict):
        self.open_trades[ticket] = trade
        symbol = trade.get("symbol", "")
        state = self._last_states.get(symbol)
        action = self._last_actions.get(symbol, 0)

        if state is not None:
            zero_next = np.zeros_like(state)
            self.memory_engine.store_experience(state, action, 0.0, zero_next, False,
                                                 metadata={"symbol": symbol, "ticket": ticket})

        self.execution_safety.on_trade_executed(symbol, trade.get("order_type", "BUY"), {"ticket": ticket})

        await self.event_bus.publish(TradingEvent(
            event_type=EventBus.TRADE_OPENED,
            source="MasterAI",
            payload={
                "ticket": ticket, "symbol": symbol, "action": trade.get("order_type"),
                "volume": trade.get("volume"), "open_price": trade.get("open_price"),
                "strategy": trade.get("strategy"),
            },
            priority=2,
        ))

        if state is not None:
            record = FeatureRecord(
                timestamp=datetime.utcnow().isoformat(),
                symbol=symbol,
                regime=self.current_regime,
                strategy=self.current_strategy,
                features=state.tolist(),
                label=0,
                confidence=trade.get("confidence", 0.5),
                profit=0.0,
            )
            self.online_learning_engine.store_feature(record)

        logger.info(f"Trade opened: ticket={ticket} symbol={symbol}")

    async def on_trade_closed(self, ticket: int, profit: float):
        trade = self.open_trades.pop(ticket, {"ticket": ticket, "profit": profit})
        symbol = trade.get("symbol", "")
        strategy = trade.get("strategy", "UNKNOWN")

        self.risk_engine.record_trade_result(profit, 10000)
        self.strategy_engine.record_result(strategy, profit)

        open_time_str = trade.get("open_time", datetime.utcnow().isoformat())
        try:
            open_time = datetime.fromisoformat(open_time_str)
            duration_hours = (datetime.utcnow() - open_time).total_seconds() / 3600
        except Exception:
            duration_hours = 1.0

        reward = self.memory_engine.calculate_reward({"profit": profit, "balance": 10000, "duration_hours": duration_hours})

        state = self._last_states.get(symbol, np.zeros(50))
        action = self._last_actions.get(symbol, 0)
        next_state = np.zeros_like(state)

        self.memory_engine.store_experience(state, action, reward, next_state, True,
                                             metadata={"symbol": symbol, "ticket": ticket, "profit": profit, "strategy": strategy})
        self.memory_engine.record_trade({"ticket": ticket, "symbol": symbol, "profit": profit, "strategy": strategy, "regime": self.current_regime})

        await self.learning_engine.train_agents(self.memory_engine)
        self.execution_safety.on_trade_closed(symbol, profit)

        if state is not None:
            label = 1 if profit > 0 else 0
            record = FeatureRecord(
                timestamp=datetime.utcnow().isoformat(),
                symbol=symbol,
                regime=self.current_regime,
                strategy=self.current_strategy,
                features=state.tolist(),
                label=label,
                confidence=0.5,
                profit=profit,
            )
            self.online_learning_engine.online_update(record)

        final_metrics = self.position_tracker.remove_position(ticket)
        if final_metrics:
            trade_record = {
                "ticket": ticket, "profit": profit, "symbol": final_metrics.get("symbol", "UNKNOWN"),
                "strategy": self.current_strategy, "regime": self.current_regime,
                "open_time": final_metrics.get("open_time", datetime.utcnow().isoformat()),
                "close_time": datetime.utcnow().isoformat(),
                "peak_profit": final_metrics.get("peak_profit", 0.0),
                "mae": final_metrics.get("max_adverse_excursion", 0.0),
                "mfe": final_metrics.get("max_favorable_excursion", 0.0),
                "age_hours": final_metrics.get("age_hours", 0.0),
            }
            self.analytics_engine.record_trade_result(trade_record)

            candles = self._candles_cache.get(symbol, {})
            if candles:
                indicators = self.market_intelligence.get_technical_indicators(symbol, candles)
                features = self.regime_classifier._build_classifier_features(candles, indicators)
                if features is not None:
                    regime_to_label = self.current_regime if profit > 0 else "VOLATILE"
                    self.regime_classifier.train_on_labeled(features, regime_to_label)

        await self.event_bus.publish(TradingEvent(
            event_type=EventBus.TRADE_CLOSED,
            source="MasterAI",
            payload={"ticket": ticket, "symbol": symbol, "profit": profit, "strategy": self.current_strategy, "regime": self.current_regime},
            priority=2,
        ))

        logger.info(f"Trade closed: ticket={ticket} profit={profit:.2f} reward={reward:.3f}")

    async def chat(self, message: str, context: dict) -> dict:
        msg_lower = message.lower()

        if any(kw in msg_lower for kw in ["аналитик", "analytics", "equity", "sharpe", "sortino"]):
            report = await self.get_analytics_report()
            perf = report.get("performance", {})
            reply = (
                f"📊 **Deep Analytics Report:**\n"
                f"Sharpe Ratio: **{perf.get('sharpe_ratio', 0):.3f}**\n"
                f"Sortino Ratio: **{perf.get('sortino_ratio', 0):.3f}**\n"
                f"Profit Factor: **{perf.get('profit_factor', 0):.3f}**\n"
                f"Calmar Ratio: **{perf.get('calmar_ratio', 0):.3f}**\n"
                f"Max Drawdown: **{perf.get('max_drawdown_ever', 0):.2%}**\n"
                f"Win Rate: **{perf.get('win_rate', 0):.1%}**\n"
                f"Total Trades: **{perf.get('total_trades', 0)}**"
            )
            return {"reply": reply, "reasoning": ["Analytics query"]}

        if any(kw in msg_lower for kw in ["тепло", "heat", "портфель риск"]):
            pos_summary = self.position_tracker.get_positions_summary()
            heat = pos_summary.get("portfolio_heat", 0)
            heat_emoji = "🔴" if heat > 0.7 else "🟡" if heat > 0.4 else "🟢"
            reply = f"{heat_emoji} **Portfolio Heat: {heat:.1%}**\nОткрытых позиций: {pos_summary.get('count', 0)}"
            return {"reply": reply, "reasoning": ["Portfolio heat query"]}

        if any(kw in msg_lower for kw in ["режим", "regime", "классификац"]):
            regime_lines = [f"**{sym}**: {self.current_regime} ({self._regime_confidence.get(sym, 0.5):.1%})" for sym in self.symbols]
            reply = "🎯 **Market Regime Classification:**\n" + "\n".join(regime_lines)
            return {"reply": reply, "reasoning": ["Regime classification"]}

        if any(kw in msg_lower for kw in ["сигнал", "signal", "таймфрейм"]):
            sig_lines = []
            for sym in self.symbols:
                consistency = self.signal_aggregator.get_signal_consistency(sym)
                bar = "█" * int(consistency * 10) + "░" * (10 - int(consistency * 10))
                sig_lines.append(f"**{sym}**: [{bar}] {consistency:.1%}")
            reply = "📡 **Signal Consistency:**\n" + "\n".join(sig_lines)
            return {"reply": reply, "reasoning": ["Signal consistency"]}

        return self.chat_engine.generate_response(
            message=message,
            context=context,
            ai_status=self.get_status(),
            memory_summary=self.memory_engine.get_summary(),
            risk_report=self.risk_engine.get_risk_report(),
            development_report=self.self_development.get_development_report(),
        )

    def get_status(self) -> dict:
        analytics_report = self.analytics_engine.get_full_report()
        position_summary = self.position_tracker.get_positions_summary()

        return {
            "is_initialized": self.is_initialized,
            "autotrade_running": self.autotrade_running,
            "decision_cycles": self.decision_cycles,
            "trading_mode": self.current_trading_mode,
            "current_strategy": self.current_strategy,
            "current_regime": self.current_regime,
            "avg_confidence": round(self.avg_confidence, 4),
            "training_steps": self.total_training_steps,
            "open_trades_count": len(self.open_trades),
            "analytics": analytics_report,
            "position_tracking": position_summary,
            "sharpe_ratio": analytics_report.get("sharpe_ratio", 0.0),
            "profit_factor": analytics_report.get("profit_factor", 0.0),
            "connection_id": self.connection_id,
        }

    async def get_analytics_report(self) -> dict:
        return {
            "performance": self.analytics_engine.get_full_report(),
            "equity_curve": self.analytics_engine.get_equity_curve(last_n=100),
            "position_tracking": self.position_tracker.get_positions_summary(),
            "regime_stats": {
                sym: {
                    "probabilities": self.regime_classifier.get_regime_probabilities(sym),
                    "confidence": self._regime_confidence.get(sym, 0.5),
                }
                for sym in self.symbols
            },
            "signal_consistency": {sym: self.signal_aggregator.get_signal_consistency(sym) for sym in self.symbols},
            "timestamp": datetime.utcnow().isoformat(),
            "connection_id": self.connection_id,
        }

    async def manual_kill_switch(self, activate: bool, reason: str = "manual") -> dict:
        if activate:
            await self.execution_safety.activate_kill_switch(reason)
            return {"status": "activated", "reason": reason}
        else:
            success = self.execution_safety.deactivate_kill_switch(manual=True)
            return {"status": "deactivated" if success else "not_active"}

    async def emergency_flatten(self) -> dict:
        async def close_all():
            positions = self.mt5.get_positions()
            results = []
            for pos in positions:
                result = self.mt5.close_position(pos.get("ticket"))
                results.append(result)
            return {"closed": len(results), "results": results}
        return await self.circuit_breaker.emergency_flatten(close_all)

    def get_cycle_delay(self) -> float:
        return self._cycle_delay

    async def on_autotrade_start(self):
        self.autotrade_running = True
        logger.info(f"Autotrade started for {self.connection_id}")

    async def on_autotrade_stop(self):
        self.autotrade_running = False
        logger.info(f"Autotrade stopped for {self.connection_id}")

    async def get_full_institutional_report(self) -> dict:
        return {
            "timestamp": datetime.utcnow().isoformat(),
            "system_status": self.get_status(),
            "analytics": await self.get_analytics_report(),
            "risk": self.advanced_risk_engine.get_full_risk_report(),
            "safety": self.execution_safety.get_safety_report(),
            "learning": self.online_learning_engine.get_feature_store_stats(),
            "events": self.event_bus.get_stats(),
            "execution": {
                "ledger": await self.execution_ledger.get_stats(),
                "circuit_breaker": await self.circuit_breaker.get_status(),
            },
            "connection_id": self.connection_id,
        }

    async def shutdown(self):
        logger.info(f"Shutting down MasterAI for {self.connection_id}...")
        await self.persistence_layer.save_all(self)
        await self.reconciliation_engine.stop()
        await self.confirmation_loop.stop()
        await self.failure_resilience.stop()
        await self.event_bus.stop()
        self.autotrade_running = False
        if self._training_task:
            self._training_task.cancel()
        self.mt5.disconnect()
        logger.info(f"MasterAI shutdown complete for {self.connection_id}")

    async def _on_kill_switch_event(self, event: TradingEvent):
        logger.critical(f"Kill switch event: {event.payload.get('reason')}")
        self.autotrade_running = False

    async def _on_drawdown_breach_event(self, event: TradingEvent):
        logger.warning(f"Drawdown breach: {event.payload.get('drawdown', 0):.2%}")
        self.risk_engine.risk_multiplier = max(0.2, self.risk_engine.risk_multiplier * 0.7)

    async def _on_risk_alert_event(self, event: TradingEvent):
        logger.warning(f"Risk alert: {event.payload}")

    async def _on_model_drift_event(self, event: TradingEvent):
        logger.warning(f"Model drift: {event.payload.get('details', {})}")

    async def _on_performance_alert_event(self, event: TradingEvent):
        logger.warning(f"Performance alert: {event.payload}")

    async def _on_overtrading_alert_event(self, event: TradingEvent):
        logger.warning(f"Overtrading alert: {event.payload.get('reason')}")


# ============================================================================
# МУЛЬТИПОДКЛЮЧЕНИЕ ДЛЯ САЙТА
# ============================================================================

class MultiConnectionManager:
    def __init__(self):
        self.connections: Dict[str, MasterAI] = {}
        self._lock = asyncio.Lock()
        
    async def get_or_create(self, connection_id: str, symbols: List[str] = None, 
                            db_path: str = None) -> MasterAI:
        async with self._lock:
            if connection_id not in self.connections:
                db_path = db_path or f"trading_{connection_id}.db"
                symbols = symbols or ["EURUSD", "GBPUSD", "USDJPY", "XAUUSD"]
                ai = MasterAI(symbols, db_path, connection_id=connection_id)
                success = await ai.initialize()
                if not success:
                    logger.error(f"Failed to initialize AI for {connection_id}")
                    raise RuntimeError(f"Failed to initialize AI for {connection_id}")
                self.connections[connection_id] = ai
                logger.info(f"Created new connection: {connection_id}")
            return self.connections[connection_id]
    
    async def remove(self, connection_id: str):
        async with self._lock:
            if connection_id in self.connections:
                await self.connections[connection_id].shutdown()
                del self.connections[connection_id]
                logger.info(f"Removed connection: {connection_id}")
    
    async def get_all_status(self) -> dict:
        async with self._lock:
            return {
                conn_id: ai.get_status()
                for conn_id, ai in self.connections.items()
            }
    
    async def broadcast(self, message: str, context: dict) -> dict:
        async with self._lock:
            results = {}
            for conn_id, ai in self.connections.items():
                ctx = context.copy()
                ctx["connection_id"] = conn_id
                results[conn_id] = await ai.chat(message, ctx)
            return results
    
    async def shutdown_all(self):
        async with self._lock:
            for conn_id, ai in list(self.connections.items()):
                await ai.shutdown()
            self.connections.clear()
            logger.info("All connections shut down")


connection_manager = MultiConnectionManager()


# ============================================================================
# ФУНКЦИИ ЗАПУСКА
# ============================================================================

async def main():
    logger.info("Starting Master AI with multi-connection support...")
    try:
        ai_default = await connection_manager.get_or_create("default")
        logger.info("MASTER AI PRIME VERSION RUNNING — ALL STUB FUNCTIONS REPLACED")
        while True:
            status = ai_default.get_status()
            logger.info(f"Status: {status.get('current_strategy', 'N/A')} - {status.get('current_regime', 'N/A')} - "
                       f"Trades: {status.get('open_trades_count', 0)}")
            await asyncio.sleep(60)
    except KeyboardInterrupt:
        logger.info("Interrupted")
        await connection_manager.shutdown_all()
    except Exception as e:
        logger.error(f"Fatal error: {e}")
        await connection_manager.shutdown_all()


if __name__ == "__main__":
    asyncio.run(main())
