# CHAT ENGINE (ПОЛНЫЙ - БЕЗ ИЗМЕНЕНИЙ)
# ============================================================================
class ChatEngine:
    def __init__(self):
        self.conversation_history: deque = deque(maxlen=50)
        self.personality = {
            "name": "MASTER AI",
            "style": "analytical",
            "confidence_threshold": 0.65,
        }

    def _format_number(self, n, decimals=2) -> str:
        if n is None:
            return "N/A"
        try:
            return f"{float(n):+.{decimals}f}" if float(n) != 0 else "0.00"
        except Exception:
            return str(n)

    def generate_response(self, message: str, context: dict,
                           ai_status: dict, memory_summary: dict,
                           risk_report: dict, development_report: dict) -> dict:
        msg_lower = message.lower()
        positions = context.get("positions", [])
        account = context.get("account", {})
        market_data = context.get("market_data", {})

        self.conversation_history.append({
            "role": "user",
            "message": message,
            "timestamp": datetime.utcnow().isoformat(),
        })

        response_parts = []
        reasoning = []

        if any(kw in msg_lower for kw in ["status", "статус", "как ты", "состояние", "работаешь"]):
            mode = ai_status.get("trading_mode", "N/A")
            regime = ai_status.get("current_regime", "N/A")
            conf = ai_status.get("avg_confidence", 0)
            cycles = ai_status.get("decision_cycles", 0)
            response_parts.append(
                f"🤖 **MASTER AI Status Report**\n"
                f"Режим торговли: **{mode}**\n"
                f"Рыночный режим: **{regime}**\n"
                f"Уверенность: **{conf:.1%}**\n"
                f"Циклов анализа: **{cycles}**\n"
                f"Обучающих шагов: **{ai_status.get('training_steps', 0)}**"
            )
            reasoning.append("Status query detected - providing full system status")

        elif any(kw in msg_lower for kw in ["сделк", "позиц", "trade", "position", "открыт"]):
            if positions:
                pos_lines = []
                total_profit = 0.0
                for p in positions:
                    profit = p.get("profit", 0)
                    total_profit += profit
                    emoji = "📈" if p.get("order_type") == "BUY" else "📉"
                    pos_lines.append(
                        f"{emoji} {p['symbol']} {p['order_type']} "
                        f"vol:{p['volume']} @ {p['open_price']} "
                        f"P&L: {self._format_number(profit)}"
                    )
                pos_text = "\n".join(pos_lines)
                response_parts.append(
                    f"📊 **Открытые позиции ({len(positions)}):**\n{pos_text}\n"
                    f"💰 Суммарный P&L: **{self._format_number(total_profit)}**"
                )
            else:
                response_parts.append(
                    "📭 **Нет открытых позиций.**\n"
                    "Я нахожусь в режиме наблюдения и анализирую рынок в поиске торговых возможностей."
                )
            reasoning.append("Position query - showing current portfolio")

        elif any(kw in msg_lower for kw in ["рынок", "market", "анализ", "analysis", "что происходит"]):
            market_lines = []
            for sym, md in market_data.items():
                if isinstance(md, dict) and "tick" in md:
                    tick = md["tick"]
                    market_lines.append(
                        f"**{sym}**: Bid={tick.get('bid', 0):.5f} "
                        f"Ask={tick.get('ask', 0):.5f} "
                        f"Spread={tick.get('spread', 0):.1f}"
                    )
                elif isinstance(md, dict) and "bid" in md:
                    market_lines.append(
                        f"**{sym}**: Bid={md.get('bid', 0):.5f} "
                        f"Ask={md.get('ask', 0):.5f} "
                        f"Spread={md.get('spread', 0):.1f}"
                    )
            current_regime = ai_status.get("current_regime", "UNKNOWN")
            response_parts.append(
                f"🌐 **Текущий анализ рынка:**\n"
                f"Режим: **{current_regime}**\n"
                + "\n".join(market_lines)
            )
            response_parts.append(
                f"\n📡 **Стратегия:** {ai_status.get('current_strategy', 'N/A')}\n"
                f"**Волатильность:** {ai_status.get('volatility', 0):.2f}%\n"
                f"**Тренд:** {ai_status.get('trend_strength', 0):.3f}"
            )
            reasoning.append("Market analysis query - providing full market overview")

        elif any(kw in msg_lower for kw in ["риск", "risk", "убыток", "loss", "drawdown", "просадк"]):
            response_parts.append(
                f"⚠️ **Risk Management Report:**\n"
                f"Риск на сделку: **{risk_report.get('risk_per_trade', 0):.1%}**\n"
                f"Мультипликатор риска: **{risk_report.get('risk_multiplier', 1):.2f}x**\n"
                f"Текущая просадка: **{risk_report.get('current_drawdown', 0):.2%}**\n"
                f"Дневной P&L: **{self._format_number(risk_report.get('daily_loss', 0))}**\n"
                f"Серия потерь: **{risk_report.get('consecutive_losses', 0)}**\n"
                f"Серия побед: **{risk_report.get('consecutive_wins', 0)}**\n"
                f"Win Rate: **{risk_report.get('win_rate', 0.5):.1%}**\n"
                f"Expectancy: **{self._format_number(risk_report.get('expectancy', 0))}**"
            )
            reasoning.append("Risk query - providing complete risk metrics")

        elif any(kw in msg_lower for kw in ["обучен", "learn", "производительн", "performance", "статистик", "stats"]):
            mem = memory_summary
            response_parts.append(
                f"🧠 **Learning & Performance Stats:**\n"
                f"Всего сделок: **{mem.get('total_trades', 0)}**\n"
                f"Суммарная прибыль: **{self._format_number(mem.get('total_profit', 0))}**\n"
                f"Буфер опыта: **{mem.get('buffer_size', 0)}** эпизодов\n"
                f"Паттернов изучено: **{mem.get('patterns_learned', 0)}**\n"
                f"Средний reward: **{mem.get('recent_performance', {}).get('avg_reward', 0):.3f}**\n"
                f"Тренд обучения: **{mem.get('recent_performance', {}).get('trend', 'N/A')}**\n"
                f"Обучающих шагов RL: **{ai_status.get('training_steps', 0)}**"
            )
            reasoning.append("Performance query - showing learning statistics")

        elif any(kw in msg_lower for kw in ["стратег", "strategy", "почему", "why", "решен", "decision"]):
            strategy = ai_status.get("current_strategy", "N/A")
            mode = ai_status.get("trading_mode", "N/A")
            regime = ai_status.get("current_regime", "N/A")
            conf = ai_status.get("avg_confidence", 0)
            response_parts.append(
                f"🎯 **Текущая стратегия: {strategy}**\n"
                f"Режим торговли: **{mode}**\n"
                f"Рыночный режим: **{regime}**\n"
                f"Уверенность: **{conf:.1%}**\n\n"
                f"Я выбираю стратегию динамически на основе:\n"
                f"• Текущего рыночного режима ({regime})\n"
                f"• Волатильности ({ai_status.get('volatility', 0):.2f}%)\n"
                f"• Силы тренда ({ai_status.get('trend_strength', 0):.3f})\n"
                f"• Исторической эффективности стратегий\n"
                f"• Текущего уровня риска"
            )
            reasoning.append(f"Strategy query - explaining {strategy} selection logic")

        elif any(kw in msg_lower for kw in ["развитие", "development", "улучшен", "improve", "знания", "knowledge"]):
            dev = development_report
            response_parts.append(
                f"🔬 **Self-Development Report:**\n"
                f"Последнее обновление: **{dev.get('last_update', 'N/A')}**\n"
                f"Изученных символов: **{dev.get('knowledge_symbols', 0)}**\n"
                f"Накоплено инсайтов: **{dev.get('insights_count', 0)}**\n"
                f"Сигналов sentiment: **{dev.get('sentiment_signals', 0)}**\n"
                f"Улучшений запланировано: **{dev.get('improvements_pending', 0)}**"
            )
            if dev.get("recent_developments"):
                dev_lines = [f"• {d.get('event', '')}" for d in dev["recent_developments"]]
                response_parts.append("**Последние события:**\n" + "\n".join(dev_lines))
            reasoning.append("Development query - showing self-improvement status")

        elif any(kw in msg_lower for kw in ["баланс", "balance", "счёт", "account", "деньги", "money", "equity"]):
            bal = account.get("balance", 0)
            eq = account.get("equity", 0)
            margin = account.get("free_margin", 0)
            profit = account.get("profit", 0)
            response_parts.append(
                f"💳 **Account Information:**\n"
                f"Баланс: **{bal:.2f} {account.get('currency', 'USD')}**\n"
                f"Equity: **{eq:.2f}**\n"
                f"Свободная маржа: **{margin:.2f}**\n"
                f"Текущий P&L: **{self._format_number(profit)}**\n"
                f"Кредитное плечо: **1:{account.get('leverage', 'N/A')}**\n"
                f"Сервер: **{account.get('server', 'N/A')}**"
            )
            reasoning.append("Account query - displaying full account details")

        elif any(kw in msg_lower for kw in ["помощь", "help", "что умеешь", "команды", "commands"]):
            response_parts.append(
                f"🤖 **MASTER AI — Доступные запросы:**\n\n"
                f"📊 **Торговля:**\n"
                f"• *позиции* — показать открытые сделки\n"
                f"• *стратегия* — текущая стратегия и причины выбора\n"
                f"• *почему* — объяснение последних решений\n\n"
                f"📈 **Рынок:**\n"
                f"• *рынок* — анализ текущего рынка\n"
                f"• *анализ [SYMBOL]* — детальный анализ символа\n\n"
                f"⚠️ **Риски:**\n"
                f"• *риски* — полный отчёт по управлению рисками\n"
                f"• *просадка* — текущая просадка и лимиты\n\n"
                f"🧠 **Система:**\n"
                f"• *статус* — полный статус AI системы\n"
                f"• *обучение* — статистика самообучения\n"
                f"• *развитие* — отчёт саморазвития\n"
                f"• *баланс* — информация о счёте\n"
            )
            reasoning.append("Help query - listing all capabilities")

        else:
            symbol_match = None
            all_symbols = list(market_data.keys())
            for sym in all_symbols:
                if sym.upper() in msg_lower.upper():
                    symbol_match = sym
                    break

            if symbol_match:
                md = market_data.get(symbol_match, {})
                tick = md.get("tick", md) if "tick" in md else md
                response_parts.append(
                    f"🔍 **Анализ {symbol_match}:**\n"
                    f"Bid: **{tick.get('bid', 0):.5f}**\n"
                    f"Ask: **{tick.get('ask', 0):.5f}**\n"
                    f"Spread: **{tick.get('spread', 0):.1f} pips**\n\n"
                    f"Мой текущий взгляд на {symbol_match} основан на:\n"
                    f"• Рыночном режиме: **{ai_status.get('current_regime', 'N/A')}**\n"
                    f"• Уверенности: **{ai_status.get('avg_confidence', 0):.1%}**\n"
                    f"• Активной стратегии: **{ai_status.get('current_strategy', 'N/A')}**"
                )
                reasoning.append(f"Symbol-specific query for {symbol_match}")
            else:
                response_parts.append(
                    f"🤖 **MASTER AI:**\n"
                    f"Я проанализировал ваш запрос: *\"{message}\"*\n\n"
                    f"В данный момент я:\n"
                    f"• Мониторю **{len(all_symbols)}** символов\n"
                    f"• Управляю **{len(positions)}** позициями\n"
                    f"• Работаю в режиме **{ai_status.get('trading_mode', 'N/A')}**\n"
                    f"• Использую стратегию **{ai_status.get('current_strategy', 'N/A')}**\n\n"
                    f"Уточните запрос или напишите *помощь* для списка команд."
                )
                reasoning.append("General query - providing system overview")

        full_response = "\n\n".join(response_parts)

        self.conversation_history.append({
            "role": "assistant",
            "message": full_response,
            "timestamp": datetime.utcnow().isoformat(),
        })

        return {
            "reply": full_response,
            "reasoning": reasoning,
            "timestamp": datetime.utcnow().isoformat(),
            "context_used": {
                "positions_count": len(positions),
                "market_symbols": len(market_data),
                "account_available": bool(account),
            },
        }


# ============================================================================
# DECISION ENGINE (PRIME - С РЕАЛЬНЫМИ УРОВНЯМИ)
# ============================================================================
class DecisionEngine:
    def __init__(self):
        self.min_confidence = 0.60
        self.signal_confirmation_required = 2
        self.last_decisions: Dict[str, dict] = {}
        self.decision_cooldown: Dict[str, datetime] = {}
        self.cooldown_seconds = 60
        self.decision_history: deque = deque(maxlen=500)
        self.total_decisions = 0
        self.executed_decisions = 0

    def is_in_cooldown(self, symbol: str) -> bool:
        last = self.decision_cooldown.get(symbol)
        if last is None:
            return False
        return (datetime.utcnow() - last).total_seconds() < self.cooldown_seconds

    def set_cooldown(self, symbol: str):
        self.decision_cooldown[symbol] = datetime.utcnow()

    def make_decision(
        self,
        symbol: str,
        state: np.ndarray,
        signal: dict,
        rl_action: int,
        rl_quality: float,
        market_data: dict,
        positions: list,
        account: dict,
        risk_engine: RiskEngine,
        strategy: str,
        regime: str,
        indicators: dict,
        pattern_quality: float,
        sentiment: float,
    ) -> Optional[dict]:
        self.total_decisions += 1
        try:
            signal_action = signal.get("action", "HOLD")
            signal_confidence = signal.get("signal_confidence", signal.get("confidence", 0.0))
            signal_reasons = signal.get("reasons", [])

            rl_action_map = {0: "HOLD", 1: "BUY", 2: "SELL"}
            rl_signal = rl_action_map.get(rl_action, "HOLD")

            if self.is_in_cooldown(symbol):
                return None

            votes = {"BUY": 0.0, "SELL": 0.0, "HOLD": 0.0}

            if signal_action in votes:
                votes[signal_action] += signal_confidence * 0.45

            if rl_signal in votes:
                votes[rl_signal] += rl_quality * 0.30

            if pattern_quality > 0.55:
                if signal_action == "BUY":
                    votes["BUY"] += pattern_quality * 0.15
                elif signal_action == "SELL":
                    votes["SELL"] += pattern_quality * 0.15

            if sentiment > 0.2:
                votes["BUY"] += abs(sentiment) * 0.10
            elif sentiment < -0.2:
                votes["SELL"] += abs(sentiment) * 0.10

            if regime == "VOLATILE":
                votes["BUY"] *= 0.5
                votes["SELL"] *= 0.5
                votes["HOLD"] += 0.3
            elif regime == "TRENDING_UP":
                votes["BUY"] *= 1.2
                votes["SELL"] *= 0.7
            elif regime == "TRENDING_DOWN":
                votes["SELL"] *= 1.2
                votes["BUY"] *= 0.7

            best_action = max(votes, key=lambda k: votes[k])
            final_confidence = votes[best_action]

            if best_action == "HOLD" or final_confidence < self.min_confidence:
                return None

            can_open, reason = risk_engine.can_open_trade(account, positions, symbol)
            if not can_open:
                self.decision_history.append({
                    "symbol": symbol,
                    "action": "BLOCKED",
                    "reason": reason,
                    "timestamp": datetime.utcnow().isoformat(),
                })
                return None

            m15 = indicators.get("m15", {})
            current_price = m15.get("current_close", 0)
            if current_price <= 0:
                return None

            atr = m15.get("atr", current_price * 0.001)
            if atr <= 0:
                atr = current_price * 0.001

            # PRIME FIX #13: РЕАЛЬНЫЕ УРОВНИ ИЗ MARKET INTELLIGENCE
            market_intel = market_data.get("market_intelligence", None)
            if market_intel and hasattr(market_intel, 'get_support_levels'):
                support_levels = market_intel.get_support_levels(symbol)
                resistance_levels = market_intel.get_resistance_levels(symbol)
            else:
                support_levels = []
                resistance_levels = []

            sl, tp = risk_engine.calculate_dynamic_sl_tp(
                symbol=symbol,
                order_type=best_action,
                entry_price=current_price,
                atr=atr,
                regime=regime,
                confidence=final_confidence,
                support_levels=support_levels,
                resistance_levels=resistance_levels,
            )

            volume = risk_engine.calculate_position_size(
                symbol=symbol,
                account=account,
                entry_price=current_price,
                sl_price=sl,
                atr=atr,
            )

            if volume < 0.01:
                return None

            reasoning_parts = [
                f"Action: {best_action} on {symbol}",
                f"Confidence: {final_confidence:.2%}",
                f"Strategy: {strategy}",
                f"Regime: {regime}",
                f"TA Signal: {signal_action} ({signal_confidence:.2%})",
                f"RL Signal: {rl_signal} ({rl_quality:.2%})",
                f"Pattern Quality: {pattern_quality:.2%}",
                f"Sentiment: {sentiment:+.2f}",
            ]
            reasoning_parts.extend(signal_reasons)
            full_reasoning = " | ".join(reasoning_parts)

            decision = {
                "symbol": symbol,
                "action": f"OPEN_{best_action}",
                "execute": True,
                "volume": volume,
                "sl": sl,
                "tp": tp,
                "confidence": final_confidence,
                "strategy": strategy,
                "market_regime": regime,
                "reasoning": full_reasoning,
                "votes": votes,
                "atr": atr,
                "entry_price": current_price,
                "timestamp": datetime.utcnow().isoformat(),
            }

            self.set_cooldown(symbol)
            self.executed_decisions += 1
            self.last_decisions[symbol] = decision
            self.decision_history.append({
                "symbol": symbol,
                "action": f"OPEN_{best_action}",
                "confidence": final_confidence,
                "timestamp": datetime.utcnow().isoformat(),
            })

            logger.info(
                f"Decision: OPEN_{best_action} {symbol} "
                f"vol={volume} sl={sl} tp={tp} conf={final_confidence:.2%}"
            )
            return decision

        except Exception as e:
            logger.error(f"Decision engine error: {e}")
            return None

    def make_position_management_decision(
        self,
        position: dict,
        current_price: float,
        indicators: dict,
        regime: str,
        risk_engine: RiskEngine,
        account: dict,
    ) -> Optional[dict]:
        try:
            ticket = position.get("ticket")
            order_type = position.get("order_type", "BUY")
            open_price = position.get("open_price", current_price)
            current_sl = position.get("sl", 0.0)
            current_tp = position.get("tp", 0.0)
            profit = position.get("profit", 0.0)
            symbol = position.get("symbol", "")

            m15 = indicators.get("m15", {})
            atr = m15.get("atr", current_price * 0.001)
            rsi = m15.get("rsi", 50)
            macd = m15.get("macd", 0)

            if atr <= 0:
                atr = current_price * 0.001

            new_sl = risk_engine.should_trail_stop(position, current_price, atr)
            if new_sl is not None:
                return {
                    "action": "MODIFY_SLTP",
                    "execute": True,
                    "ticket": ticket,
                    "new_sl": new_sl,
                    "new_tp": current_tp,
                    "symbol": symbol,
                    "reasoning": f"Trailing stop moved to {new_sl:.5f} | ATR={atr:.5f}",
                    "confidence": 0.9,
                }

            if order_type == "BUY":
                adverse_move = open_price - current_price
            else:
                adverse_move = current_price - open_price

            if adverse_move > atr * 3.0:
                return {
                    "action": "CLOSE",
                    "execute": True,
                    "ticket": ticket,
                    "symbol": symbol,
                    "reasoning": f"Emergency close: adverse move {adverse_move:.5f} > 3x ATR {atr * 3:.5f}",
                    "confidence": 0.95,
                }

            if order_type == "BUY":
                if rsi > 78 and macd < 0 and regime in ["TRENDING_DOWN", "REVERSAL"]:
                    return {
                        "action": "CLOSE",
                        "execute": True,
                        "ticket": ticket,
                        "symbol": symbol,
                        "reasoning": f"Signal reversal: RSI={rsi:.1f} overbought + MACD={macd:.6f} bearish + regime={regime}",
                        "confidence": 0.80,
                    }
            else:
                if rsi < 22 and macd > 0 and regime in ["TRENDING_UP", "REVERSAL"]:
                    return {
                        "action": "CLOSE",
                        "execute": True,
                        "ticket": ticket,
                        "symbol": symbol,
                        "reasoning": f"Signal reversal: RSI={rsi:.1f} oversold + MACD={macd:.6f} bullish + regime={regime}",
                        "confidence": 0.80,
                    }

            if order_type == "BUY" and regime == "TRENDING_UP" and rsi > 55:
                new_tp_candidate = current_price + atr * 2.5
                if current_tp > 0 and new_tp_candidate > current_tp + atr * 0.5:
                    return {
                        "action": "MODIFY_SLTP",
                        "execute": True,
                        "ticket": ticket,
                        "new_sl": current_sl,
                        "new_tp": round(new_tp_candidate, 5),
                        "symbol": symbol,
                        "reasoning": f"TP extended to {new_tp_candidate:.5f} on strong uptrend",
                        "confidence": 0.75,
                    }
            elif order_type == "SELL" and regime == "TRENDING_DOWN" and rsi < 45:
                new_tp_candidate = current_price - atr * 2.5
                if current_tp > 0 and new_tp_candidate < current_tp - atr * 0.5:
                    return {
                        "action": "MODIFY_SLTP",
                        "execute": True,
                        "ticket": ticket,
                        "new_sl": current_sl,
                        "new_tp": round(new_tp_candidate, 5),
                        "symbol": symbol,
                        "reasoning": f"TP extended to {new_tp_candidate:.5f} on strong downtrend",
                        "confidence": 0.75,
                    }

            return None

        except Exception as e:
            logger.error(f"Position management decision error: {e}")
            return None

    def get_stats(self) -> dict:
        return {
            "total_decisions": self.total_decisions,
            "executed_decisions": self.executed_decisions,
            "execution_rate": (
                self.executed_decisions / self.total_decisions
                if self.total_decisions > 0 else 0.0
            ),
            "symbols_in_cooldown": [
                sym for sym, ts in self.decision_cooldown.items()
                if (datetime.utcnow() - ts).total_seconds() < self.cooldown_seconds
            ],
            "recent_decisions": list(self.decision_history)[-10:],
        }


# ============================================================================
# EVENT BUS (ПОЛНЫЙ - БЕЗ ИЗМЕНЕНИЙ)
# ============================================================================
@dataclass
class TradingEvent:
    event_id: str = field(default_factory=lambda: str(uuid.uuid4())[:8])
    event_type: str = ""
    source: str = ""
    payload: Dict[str, Any] = field(default_factory=dict)
    timestamp: str = field(default_factory=lambda: datetime.utcnow().isoformat())
    priority: int = 1

EventHandler = Callable[[TradingEvent], Coroutine[Any, Any, None]]

class EventBus:
    TRADE_OPENED       = "trade_opened"
    TRADE_CLOSED       = "trade_closed"
    TRADE_MODIFIED     = "trade_modified"
    REGIME_CHANGED     = "regime_changed"
    RISK_ALERT         = "risk_alert"
    SIGNAL_GENERATED   = "signal_generated"
    DRAWDOWN_BREACH    = "drawdown_breach"
    KILL_SWITCH        = "kill_switch"
    MODEL_DRIFT        = "model_drift"
    PERFORMANCE_ALERT  = "performance_alert"
    LEARNING_UPDATED   = "learning_updated"
    EXPOSURE_BREACH    = "exposure_breach"
    OVERTRADING_ALERT  = "overtrading_alert"
    SYSTEM_READY       = "system_ready"

    def __init__(self):
        self._subscribers: Dict[str, List[EventHandler]] = {}
        self._event_queue: asyncio.Queue = asyncio.Queue(maxsize=2000)
        self._event_log: deque = deque(maxlen=1000)
        self._handler_errors: deque = deque(maxlen=200)
        self._running = False
        self._processor_task: Optional[asyncio.Task] = None
        self._stats: Dict[str, int] = {}
        logger.info("EventBus initialized")

    def subscribe(self, event_type: str, handler: EventHandler):
        if event_type not in self._subscribers:
            self._subscribers[event_type] = []
        if handler not in self._subscribers[event_type]:
            self._subscribers[event_type].append(handler)

    def unsubscribe(self, event_type: str, handler: EventHandler):
        if event_type in self._subscribers:
            self._subscribers[event_type] = [
                h for h in self._subscribers[event_type] if h != handler
            ]

    async def publish(self, event: TradingEvent):
        try:
            self._event_log.append({
                "id": event.event_id,
                "type": event.event_type,
                "source": event.source,
                "timestamp": event.timestamp,
                "priority": event.priority,
            })
            self._stats[event.event_type] = self._stats.get(event.event_type, 0) + 1
            if not self._event_queue.full():
                await self._event_queue.put(event)
            else:
                logger.warning(f"EventBus queue full — dropping event {event.event_type}")
        except Exception as e:
            logger.error(f"EventBus publish error: {e}")

    async def publish_sync(self, event: TradingEvent):
        await self._dispatch(event)

    async def _dispatch(self, event: TradingEvent):
        handlers = self._subscribers.get(event.event_type, [])
        wildcard = self._subscribers.get("*", [])
        all_handlers = handlers + [h for h in wildcard if h not in handlers]
        for handler in all_handlers:
            try:
                await handler(event)
            except Exception as e:
                self._handler_errors.append({
                    "handler": getattr(handler, "__name__", "unknown"),
                    "event_type": event.event_type,
                    "error": str(e),
                    "timestamp": datetime.utcnow().isoformat(),
                })
                logger.error(f"EventBus handler {handler.__name__} error on {event.event_type}: {e}")

    async def start(self):
        self._running = True
        self._processor_task = asyncio.create_task(self._process_loop())
        logger.info("EventBus processor started")

    async def stop(self):
        self._running = False
        if self._processor_task and not self._processor_task.done():
            self._processor_task.cancel()
            try:
                await self._processor_task
            except asyncio.CancelledError:
                pass
        logger.info("EventBus processor stopped")

    async def _process_loop(self):
        while self._running:
            try:
                try:
                    event = await asyncio.wait_for(self._event_queue.get(), timeout=1.0)
                    await self._dispatch(event)
                    self._event_queue.task_done()
                except asyncio.TimeoutError:
                    continue
            except asyncio.CancelledError:
                break
            except Exception as e:
                logger.error(f"EventBus process loop error: {e}")
                await asyncio.sleep(0.1)

    def get_stats(self) -> dict:
        return {
            "queue_size": self._event_queue.qsize(),
            "total_events": sum(self._stats.values()),
            "events_by_type": dict(self._stats),
            "subscribers": {k: len(v) for k, v in self._subscribers.items()},
            "handler_errors": len(self._handler_errors),
            "recent_errors": list(self._handler_errors)[-5:],
            "recent_events": list(self._event_log)[-10:],
        }


# ============================================================================
# PERSISTENCE LAYER (PRIME - С ПРОВЕРКОЙ ЦЕЛОСТНОСТИ)
# ============================================================================
class PersistenceLayer:
    SCHEMA_VERSION = "1.2"

    def __init__(self, base_dir: str = ".", db_path: str = "trading.db"):
        self.base_dir = base_dir
        self.db_path = db_path
        self.state_dir = os.path.join(base_dir, "ai_state")
        os.makedirs(self.state_dir, exist_ok=True)
        self._init_persistence_db()
        logger.info(f"PersistenceLayer initialized at {self.state_dir}")

    def _init_persistence_db(self):
        try:
            conn = sqlite3.connect(self.db_path, timeout=10)
            c = conn.cursor()
            c.execute("""
                CREATE TABLE IF NOT EXISTS ai_state_blobs (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    component TEXT NOT NULL,
                    version TEXT NOT NULL,
                    data_json TEXT,
                    saved_at TEXT,
                    schema_version TEXT,
                    checksum TEXT
                )
            """)
            c.execute("""
                CREATE TABLE IF NOT EXISTS persistence_log (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    timestamp TEXT,
                    operation TEXT,
                    component TEXT,
                    success INTEGER,
                    message TEXT
                )
            """)
            conn.commit()
            conn.close()
        except Exception as e:
            logger.error(f"Init persistence DB error: {e}")

    def _log_operation(self, operation: str, component: str, success: bool, message: str = ""):
        try:
            conn = sqlite3.connect(self.db_path, timeout=10)
            c = conn.cursor()
            c.execute(
                "INSERT INTO persistence_log (timestamp, operation, component, success, message) "
                "VALUES (?,?,?,?,?)",
                (datetime.utcnow().isoformat(), operation, component, int(success), message)
            )
            conn.commit()
            conn.close()
        except Exception as e:
            logger.error(f"Persistence log error: {e}")

    def _calculate_checksum(self, data: dict) -> str:
        return hashlib.sha256(json.dumps(data, sort_keys=True).encode()).hexdigest()[:16]

    def save_analytics_engine(self, engine: PerformanceAnalyticsEngine) -> bool:
        try:
            data = {
                "schema_version": self.SCHEMA_VERSION,
                "equity_curve": list(engine.equity_curve),
                "daily_returns": list(engine.daily_returns),
                "symbol_performance": engine.symbol_performance,
                "regime_performance": engine.regime_performance,
                "hourly_performance": {str(k): v for k, v in engine.hourly_performance.items()},
                "weekly_performance": {str(k): v for k, v in engine.weekly_performance.items()},
                "max_consecutive_wins": engine.max_consecutive_wins,
                "max_consecutive_losses": engine.max_consecutive_losses,
                "peak_equity": engine.peak_equity,
                "max_drawdown_ever": engine.max_drawdown_ever,
                "sharpe_ratio": engine.sharpe_ratio,
                "sortino_ratio": engine.sortino_ratio,
                "profit_factor": engine.profit_factor,
                "calmar_ratio": engine.calmar_ratio,
                "saved_at": datetime.utcnow().isoformat(),
            }
            data["checksum"] = self._calculate_checksum(data)
            self._save_json(data, "analytics_engine.json.gz", compress=True)
            self._save_to_db("analytics_engine", data)
            self._log_operation("SAVE", "analytics_engine", True)
            return True
        except Exception as e:
            logger.error(f"Save analytics engine error: {e}")
            self._log_operation("SAVE", "analytics_engine", False, str(e))
            return False

    def load_analytics_engine(self, engine: PerformanceAnalyticsEngine) -> bool:
        try:
            data = self._load_json("analytics_engine.json.gz", compressed=True)
            if data is None:
                data = self._load_from_db("analytics_engine")
            if data is None:
                return False

            # Проверка целостности
            if "checksum" in data:
                stored_checksum = data.pop("checksum", None)
                calc_checksum = self._calculate_checksum(data)
                if stored_checksum and stored_checksum != calc_checksum:
                    logger.warning("Analytics engine data corrupted, using defaults")
                    return False

            engine.symbol_performance = data.get("symbol_performance", {})
            engine.regime_performance = data.get("regime_performance", {})
            engine.hourly_performance = {
                int(k): v for k, v in data.get("hourly_performance", {}).items()
            }
            engine.weekly_performance = {
                int(k): v for k, v in data.get("weekly_performance", {}).items()
            }
            engine.max_consecutive_wins = data.get("max_consecutive_wins", 0)
            engine.max_consecutive_losses = data.get("max_consecutive_losses", 0)
            engine.peak_equity = data.get("peak_equity", 0.0)
            engine.max_drawdown_ever = data.get("max_drawdown_ever", 0.0)
            engine.sharpe_ratio = data.get("sharpe_ratio", 0.0)
            engine.sortino_ratio = data.get("sortino_ratio", 0.0)
            engine.profit_factor = data.get("profit_factor", 0.0)
            engine.calmar_ratio = data.get("calmar_ratio", 0.0)
            for point in data.get("equity_curve", []):
                engine.equity_curve.append(point)

            self._log_operation("LOAD", "analytics_engine", True)
            logger.info("Analytics engine state restored")
            return True
        except Exception as e:
            logger.error(f"Load analytics engine error: {e}")
            self._log_operation("LOAD", "analytics_engine", False, str(e))
            return False

    def save_regime_classifier(self, classifier: MarketRegimeClassifier) -> bool:
        try:
            history_serializable = {}
            for sym, dq in classifier.regime_history.items():
                history_serializable[sym] = list(dq)

            data = {
                "schema_version": self.SCHEMA_VERSION,
                "transition_counts": classifier.transition_counts,
                "transition_matrix": classifier.transition_matrix,
                "regime_history": history_serializable,
                "nn_weights": classifier.classifier_nn.get_weights(),
                "label_history": list(classifier.label_history)[-200:],
                "saved_at": datetime.utcnow().isoformat(),
            }
            data["checksum"] = self._calculate_checksum(data)
            self._save_json(data, "regime_classifier.json.gz", compress=True)
            self._save_to_db("regime_classifier", {"saved_at": data["saved_at"], "schema": self.SCHEMA_VERSION})
            self._log_operation("SAVE", "regime_classifier", True)
            return True
        except Exception as e:
            logger.error(f"Save regime classifier error: {e}")
            self._log_operation("SAVE", "regime_classifier", False, str(e))
            return False

    def load_regime_classifier(self, classifier: MarketRegimeClassifier) -> bool:
        try:
            data = self._load_json("regime_classifier.json.gz", compressed=True)
            if data is None:
                return False

            counts = data.get("transition_counts", {})
            for r in REGIMES:
                if r in counts:
                    for r2 in REGIMES:
                        classifier.transition_counts[r][r2] = counts[r].get(r2, 0)

            matrix = data.get("transition_matrix", {})
            for r in REGIMES:
                if r in matrix:
                    for r2 in REGIMES:
                        classifier.transition_matrix[r][r2] = matrix[r].get(r2, 0.0)

            for sym, hist in data.get("regime_history", {}).items():
                if sym not in classifier.regime_history:
                    classifier.regime_history[sym] = deque(maxlen=100)
                for item in hist:
                    classifier.regime_history[sym].append(item)

            nn_weights = data.get("nn_weights")
            if nn_weights:
                try:
                    classifier.classifier_nn.set_weights(nn_weights)
                except Exception as we:
                    logger.warning(f"Could not restore regime classifier NN weights: {we}")

            self._log_operation("LOAD", "regime_classifier", True)
            logger.info("Regime classifier state restored")
            return True
        except Exception as e:
            logger.error(f"Load regime classifier error: {e}")
            self._log_operation("LOAD", "regime_classifier", False, str(e))
            return False

    def save_position_tracker(self, tracker: PositionTracker) -> bool:
        try:
            positions_serializable = {}
            for ticket, pos in tracker.tracked_positions.items():
                p = dict(pos)
                positions_serializable[str(ticket)] = p

            data = {
                "schema_version": self.SCHEMA_VERSION,
                "tracked_positions": positions_serializable,
                "position_events": list(tracker.position_events)[-100:],
                "risk_alerts": list(tracker.risk_alerts)[-50:],
                "saved_at": datetime.utcnow().isoformat(),
            }
            self._save_json(data, "position_tracker.json")
            self._log_operation("SAVE", "position_tracker", True)
            return True
        except Exception as e:
            logger.error(f"Save position tracker error: {e}")
            self._log_operation("SAVE", "position_tracker", False, str(e))
            return False

    def load_position_tracker(self, tracker: PositionTracker) -> bool:
        try:
            data = self._load_json("position_tracker.json")
            if data is None:
                return False

            for ticket_str, pos in data.get("tracked_positions", {}).items():
                tracker.tracked_positions[int(ticket_str)] = pos

            for event in data.get("position_events", []):
                tracker.position_events.append(event)

            for alert in data.get("risk_alerts", []):
                tracker.risk_alerts.append(alert)

            self._log_operation("LOAD", "position_tracker", True)
            logger.info(f"Position tracker restored: {len(tracker.tracked_positions)} positions")
            return True
        except Exception as e:
            logger.error(f"Load position tracker error: {e}")
            self._log_operation("LOAD", "position_tracker", False, str(e))
            return False

    def save_advanced_risk_engine(self, engine: AdvancedRiskEngine) -> bool:
        try:
            symbol_returns_serializable = {
                sym: list(dq) for sym, dq in engine.symbol_returns.items()
            }
            data = {
                "schema_version": self.SCHEMA_VERSION,
                "portfolio_returns": list(engine.portfolio_returns),
                "symbol_returns": symbol_returns_serializable,
                "correlation_matrix": engine.correlation_matrix,
                "current_leverage": engine.current_leverage,
                "portfolio_risk_score": engine.portfolio_risk_score,
                "last_var": engine.last_var,
                "last_cvar": engine.last_cvar,
                "baseline_accuracy": {},
                "saved_at": datetime.utcnow().isoformat(),
            }
            self._save_json(data, "advanced_risk_engine.json.gz", compress=True)
            self._log_operation("SAVE", "advanced_risk_engine", True)
            return True
        except Exception as e:
            logger.error(f"Save advanced risk engine error: {e}")
            self._log_operation("SAVE", "advanced_risk_engine", False, str(e))
            return False

    def load_advanced_risk_engine(self, engine: AdvancedRiskEngine) -> bool:
        try:
            data = self._load_json("advanced_risk_engine.json.gz", compressed=True)
            if data is None:
                return False

            for ret in data.get("portfolio_returns", []):
                engine.portfolio_returns.append(ret)

            for sym, rets in data.get("symbol_returns", {}).items():
                if sym not in engine.symbol_returns:
                    engine.symbol_returns[sym] = deque(maxlen=252)
                for r in rets:
                    engine.symbol_returns[sym].append(r)

            engine.correlation_matrix = data.get("correlation_matrix", {})
            engine.current_leverage = data.get("current_leverage", 1.0)
            engine.portfolio_risk_score = data.get("portfolio_risk_score", 0.0)
            engine.last_var = data.get("last_var", 0.0)
            engine.last_cvar = data.get("last_cvar", 0.0)

            self._log_operation("LOAD", "advanced_risk_engine", True)
            logger.info("Advanced risk engine state restored")
            return True
        except Exception as e:
            logger.error(f"Load advanced risk engine error: {e}")
            self._log_operation("LOAD", "advanced_risk_engine", False, str(e))
            return False

    def save_online_learning_engine(self, engine: OnlineLearningEngine) -> bool:
        try:
            data = {
                "schema_version": self.SCHEMA_VERSION,
                "baseline_accuracy": engine.baseline_accuracy,
                "total_online_updates": engine.total_online_updates,
                "global_weights": engine.global_classifier.get_weights(),
                "regime_weights": {
                    r: clf.get_weights() for r, clf in engine.regime_classifiers.items()
                },
                "strategy_weights": {
                    s: clf.get_weights() for s, clf in engine.strategy_classifiers.items()
                },
                "drift_events": list(engine.drift_events)[-20:],
                "degradation_alerts": list(engine.degradation_alerts)[-10:],
                "saved_at": datetime.utcnow().isoformat(),
            }
            self._save_json(data, "online_learning_engine.json.gz", compress=True)
            self._log_operation("SAVE", "online_learning_engine", True)
            return True
        except Exception as e:
            logger.error(f"Save online learning engine error: {e}")
            self._log_operation("SAVE", "online_learning_engine", False, str(e))
            return False

    def load_online_learning_engine(self, engine: OnlineLearningEngine) -> bool:
        try:
            data = self._load_json("online_learning_engine.json.gz", compressed=True)
            if data is None:
                return False

            engine.baseline_accuracy = data.get("baseline_accuracy", {})
            engine.total_online_updates = data.get("total_online_updates", 0)

            try:
                gw = data.get("global_weights")
                if gw:
                    engine.global_classifier.set_weights(gw)
            except Exception as e:
                logger.warning(f"Could not restore global classifier weights: {e}")

            for r, weights in data.get("regime_weights", {}).items():
                if r in engine.regime_classifiers:
                    try:
                        engine.regime_classifiers[r].set_weights(weights)
                    except Exception:
                        pass

            for s, weights in data.get("strategy_weights", {}).items():
                if s in engine.strategy_classifiers:
                    try:
                        engine.strategy_classifiers[s].set_weights(weights)
                    except Exception:
                        pass

            for evt in data.get("drift_events", []):
                engine.drift_events.append(evt)
            for alert in data.get("degradation_alerts", []):
                engine.degradation_alerts.append(alert)

            self._log_operation("LOAD", "online_learning_engine", True)
            logger.info("Online learning engine state restored")
            return True
        except Exception as e:
            logger.error(f"Load online learning engine error: {e}")
            self._log_operation("LOAD", "online_learning_engine", False, str(e))
            return False

    async def save_all(self, master_ai: "MasterAI") -> dict:
        results = {}
        try:
            if hasattr(master_ai, "analytics_engine"):
                results["analytics"] = self.save_analytics_engine(master_ai.analytics_engine)
            if hasattr(master_ai, "regime_classifier"):
                results["regime_classifier"] = self.save_regime_classifier(master_ai.regime_classifier)
            if hasattr(master_ai, "position_tracker"):
                results["position_tracker"] = self.save_position_tracker(master_ai.position_tracker)
            if hasattr(master_ai, "advanced_risk_engine"):
                results["advanced_risk"] = self.save_advanced_risk_engine(master_ai.advanced_risk_engine)
            if hasattr(master_ai, "online_learning_engine"):
                results["online_learning"] = self.save_online_learning_engine(master_ai.online_learning_engine)

            self._log_operation("SAVE_ALL", "master_ai", all(results.values()), str(results))
            logger.info(f"Full state saved: {results}")
        except Exception as e:
            logger.error(f"Save all error: {e}")
        return results

    async def load_all(self, master_ai: "MasterAI") -> dict:
        results = {}
        try:
            if hasattr(master_ai, "analytics_engine"):
                results["analytics"] = self.load_analytics_engine(master_ai.analytics_engine)
            if hasattr(master_ai, "regime_classifier"):
                results["regime_classifier"] = self.load_regime_classifier(master_ai.regime_classifier)
            if hasattr(master_ai, "position_tracker"):
                results["position_tracker"] = self.load_position_tracker(master_ai.position_tracker)
            if hasattr(master_ai, "advanced_risk_engine"):
                results["advanced_risk"] = self.load_advanced_risk_engine(master_ai.advanced_risk_engine)
            if hasattr(master_ai, "online_learning_engine"):
                results["online_learning"] = self.load_online_learning_engine(master_ai.online_learning_engine)

            self._log_operation("LOAD_ALL", "master_ai", True, str(results))
            logger.info(f"Full state loaded: {results}")
        except Exception as e:
            logger.error(f"Load all error: {e}")
        return results

    def _save_json(self, data: dict, filename: str, compress: bool = False):
        path = os.path.join(self.state_dir, filename)
        payload = json.dumps(data, default=str, ensure_ascii=False)
        if compress:
            with gzip.open(path, "wt", encoding="utf-8") as f:
                f.write(payload)
        else:
            with open(path, "w", encoding="utf-8") as f:
                f.write(payload)

    def _load_json(self, filename: str, compressed: bool = False) -> Optional[dict]:
        path = os.path.join(self.state_dir, filename)
        if not os.path.exists(path):
            return None
        try:
            if compressed:
                with gzip.open(path, "rt", encoding="utf-8") as f:
                    return json.loads(f.read())
            else:
                with open(path, "r", encoding="utf-8") as f:
                    return json.loads(f.read())
        except json.JSONDecodeError as e:
            logger.error(f"JSON decode error {filename}: {e}")
            # Пытаемся восстановить из бэкапа
            backup_path = path + ".backup"
            if os.path.exists(backup_path):
                try:
                    with open(backup_path, "r", encoding="utf-8") as f:
                        return json.loads(f.read())
                except Exception:
                    pass
            return None
        except Exception as e:
            logger.error(f"Load JSON {filename} error: {e}")
            return None

    def _save_to_db(self, component: str, data: dict):
        try:
            conn = sqlite3.connect(self.db_path, timeout=10)
            c = conn.cursor()
            c.execute("""
                INSERT INTO ai_state_blobs (component, version, data_json, saved_at, schema_version, checksum)
                VALUES (?, ?, ?, ?, ?, ?)
            """, (
                component,
                self.SCHEMA_VERSION,
                json.dumps(data, default=str, ensure_ascii=False),
                datetime.utcnow().isoformat(),
                self.SCHEMA_VERSION,
                data.get("checksum", ""),
            ))
            conn.commit()
            conn.close()
        except Exception as e:
            logger.error(f"Save to DB error ({component}): {e}")

    def _load_from_db(self, component: str) -> Optional[dict]:
        try:
            conn = sqlite3.connect(self.db_path, timeout=10)
            c = conn.cursor()
            c.execute("""
                SELECT data_json FROM ai_state_blobs
                WHERE component = ?
                ORDER BY id DESC LIMIT 1
            """, (component,))
            row = c.fetchone()
            conn.close()
            if row and row[0]:
                return json.loads(row[0])
            return None
        except Exception as e:
            logger.error(f"Load from DB error ({component}): {e}")
            return None

    def list_saved_states(self) -> List[dict]:
        try:
            conn = sqlite3.connect(self.db_path, timeout=10)
            c = conn.cursor()
            c.execute("""
                SELECT component, version, saved_at, schema_version
                FROM ai_state_blobs
                ORDER BY id DESC
            """)
            rows = c.fetchall()
            conn.close()
            return [
                {
                    "component": r[0],
                    "version": r[1],
                    "saved_at": r[2],
                    "schema_version": r[3],
                }
                for r in rows
            ]
        except Exception as e:
            logger.error(f"List saved states error: {e}")
            return []

    def get_persistence_log(self, limit: int = 50) -> List[dict]:
        try:
            conn = sqlite3.connect(self.db_path, timeout=10)
            c = conn.cursor()
            c.execute("""
                SELECT timestamp, operation, component, success, message
                FROM persistence_log
                ORDER BY id DESC LIMIT ?
            """, (limit,))
            rows = c.fetchall()
            conn.close()
            return [
                {
                    "timestamp": r[0],
                    "operation": r[1],
                    "component": r[2],
                    "success": bool(r[3]),
                    "message": r[4],
                }
                for r in rows
            ]
        except Exception as e:
            logger.error(f"Get persistence log error: {e}")
            return []

    def cleanup_old_states(self, keep_last: int = 5):
        try:
            conn = sqlite3.connect(self.db_path, timeout=10)
            c = conn.cursor()
            c.execute("""
                DELETE FROM ai_state_blobs
                WHERE id NOT IN (
                    SELECT id FROM ai_state_blobs
                    ORDER BY id DESC LIMIT ?
                )
            """, (keep_last,))
            deleted = c.rowcount
            conn.commit()
            conn.close()
            logger.info(f"Persistence cleanup: removed {deleted} old state records")
        except Exception as e:
            logger.error(f"Cleanup old states error: {e}")

    def get_state_size_report(self) -> dict:
        report = {}
        try:
            for fname in os.listdir(self.state_dir):
                fpath = os.path.join(self.state_dir, fname)
                if os.path.isfile(fpath):
                    size_bytes = os.path.getsize(fpath)
                    report[fname] = {
                        "size_bytes": size_bytes,
                        "size_kb": round(size_bytes / 1024, 2),
                        "modified": datetime.fromtimestamp(
                            os.path.getmtime(fpath)
                        ).isoformat(),
                    }
        except Exception as e:
            logger.error(f"State size report error: {e}")
        return report


# ============================================================================
# EXECUTION SAFETY LAYER (PRIME - БЕЗ ЗАГЛУШЕК)
# ============================================================================
@dataclass
class CooldownEntry:
    symbol: str
    triggered_at: datetime
    duration_seconds: float
    reason: str

class ExecutionSafetyLayer:
    def __init__(self, event_bus: Optional[EventBus] = None):
        self.event_bus = event_bus

        self.kill_switch_active: bool = False
        self.kill_switch_reason: str = ""
        self.kill_switch_triggered_at: Optional[datetime] = None
        self.kill_switch_auto_reset_seconds: float = 3600.0

        self.symbol_cooldowns: Dict[str, CooldownEntry] = {}
        self.default_cooldown_seconds: float = 60.0
        self.cooldown_after_loss_seconds: float = 300.0
        self.cooldown_after_win_seconds: float = 30.0

        self.trade_timestamps: deque = deque(maxlen=500)
        self.max_trades_per_hour: int = 20
        self.max_trades_per_minute: int = 3
        self.overtrading_window_seconds: float = 3600.0

        self.recent_signals: Dict[str, dict] = {}
        self.signal_dedup_window_seconds: float = 30.0

        self.open_directions: Dict[str, str] = {}

        self.max_concurrent_positions: int = 10
        self.max_positions_per_symbol: int = 2
        self.max_daily_trades: int = 50
        self.daily_trade_count: int = 0
        self.daily_trade_reset: datetime = datetime.utcnow()

        self.blocked_symbols: set = set()

        self.blocked_log: deque = deque(maxlen=500)
        self.allowed_log: deque = deque(maxlen=200)

        logger.info("ExecutionSafetyLayer initialized")

    async def activate_kill_switch(self, reason: str):
        self.kill_switch_active = True
        self.kill_switch_reason = reason
        self.kill_switch_triggered_at = datetime.utcnow()
        logger.critical(f"KILL-SWITCH ACTIVATED: {reason}")
        if self.event_bus:
            await self.event_bus.publish_sync(TradingEvent(
                event_type=EventBus.KILL_SWITCH,
                source="ExecutionSafetyLayer",
                payload={
                    "reason": reason,
                    "triggered_at": self.kill_switch_triggered_at.isoformat(),
                },
                priority=3,
            ))

    def deactivate_kill_switch(self, manual: bool = False) -> bool:
        if not self.kill_switch_active:
            return False
        if not manual:
            if self.kill_switch_triggered_at:
                elapsed = (datetime.utcnow() - self.kill_switch_triggered_at).total_seconds()
                if elapsed < self.kill_switch_auto_reset_seconds:
                    return False
        self.kill_switch_active = False
        self.kill_switch_reason = ""
        self.kill_switch_triggered_at = None
        logger.info(f"Kill-switch deactivated (manual={manual})")
        return True

    def check_kill_switch_auto_reset(self):
        if (
            self.kill_switch_active
            and self.kill_switch_triggered_at
        ):
            elapsed = (datetime.utcnow() - self.kill_switch_triggered_at).total_seconds()
            if elapsed >= self.kill_switch_auto_reset_seconds:
                self.deactivate_kill_switch(manual=False)

    def set_cooldown(
        self,
        symbol: str,
        duration_seconds: float,
        reason: str = "default",
    ):
        self.symbol_cooldowns[symbol] = CooldownEntry(
            symbol=symbol,
            triggered_at=datetime.utcnow(),
            duration_seconds=duration_seconds,
            reason=reason,
        )
        logger.debug(f"Cooldown set for {symbol}: {duration_seconds}s — {reason}")

    def is_in_cooldown(self, symbol: str) -> Tuple[bool, float]:
        entry = self.symbol_cooldowns.get(symbol)
        if entry is None:
            return False, 0.0
        elapsed = (datetime.utcnow() - entry.triggered_at).total_seconds()
        remaining = entry.duration_seconds - elapsed
        if remaining <= 0:
            del self.symbol_cooldowns[symbol]
            return False, 0.0
        return True, round(remaining, 1)

    def clear_cooldown(self, symbol: str):
        self.symbol_cooldowns.pop(symbol, None)

    def _reset_daily_counter_if_needed(self):
        now = datetime.utcnow()
        if now.date() > self.daily_trade_reset.date():
            self.daily_trade_count = 0
            self.daily_trade_reset = now

    def increment_trade_count(self):
        self._reset_daily_counter_if_needed()
        self.daily_trade_count += 1
        self.trade_timestamps.append(datetime.utcnow())

    def is_overtrading(self) -> Tuple[bool, str]:
        now = datetime.utcnow()

        minute_ago = now - timedelta(seconds=60)
        trades_last_minute = sum(
            1 for ts in self.trade_timestamps
            if ts > minute_ago
        )
        if trades_last_minute >= self.max_trades_per_minute:
            return True, f"Max trades/min reached: {trades_last_minute}/{self.max_trades_per_minute}"

        hour_ago = now - timedelta(seconds=self.overtrading_window_seconds)
        trades_last_hour = sum(
            1 for ts in self.trade_timestamps
            if ts > hour_ago
        )
        if trades_last_hour >= self.max_trades_per_hour:
            return True, f"Max trades/hour reached: {trades_last_hour}/{self.max_trades_per_hour}"

        self._reset_daily_counter_if_needed()
        if self.daily_trade_count >= self.max_daily_trades:
            return True, f"Max daily trades reached: {self.daily_trade_count}/{self.max_daily_trades}"

        return False, ""

    def is_duplicate_signal(self, symbol: str, action: str) -> bool:
        now = datetime.utcnow()
        key = f"{symbol}_{action}"
        last = self.recent_signals.get(key)
        if last is None:
            return False
        elapsed = (now - last["timestamp"]).total_seconds()
        if elapsed < self.signal_dedup_window_seconds:
            return True
        del self.recent_signals[key]
        return False

    def register_signal(self, symbol: str, action: str):
        key = f"{symbol}_{action}"
        self.recent_signals[key] = {
            "symbol": symbol,
            "action": action,
            "timestamp": datetime.utcnow(),
        }

    def has_conflicting_position(self, symbol: str, action: str, positions: list) -> bool:
        for p in positions:
            if p.get("symbol") != symbol:
                continue
            existing_type = p.get("order_type", "").upper()
            new_type = action.replace("OPEN_", "").upper()
            if existing_type and new_type and existing_type != new_type:
                return True
        return False

    def count_positions_for_symbol(self, symbol: str, positions: list) -> int:
        return sum(1 for p in positions if p.get("symbol") == symbol)

    async def is_execution_allowed(
        self,
        decision: dict,
        positions: list,
        account: dict,
    ) -> Tuple[bool, str]:
        symbol = decision.get("symbol", "")
        action = decision.get("action", "")
        self.check_kill_switch_auto_reset()

        if self.kill_switch_active:
            reason = f"Kill-switch active: {self.kill_switch_reason}"
            self._log_block(symbol, action, reason)
            return False, reason

        if symbol in self.blocked_symbols:
            reason = f"Symbol {symbol} is blocked"
            self._log_block(symbol, action, reason)
            return False, reason

        in_cd, remaining = self.is_in_cooldown(symbol)
        if in_cd:
            reason = f"Symbol {symbol} in cooldown ({remaining:.0f}s remaining)"
            self._log_block(symbol, action, reason)
            return False, reason

        over, over_reason = self.is_overtrading()
        if over:
            reason = f"Overtrading guard: {over_reason}"
            self._log_block(symbol, action, reason)
            if self.event_bus:
                await self.event_bus.publish(TradingEvent(
                    event_type=EventBus.OVERTRADING_ALERT,
                    source="ExecutionSafetyLayer",
                    payload={"reason": reason, "symbol": symbol},
                    priority=2,
                ))
            return False, reason

        if self.is_duplicate_signal(symbol, action):
            reason = f"Duplicate signal for {symbol}/{action} (dedup window)"
            self._log_block(symbol, action, reason)
            return False, reason

        if len(positions) >= self.max_concurrent_positions:
            reason = f"Max concurrent positions ({self.max_concurrent_positions}) reached"
            self._log_block(symbol, action, reason)
            return False, reason

        sym_count = self.count_positions_for_symbol(symbol, positions)
        if sym_count >= self.max_positions_per_symbol:
            reason = f"Max positions per symbol ({self.max_positions_per_symbol}) reached for {symbol}"
            self._log_block(symbol, action, reason)
            return False, reason

        if action.startswith("OPEN") and self.has_conflicting_position(symbol, action, positions):
            reason = f"Conflicting position exists for {symbol}"
            self._log_block(symbol, action, reason)
            return False, reason

        free_margin = account.get("free_margin", 0)
        balance = account.get("balance", 1)
        if free_margin < balance * 0.05:
            reason = f"Insufficient free margin: {free_margin:.2f} ({free_margin/balance:.1%} of balance)"
            self._log_block(symbol, action, reason)
            return False, reason

        confidence = decision.get("confidence", 0.0)
        if confidence < 0.55:
            reason = f"Confidence too low: {confidence:.2%} < 55%"
            self._log_block(symbol, action, reason)
            return False, reason

        self._log_allow(symbol, action, confidence)
        return True, "OK"

    def on_trade_executed(self, symbol: str, action: str, result: dict):
        self.increment_trade_count()
        self.register_signal(symbol, action)
        self.set_cooldown(symbol, self.default_cooldown_seconds, reason="post_execution")

    def on_trade_closed(self, symbol: str, profit: float):
        if profit < 0:
            self.set_cooldown(
                symbol,
                self.cooldown_after_loss_seconds,
                reason=f"post_loss profit={profit:.2f}",
            )
        else:
            self.set_cooldown(
                symbol,
                self.cooldown_after_win_seconds,
                reason=f"post_win profit={profit:.2f}",
            )

    def block_symbol(self, symbol: str, reason: str = "manual"):
        self.blocked_symbols.add(symbol)
        logger.warning(f"Symbol {symbol} blocked: {reason}")

    def unblock_symbol(self, symbol: str):
        self.blocked_symbols.discard(symbol)
        logger.info(f"Symbol {symbol} unblocked")

    def _log_block(self, symbol: str, action: str, reason: str):
        self.blocked_log.append({
            "symbol": symbol,
            "action": action,
            "reason": reason,
            "timestamp": datetime.utcnow().isoformat(),
        })

    def _log_allow(self, symbol: str, action: str, confidence: float):
        self.allowed_log.append({
            "symbol": symbol,
            "action": action,
            "confidence": confidence,
            "timestamp": datetime.utcnow().isoformat(),
        })

    def get_safety_report(self) -> dict:
        active_cooldowns = {}
        for symbol, entry in list(self.symbol_cooldowns.items()):
            in_cd, remaining = self.is_in_cooldown(symbol)
            if in_cd:
                active_cooldowns[symbol] = {
                    "remaining_seconds": remaining,
                    "reason": entry.reason,
                }

        now = datetime.utcnow()
        minute_ago = now - timedelta(seconds=60)
        hour_ago = now - timedelta(seconds=3600)

        return {
            "kill_switch_active": self.kill_switch_active,
            "kill_switch_reason": self.kill_switch_reason,
            "kill_switch_triggered_at": (
                self.kill_switch_triggered_at.isoformat()
                if self.kill_switch_triggered_at else None
            ),
            "blocked_symbols": list(self.blocked_symbols),
            "active_cooldowns": active_cooldowns,
            "daily_trade_count": self.daily_trade_count,
            "max_daily_trades": self.max_daily_trades,
            "trades_last_minute": sum(1 for ts in self.trade_timestamps if ts > minute_ago),
            "trades_last_hour": sum(1 for ts in self.trade_timestamps if ts > hour_ago),
            "max_trades_per_minute": self.max_trades_per_minute,
            "max_trades_per_hour": self.max_trades_per_hour,
            "recent_blocked": list(self.blocked_log)[-10:],
            "recent_allowed": list(self.allowed_log)[-5:],
            "recent_signals_count": len(self.recent_signals),
            "max_concurrent_positions": self.max_concurrent_positions,
        }


# ============================================================================
# EXECUTION HARDENING COMPONENTS (PRIME - БЕЗ ЗАГЛУШЕК)
# ============================================================================

class ExecutionStatus(Enum):
    PENDING = "pending"
    SENT = "sent"
    CONFIRMED = "confirmed"
    FAILED = "failed"
    REJECTED = "rejected"
    PARTIAL = "partial"
    CANCELLED = "cancelled"


class ExecutionLedger:
    """Immutable execution ledger - single source of truth."""
    
    def __init__(self, db_path: str):
        self.db_path = db_path
        self._lock = asyncio.Lock()
        self._init_ledger_tables()
        logger.info("ExecutionLedger initialized")
    
    def _init_ledger_tables(self):
        try:
            conn = sqlite3.connect(self.db_path, timeout=10)
            c = conn.cursor()
            c.execute("""
                CREATE TABLE IF NOT EXISTS execution_ledger (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    trace_id TEXT UNIQUE NOT NULL,
                    idempotency_key TEXT UNIQUE NOT NULL,
                    symbol TEXT NOT NULL,
                    action TEXT NOT NULL,
                    volume REAL NOT NULL,
                    sl REAL,
                    tp REAL,
                    strategy TEXT,
                    regime TEXT,
                    confidence REAL,
                    status TEXT NOT NULL,
                    created_at TEXT NOT NULL,
                    sent_at TEXT,
                    confirmed_at TEXT,
                    ticket INTEGER,
                    fill_price REAL,
                    error_message TEXT,
                    retry_count INTEGER DEFAULT 0,
                    last_retry_at TEXT,
                    version INTEGER DEFAULT 1
                )
            """)
            c.execute("CREATE INDEX IF NOT EXISTS idx_ledger_trace ON execution_ledger(trace_id)")
            c.execute("CREATE INDEX IF NOT EXISTS idx_ledger_idempotency ON execution_ledger(idempotency_key)")
            c.execute("CREATE INDEX IF NOT EXISTS idx_ledger_status ON execution_ledger(status)")
            c.execute("CREATE INDEX IF NOT EXISTS idx_ledger_ticket ON execution_ledger(ticket)")
            conn.commit()
            conn.close()
        except Exception as e:
            logger.error(f"Init ledger tables error: {e}")
    
    async def create_pending(self, trace_id: str, idempotency_key: str, symbol: str,
                              action: str, volume: float, sl: float, tp: float,
                              strategy: str, regime: str, confidence: float) -> bool:
        async with self._lock:
            try:
                conn = sqlite3.connect(self.db_path, timeout=10)
                c = conn.cursor()
                c.execute("""
                    INSERT INTO execution_ledger 
                    (trace_id, idempotency_key, symbol, action, volume, sl, tp, 
                     strategy, regime, confidence, status, created_at, version)
                    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                """, (
                    trace_id, idempotency_key, symbol, action, volume, sl, tp,
                    strategy, regime, confidence, ExecutionStatus.PENDING.value,
                    datetime.utcnow().isoformat(), 1
                ))
                conn.commit()
                conn.close()
                logger.debug(f"Ledger: created PENDING record {trace_id}")
                return True
            except sqlite3.IntegrityError:
                logger.warning(f"Ledger: record {trace_id} or {idempotency_key} already exists")
                return False
            except Exception as e:
                logger.error(f"Ledger create error: {e}")
                return False
    
    async def update_status(self, trace_id: str, new_status: ExecutionStatus,
                             ticket: Optional[int] = None, fill_price: Optional[float] = None,
                             error: Optional[str] = None) -> bool:
        async with self._lock:
            try:
                conn = sqlite3.connect(self.db_path, timeout=10)
                c = conn.cursor()
                c.execute("""
                    UPDATE execution_ledger 
                    SET status = ?, sent_at = COALESCE(sent_at, ?),
                        confirmed_at = CASE WHEN ? = 'confirmed' THEN ? ELSE confirmed_at END,
                        ticket = COALESCE(?, ticket),
                        fill_price = COALESCE(?, fill_price),
                        error_message = ?,
                        version = version + 1
                    WHERE trace_id = ?
                """, (
                    new_status.value,
                    datetime.utcnow().isoformat() if new_status == ExecutionStatus.SENT else None,
                    new_status.value,
                    datetime.utcnow().isoformat() if new_status == ExecutionStatus.CONFIRMED else None,
                    ticket,
                    fill_price,
                    error,
                    trace_id
                ))
                conn.commit()
                conn.close()
                logger.debug(f"Ledger: {trace_id} → {new_status.value}")
                return True
            except Exception as e:
                logger.error(f"Ledger update error: {e}")
                return False
    
    async def get_pending_records(self) -> List[dict]:
        try:
            conn = sqlite3.connect(self.db_path, timeout=10)
            conn.row_factory = sqlite3.Row
            c = conn.cursor()
            c.execute("""
                SELECT * FROM execution_ledger 
                WHERE status IN (?, ?) 
                ORDER BY created_at ASC
            """, (ExecutionStatus.PENDING.value, ExecutionStatus.SENT.value))
            rows = c.fetchall()
            conn.close()
            return [dict(row) for row in rows]
        except Exception as e:
            logger.error(f"Get pending records error: {e}")
            return []
    
    async def get_stats(self) -> dict:
        try:
            conn = sqlite3.connect(self.db_path, timeout=10)
            c = conn.cursor()
            c.execute("SELECT COUNT(*) FROM execution_ledger")
            total = c.fetchone()[0]
            c.execute("SELECT COUNT(*) FROM execution_ledger WHERE status = ?", (ExecutionStatus.PENDING.value,))
            pending = c.fetchone()[0]
            c.execute("SELECT COUNT(*) FROM execution_ledger WHERE status = ?", (ExecutionStatus.CONFIRMED.value,))
            confirmed = c.fetchone()[0]
            conn.close()
            return {"total": total, "pending": pending, "confirmed": confirmed}
        except Exception as e:
            return {"error": str(e)}


class IdempotencyManager:
    def __init__(self, ledger: ExecutionLedger):
        self.ledger = ledger
        self._cache: Dict[str, dict] = {}
        logger.info("IdempotencyManager initialized")
    
    def generate_key(self, symbol: str, action: str, strategy: str, regime: str,
                      volume: float, timestamp: datetime) -> str:
        time_bucket = timestamp.strftime("%Y%m%d%H%M")
        normalized_volume = round(volume, 2)
        unique_string = f"{symbol}:{action}:{strategy}:{regime}:{normalized_volume}:{time_bucket}"
        return hashlib.sha256(unique_string.encode()).hexdigest()[:32]
    
    async def is_duplicate(self, key: str) -> Tuple[bool, Optional[dict]]:
        if key in self._cache:
            return True, self._cache[key]
        return False, None


class AtomicExecutionPipeline:
    def __init__(self, ledger: ExecutionLedger, idempotency_manager: IdempotencyManager,
                 event_bus: Optional[EventBus] = None):
        self.ledger = ledger
        self.idempotency = idempotency_manager
        self.event_bus = event_bus
        self._execution_lock = asyncio.Lock()
        logger.info("AtomicExecutionPipeline initialized")
    
    async def execute(self, decision: dict, mt5_send_fn: Callable,
                       trace_id: Optional[str] = None) -> Tuple[bool, dict]:
        trace_id = trace_id or f"exec_{uuid.uuid4().hex[:16]}_{int(time.time() * 1000)}"
        
        async with self._execution_lock:
            symbol = decision.get("symbol")
            action = decision.get("action", "").replace("OPEN_", "")
            volume = decision.get("volume", 0.01)
            sl = decision.get("sl", 0.0)
            tp = decision.get("tp", 0.0)
            strategy = decision.get("strategy", "UNKNOWN")
            regime = decision.get("market_regime", "UNKNOWN")
            confidence = decision.get("confidence", 0.5)
            
            idempotency_key = self.idempotency.generate_key(
                symbol=symbol, action=action, strategy=strategy,
                regime=regime, volume=volume, timestamp=datetime.utcnow()
            )
            
            is_dup, existing = await self.idempotency.is_duplicate(idempotency_key)
            if is_dup:
                logger.warning(f"Duplicate execution prevented: {idempotency_key[:16]}...")
                return False, {"success": False, "error": "Duplicate blocked", "was_duplicate": True}
            
            success = await self.ledger.create_pending(
                trace_id, idempotency_key, symbol, action, volume, sl, tp,
                strategy, regime, confidence
            )
            if not success:
                return False, {"success": False, "error": "Failed to create ledger record"}
            
            await self.ledger.update_status(trace_id, ExecutionStatus.SENT)
            
            try:
                if asyncio.iscoroutinefunction(mt5_send_fn):
                    mt5_result = await mt5_send_fn(decision)
                else:
                    mt5_result = mt5_send_fn(decision)
            except Exception as e:
                mt5_result = {"success": False, "error": str(e)}
            
            if mt5_result.get("success"):
                ticket = mt5_result.get("ticket")
                price = mt5_result.get("price", 0)
                await self.ledger.update_status(trace_id, ExecutionStatus.CONFIRMED, ticket, price)
                return True, {"success": True, "trace_id": trace_id, "ticket": ticket, "price": price}
            else:
                error = mt5_result.get("error", "Unknown MT5 error")
                await self.ledger.update_status(trace_id, ExecutionStatus.FAILED, error=error)
                return False, {"success": False, "trace_id": trace_id, "error": error}


class ReconciliationEngine:
    def __init__(self, ledger: ExecutionLedger, get_broker_positions_fn: Callable,
                 event_bus: Optional[EventBus] = None):
        self.ledger = ledger
        self.get_broker_positions = get_broker_positions_fn
        self.event_bus = event_bus
        self._running = False
        self._task: Optional[asyncio.Task] = None
        logger.info("ReconciliationEngine initialized")
    
    async def start(self):
        self._running = True
        self._task = asyncio.create_task(self._reconciliation_loop())
        logger.info("Reconciliation engine started")
    
    async def stop(self):
        self._running = False
        if self._task:
            self._task.cancel()
            try:
                await self._task
            except asyncio.CancelledError:
                pass
    
    async def _reconciliation_loop(self):
        while self._running:
            try:
                await self.reconcile()
                await asyncio.sleep(60)
            except asyncio.CancelledError:
                break
            except Exception as e:
                logger.error(f"Reconciliation loop error: {e}")
                await asyncio.sleep(10)
    
    async def reconcile(self) -> dict:
        try:
            broker_positions = await self.get_broker_positions() if asyncio.iscoroutinefunction(self.get_broker_positions) else self.get_broker_positions()
            broker_tickets = {p.get("ticket") for p in broker_positions if p.get("ticket")}
            ledger_records = await self.ledger.get_pending_records()
            ledger_tickets = {r.get("ticket") for r in ledger_records if r.get("ticket")}
            orphan_broker = broker_tickets - ledger_tickets
            orphan_ledger = ledger_tickets - broker_tickets
            consistent = len(orphan_broker) == 0 and len(orphan_ledger) == 0
            logger.info(f"Reconciliation: broker={len(broker_tickets)}, ledger={len(ledger_tickets)}, "
                       f"orphan_broker={len(orphan_broker)}, orphan_ledger={len(orphan_ledger)}")
            return {"consistent": consistent, "broker_count": len(broker_tickets), "ledger_count": len(ledger_tickets)}
        except Exception as e:
            logger.error(f"Reconcile error: {e}")
            return {"consistent": False, "error": str(e)}


class CircuitBreakerState(Enum):
    GREEN = "green"
    YELLOW = "yellow"
    RED = "red"
    HALTED = "halted"


class CircuitBreakerSystem:
    def __init__(self, db_path: str, event_bus: Optional[EventBus] = None):
        self.db_path = db_path
        self.event_bus = event_bus
        self.state = CircuitBreakerState.GREEN
        self.drawdown_hard_limit = 0.15
        self.drawdown_soft_limit = 0.10
        self.peak_equity = 0.0
        self.current_drawdown = 0.0
        self.execution_attempts = 0
        self.execution_failures = 0
        logger.info("CircuitBreakerSystem initialized")
    
    def update_metrics(self, equity: float, execution_success: Optional[bool] = None):
        if equity > self.peak_equity:
            self.peak_equity = equity
        if self.peak_equity > 0:
            self.current_drawdown = (self.peak_equity - equity) / self.peak_equity
        
        if execution_success is not None:
            self.execution_attempts += 1
            if not execution_success:
                self.execution_failures += 1
        
        self._evaluate_state()
    
    def _evaluate_state(self):
        if self.current_drawdown >= self.drawdown_hard_limit:
            self.state = CircuitBreakerState.HALTED
        elif self.current_drawdown >= self.drawdown_soft_limit:
            self.state = CircuitBreakerState.RED
        elif self.state == CircuitBreakerState.RED and self.current_drawdown < self.drawdown_soft_limit * 0.5:
            self.state = CircuitBreakerState.YELLOW
        
        if self.execution_attempts > 10:
            failure_rate = self.execution_failures / self.execution_attempts
            if failure_rate > 0.30:
                self.state = CircuitBreakerState.RED
    
    def can_trade(self) -> Tuple[bool, str]:
        if self.state == CircuitBreakerState.HALTED:
            return False, "System HALTED"
        if self.state == CircuitBreakerState.RED:
            return False, "System RED - no new trades"
        return True, "OK"
    
    async def emergency_flatten(self, close_all_fn: Callable) -> dict:
        logger.critical("EMERGENCY FLATTEN initiated")
        result = await close_all_fn()
        self.state = CircuitBreakerState.HALTED
        return result
    
    async def get_status(self) -> dict:
        return {
            "state": self.state.value,
            "drawdown": self.current_drawdown,
            "execution_failure_rate": round(self.execution_failures / max(1, self.execution_attempts), 4),
        }


class ExecutionConfirmationLoop:
    def __init__(self, ledger: ExecutionLedger, get_position_fn: Callable,
                 event_bus: Optional[EventBus] = None):
        self.ledger = ledger
        self.get_position = get_position_fn
        self.event_bus = event_bus
        self._running = False
        self._task: Optional[asyncio.Task] = None
        logger.info("ExecutionConfirmationLoop initialized")
    
    async def start(self):
        self._running = True
        self._task = asyncio.create_task(self._confirmation_loop())
        logger.info("Confirmation loop started")
    
    async def stop(self):
        self._running = False
        if self._task:
            self._task.cancel()
    
    async def _confirmation_loop(self):
        while self._running:
            try:
                pending = await self.ledger.get_pending_records()
                for record in pending:
                    if record["status"] == "sent" and record.get("ticket"):
                        pos = await self.get_position(record["ticket"]) if asyncio.iscoroutinefunction(self.get_position) else self.get_position(record["ticket"])
                        if pos:
                            await self.ledger.update_status(record["trace_id"], ExecutionStatus.CONFIRMED,
                                                            record["ticket"], pos.get("open_price"))
                await asyncio.sleep(1)
            except asyncio.CancelledError:
                break
            except Exception as e:
                logger.error(f"Confirmation loop error: {e}")
                await asyncio.sleep(5)


class FailureResilienceLayer:
    def __init__(self, db_path: str, mt5_connect_fn: Callable, mt5_is_connected_fn: Callable,
                 event_bus: Optional[EventBus] = None):
        self.db_path = db_path
        self.mt5_connect = mt5_connect_fn
        self.mt5_is_connected = mt5_is_connected_fn
        self.event_bus = event_bus
        self._running = False
        self._reconnect_task: Optional[asyncio.Task] = None
        self.is_connected = False
        self._reconnect_attempts = 0
        self._max_reconnect_attempts = 10
        logger.info("FailureResilienceLayer initialized")
    
    async def start(self):
        self._running = True
        self._reconnect_task = asyncio.create_task(self._reconnect_loop())
        logger.info("Failure resilience started")
    
    async def stop(self):
        self._running = False
        if self._reconnect_task:
            self._reconnect_task.cancel()
    
    async def _reconnect_loop(self):
        while self._running:
            try:
                current = self.mt5_is_connected()
                if not current and not self.is_connected:
                    if self._reconnect_attempts >= self._max_reconnect_attempts:
                        logger.error(f"Max reconnection attempts ({self._max_reconnect_attempts}) reached, giving up")
                        await asyncio.sleep(60)
                        self._reconnect_attempts = 0
                        continue
                    
                    self._reconnect_attempts += 1
                    logger.info(f"MT5 reconnect attempt {self._reconnect_attempts}/{self._max_reconnect_attempts}...")
                    success = self.mt5_connect()
                    if success:
                        self.is_connected = True
                        self._reconnect_attempts = 0
                        logger.info("MT5 reconnected successfully")
                    else:
                        logger.warning(f"MT5 reconnect failed, attempt {self._reconnect_attempts}")
                        await asyncio.sleep(5 * self._reconnect_attempts)  # Exponential backoff
                elif current and not self.is_connected:
                    self.is_connected = True
                    self._reconnect_attempts = 0
                    logger.info("MT5 connection restored")
                await asyncio.sleep(5)
            except asyncio.CancelledError:
                break
            except Exception as e:
                logger.error(f"Reconnect error: {e}")
                await asyncio.sleep(10)


class ExecutionObservability:
    def __init__(self, db_path: str):
        self.db_path = db_path
        self.latency_records = deque(maxlen=10000)
        self.slippage_records = deque(maxlen=10000)
        self.rejection_codes = {}
        logger.info("ExecutionObservability initialized")
    
    def record_latency(self, trace_id: str, latency_ms: float, symbol: str):
        self.latency_records.append({"trace_id": trace_id, "latency_ms": latency_ms, "symbol": symbol})
    
    def record_slippage(self, trace_id: str, expected: float, actual: float, symbol: str):
        if "JPY" in symbol:
            slippage_pips = abs(actual - expected) * 100
        else:
            slippage_pips = abs(actual - expected) * 10000
        self.slippage_records.append({"trace_id": trace_id, "slippage_pips": slippage_pips, "symbol": symbol})
    
    def record_rejection(self, retcode: int, symbol: str):
        self.rejection_codes[retcode] = self.rejection_codes.get(retcode, 0) + 1
    
    def get_report(self) -> dict:
        latencies = [r["latency_ms"] for r in self.latency_records]
        slippages = [r["slippage_pips"] for r in self.slippage_records]
        return {
            "total_records": len(self.latency_records),
            "avg_latency_ms": float(np.mean(latencies)) if latencies else 0,
            "p95_latency_ms": float(np.percentile(latencies, 95)) if latencies else 0,
            "avg_slippage_pips": float(np.mean(slippages)) if slippages else 0,
            "rejection_codes": self.rejection_codes,
        }


class StartupRecoverySequence:
    def __init__(self, ledger: ExecutionLedger, reconciliation_engine: ReconciliationEngine,
                 circuit_breaker: CircuitBreakerSystem, execution_safety: ExecutionSafetyLayer,
                 event_bus: Optional[EventBus] = None):
        self.ledger = ledger
        self.reconciliation = reconciliation_engine
        self.circuit_breaker = circuit_breaker
        self.execution_safety = execution_safety
        self.event_bus = event_bus
        logger.info("StartupRecoverySequence initialized")
    
    async def execute(self) -> Tuple[bool, str]:
        logger.info("=" * 60)
        logger.info("STARTUP RECOVERY SEQUENCE")
        logger.info("=" * 60)
        
        stats = await self.ledger.get_stats()
        logger.info(f"Ledger: {stats}")
        
        report = await self.reconciliation.reconcile()
        if not report.get("consistent", False):
            logger.warning("Reconciliation inconsistency detected, attempting to repair...")
            # В production здесь должна быть логика восстановления
            if len(report.get("orphan_broker", [])) > 0:
                logger.error(f"Orphan broker positions found: {report.get('orphan_broker')}")
                return False, "Orphan positions detected, manual intervention required"
        
        cb_status = await self.circuit_breaker.get_status()
        if cb_status["state"] in ["red", "halted"]:
            return False, f"Circuit breaker in {cb_status['state']}"
        
        if self.execution_safety.kill_switch_active:
            return False, "Kill switch active"
        
        logger.info("RECOVERY COMPLETE - TRADING ENABLED")
        return True, "Recovery complete"


