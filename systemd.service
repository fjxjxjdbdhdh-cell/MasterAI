[Unit]
Description=Master AI Trading Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/master_ai
Environment="DISPLAY=:0"
ExecStart=/usr/bin/python3 /root/master_ai/run.py
Restart=always
RestartSec=10
StandardOutput=append:/var/log/master_ai.log
StandardError=append:/var/log/master_ai_error.log

[Install]
WantedBy=multi-user.target
